{"type":"message","id":"cfa9e919","parentId":"bfe6a450","timestamp":"2026-04-14T10:31:01.572Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"\nThe process has been terminated. Let me check if there are any recent logs or if I can see what the issue might be. Since the script appeared to hang after connecting to the SSH server and fetching positions, there might be an issue with the script itself or the server connection.\n\nLet me try to run the script again but with a shorter timeout to see what happens, or examine the script first to understand what it's doing.","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n"},{"type":"toolCall","id":"call_5251c3c4c0df4b91901e2f2e","name":"read","arguments":{"path":"/Users/lynch/.openclaw/workspace-chairong/scripts/postmarket_pipeline.py"}}],"api":"openai-completions","provider":"custom-customb2","model":"glm-5-turbo","usage":{"input":16,"output":118,"cacheRead":44140,"cacheWrite":0,"totalTokens":44274,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1776162658402,"responseId":"2026041418305981299ba824a64627"}}
{"type":"message","id":"d1f617b3","parentId":"cfa9e919","timestamp":"2026-04-14T10:31:01.580Z","message":{"role":"toolResult","toolCallId":"call_5251c3c4c0df4b91901e2f2e","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n盘后复盘全流程自动化脚本 (postmarket_pipeline.py)\n\n职责：替代 cron LLM session，将盘后复盘固化为 Python 脚本\n流程：SSH拉数据 → Baostock查行情 → 计算盈亏 → 生成报告 → 发邮件 → 飞书通知\n\n用法：\n    uv run python scripts/postmarket_pipeline.py [--date YYYYMMDD] [--dry-run]\n\n退出码：\n    0  = 全流程成功\n    1  = SSH 连接失败\n    2  = 行情数据获取失败\n    3  = 邮件发送失败\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport logging\nimport os\nimport smtplib\nimport sys\nimport time\nfrom datetime import date, datetime, timedelta\nfrom email.header import Header\nfrom email.mime.text import MIMEText\nfrom pathlib import Path\n\nimport baostock as bs\nimport tushare\nimport paramiko\n\n# ── Tushare 配置 ─────────────────────────────────────────\nTUSHARE_TOKEN_FILE = Path(\"/Users/lynch/Codes/MyQuant/.myquant/tushare.local.json\")\n\ndef _get_tushare_token() -> str:\n    \"\"\"从 MyQuant 配置读取 Tushare token\"\"\"\n    try:\n        data = json.loads(TUSHARE_TOKEN_FILE.read_text(encoding=\"utf-8\"))\n        return data.get(\"token\", \"\")\n    except Exception:\n        return \"\"\n\ndef _ts_api():\n    return tushare.pro_api(_get_tushare_token())\n\n# ── 路径配置 ──────────────────────────────────────────────\nWORKSPACE = Path(\"/Users/lynch/.openclaw/workspace-chairong\")\nREPORT_DIR = WORKSPACE / \"strategies\" / \"reports\"\nSTATUS_FILE = Path(\"/tmp/openclaw/postmarket_pipeline_status.json\")\n\n# ── SSH 配置 ───────────────────────────────────────────────\nSSH_HOST = \"118.89.118.199\"\nSSH_USER = \"Administrator\"\nSSH_KEY_PATH = Path(\"/Users/lynch/.ssh/id_ed25519\")\nSSH_REMOTE_POSITIONS = r\"E:\\Quant\\Datas\\positions.json\"\nSSH_REMOTE_RESULT = r\"E:\\Quant\\Datas\\daily_result.json\"\nSSH_REMOTE_LOG = r\"E:\\Quant\\strategies\\logs\\trader_{ymd}.log\"\nSSH_LOCAL_POSITIONS = Path(\"/Users/lynch/Codes/MyQuant/qmt_sync/positions.json\")\n\n# ── 邮件配置 ──────────────────────────────────────────────\nSMTP_SERVER = \"smtp.gmail.com\"\nSMTP_PORT = 587\nSMTP_USER = \"yuanlynch@gmail.com\"\nSMTP_PASSWORD = \"jsnjyjwpavymplev\"\nEMAIL_TO = \"958500892@qq.com\"\nEMAIL_CC = \"l1cheeyuan@163.com\"\n\n# ── 2026 年休市日 ────────────────────────────────────────\nHOLIDAYS_2026 = {\n    \"20260101\", \"20260102\",\n    \"20260216\", \"20260217\", \"20260218\", \"20260219\", \"20260220\", \"20260223\",\n    \"20260406\",\n    \"20260501\", \"20260504\", \"20260505\",\n    \"20260619\",\n    \"20260925\",\n    \"20261001\", \"20261002\", \"20261005\", \"20261006\", \"20261007\",\n}\n\n# ── 日志 ──────────────────────────────────────────────────\nlogging.basicConfig(\n    level=logging.INFO,\n    format=\"%(asctime)s [%(levelname)s] %(message)s\",\n    handlers=[\n        logging.StreamHandler(sys.stdout),\n        logging.FileHandler(\"/tmp/openclaw/postmarket_pipeline.log\", encoding=\"utf-8\"),\n    ],\n)\nlog = logging.getLogger(\"postmarket\")\n\n\ndef _write_status(step: str, status: str, detail: str = \"\"):\n    STATUS_FILE.parent.mkdir(parents=True, exist_ok=True)\n    STATUS_FILE.write_text(json.dumps({\n        \"step\": step, \"status\": status, \"detail\": detail,\n        \"timestamp\": datetime.now().isoformat(),\n    }, ensure_ascii=False, indent=2))\n\n\ndef _refresh_positions_from_qmt(data: dict, ymd: str) -> dict:\n    \"\"\"positions.json 过期时，从 QMT 直接查询实时持仓并更新远程文件\"\"\"\n    import random\n    try:\n        ssh = _ssh_connect()\n\n        # 上传并执行查询脚本\n        script = r'''from xtquant.xttrader import XtQuantTrader\nfrom xtquant.xttype import StockAccount\nimport json, random, time\nxt = XtQuantTrader(r\"E:\\国金QMT交易端模拟\\userdata_mini\", random.randint(100000,999999))\nxt.start()\nfor i in range(10):\n    if xt.connect() == 0: break\n    time.sleep(5)\nacc = StockAccount(\"68039812\")\nxt.subscribe(acc)\ntime.sleep(2)\nasset = xt.query_stock_asset(acc)\npos = xt.query_stock_positions(acc) or []\nxt.stop()\npos_data = []\nfor p in pos:\n    if p.volume > 0:\n        pos_data.append({\"stock_code\": p.stock_code, \"volume\": p.volume, \"open_price\": p.open_price, \"market_value\": p.market_value})\nresult = {\"timestamp\": \"''' + f\"{ymd[:4]}-{ymd[4:6]}-{ymd[6:8]} 15:00:00\" + r'''\", \"account\": \"68039812\",\n    \"asset\": {\"可用资金\": asset.cash if asset else 0, \"总资产\": asset.total_asset if asset else 0},\n    \"position\": pos_data}\nwith open(r\"E:\\Quant\\Datas\\positions.json\", \"w\", encoding=\"utf-8\") as f:\n    json.dump(result, f, ensure_ascii=False, indent=2)\nprint(json.dumps(result, ensure_ascii=False))'''\n\n        sftp = ssh.open_sftp()\n        with sftp.open(r\"E:\\Quant\\strategies\\refresh_pos.py\", \"w\") as f:\n            f.write(script)\n        sftp.close()\n\n        _, out, _ = ssh.exec_command(\n            r\"E:\\miniconda\\envs\\MyQuant\\python.exe -u E:\\Quant\\strategies\\refresh_pos.py 2>&1\",\n            timeout=60\n        )\n        import time as _t\n        _t.sleep(30)\n        output = b\"\"\n        try:\n            while True:\n                chunk = out.channel.recv(4096)\n                if not chunk: break\n                output += chunk\n        except: pass\n\n        ssh.close()\n\n        text = output.decode(\"utf-8\", \"replace\")\n        # 找 JSON 输出\n        json_start = text.find(\"{\")\n        if json_start >= 0:\n            pos_json = json.loads(text[json_start:])\n            data[\"positions\"] = pos_json\n            log.info(f\"QMT 持仓: {len(pos_json.get('position', []))} 只, 总资产 {pos_json.get('asset', {}).get('总资产', 0)}\")\n        else:\n            log.warning(f\"QMT 查询无输出: {text[:200]}\")\n    except Exception as e:\n        log.warning(f\"QMT 直接查询失败: {e}\")\n\n    return data\n\n\ndef _is_trading_day(ymd: str) -> bool:\n    d = datetime.strptime(ymd, \"%Y%m%d\")\n    if d.weekday() >= 5:\n        return False\n    return ymd not in HOLIDAYS_2026\n\n\ndef _ssh_connect():\n    \"\"\"用密钥认证连接云服务器\"\"\"\n    ssh = paramiko.SSHClient()\n    ssh.set_missing_host_key_policy(paramiko.AutoAddPolicy())\n    key = paramiko.Ed25519Key.from_private_key_file(str(SSH_KEY_PATH))\n    ssh.connect(SSH_HOST, port=22, username=SSH_USER, pkey=key, timeout=15)\n    return ssh\n\n\ndef step1_ssh_pull(ymd: str) -> dict:\n    \"\"\"SSH 拉取持仓、交易结果、日志\"\"\"\n    ssh = _ssh_connect()\n    sftp = ssh.open_sftp()\n    result = {}\n\n    # positions.json\n    try:\n        with sftp.open(SSH_REMOTE_POSITIONS, \"r\") as f:\n            positions = json.loads(f.read().decode(\"utf-8\"))\n        result[\"positions\"] = positions\n        # 保存本地\n        SSH_LOCAL_POSITIONS.parent.mkdir(parents=True, exist_ok=True)\n        SSH_LOCAL_POSITIONS.write_text(json.dumps(positions, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n    except Exception as e:\n        log.warning(f\"拉取 positions.json 失败: {e}\")\n        result[\"positions\"] = {}\n\n    # daily_result.json\n    try:\n        with sftp.open(SSH_REMOTE_RESULT, \"r\") as f:\n            daily_result = json.loads(f.read().decode(\"utf-8\"))\n        result[\"daily_result\"] = daily_result\n    except Exception as e:\n        log.warning(f\"拉取 daily_result.json 失败: {e}\")\n        result[\"daily_result\"] = {}\n\n    # trader log\n    remote_log_path = SSH_REMOTE_LOG.format(ymd=ymd)\n    try:\n        with sftp.open(remote_log_path, \"r\") as f:\n            result[\"trader_log\"] = f.read().decode(\"utf-8\", errors=\"replace\")\n    except Exception:\n        result[\"trader_log\"] = \"\"\n\n    sftp.close()\n    ssh.close()\n    return result\n\n\ndef step2_fetch_quotes(codes: list[str], ymd: str) -> dict:\n    \"\"\"Tushare 查今日行情 + 大盘（Baostock 降级）\"\"\"\n    result = {}\n    ts_ok = False\n\n    # ── Tushare 主力 ──\n    try:\n        ts = _ts_api()\n        for code in codes:\n            ts_code = f\"{code}.SH\" if code.startswith(\"6\") else f\"{code}.SZ\"\n            try:\n                df = ts.daily(ts_code=ts_code, start_date=ymd, end_date=ymd)\n                if len(df) > 0:\n                    row = df.iloc[0]\n                    result[code] = {\n                        \"date\": str(row[\"trade_date\"]),\n                        \"open\": float(row[\"open\"]), \"high\": float(row[\"high\"]),\n                        \"low\": float(row[\"low\"]), \"close\": float(row[\"close\"]),\n                        \"volume\": int(row[\"vol\"]),\n                        \"pctChg\": float(row[\"pct_chg\"]) if row[\"pct_chg\"] == row[\"pct_chg\"] else 0.0,\n                    }\n            except Exception as e:\n                log.warning(f\"Tushare 查 {ts_code} 失败: {e}\")\n\n        # 上证指数\n        try:\n            df = ts.index_daily(ts_code=\"000001.SH\", start_date=ymd, end_date=ymd)\n            if len(df) > 0:\n                row = df.iloc[0]\n                result[\"SH_INDEX\"] = {\n                    \"date\": str(row[\"trade_date\"]),\n                    \"open\": float(row[\"open\"]), \"high\": float(row[\"high\"]),\n                    \"low\": float(row[\"low\"]), \"close\": float(row[\"close\"]),\n                    \"pctChg\": float(row[\"pct_chg\"]) if row[\"pct_chg\"] == row[\"pct_chg\"] else 0.0,\n                }\n        except Exception as e:\n            log.warning(f\"Tushare 查上证指数失败: {e}\")\n\n        ts_ok = len(result) > 0  # 只要有任何数据就算成功\n    except Exception as e:\n        log.warning(f\"Tushare 初始化失败: {e}\")\n\n    if ts_ok:\n        return result\n\n    # ── Baostock 降级 ──\n    log.info(\"Tushare 失败，降级到 Baostock\")\n    lg = bs.login()\n    bs_date = f\"{ymd[:4]}-{ymd[4:6]}-{ymd[6:8]}\"\n    for code in codes:\n        full = f\"sh.{code}\" if code.startswith(\"6\") else f\"sz.{code}\"\n        try:\n            rs = bs.query_history_k_data_plus(\n                full, \"date,open,high,low,close,volume,pctChg\",\n                start_date=bs_date, end_date=bs_date,\n                frequency=\"d\", adjustflag=\"2\",\n            )\n            rows = []\n            while rs.error_code == \"0\" and rs.next():\n                rows.append(rs.get_row_data())\n            if rows:\n                r = rows[0]\n                result[code] = {\n                    \"date\": r[0], \"open\": float(r[1]), \"high\": float(r[2]),\n                    \"low\": float(r[3]), \"close\": float(r[4]),\n                    \"volume\": int(r[5]), \"pctChg\": float(r[6]) if r[6] else 0.0,\n                }\n        except Exception as e:\n            log.warning(f\"Baostock 查 {code} 失败: {e}\")\n    try:\n        rs = bs.query_history_k_data_plus(\n            \"sh.000001\", \"date,open,high,low,close,pctChg\",\n            start_date=bs_date, end_date=bs_date, frequency=\"d\", adjustflag=\"2\",\n        )\n        rows = []\n        while rs.error_code == \"0\" and rs.next():\n            rows.append(rs.get_row_data())\n        if rows:\n            r = rows[0]\n            result[\"SH_INDEX\"] = {\n                \"date\": r[0], \"open\": float(r[1]), \"high\": float(r[2]),\n                \"low\": float(r[3]), \"close\": float(r[4]),\n                \"pctChg\": float(r[5]) if r[5] else 0.0,\n            }\n    except Exception as e:\n        log.warning(f\"Baostock 查上证指数失败: {e}\")\n    bs.logout()\n    return result\n\n\ndef step3_fetch_prev_close(codes: list[str], ymd: str) -> dict:\n    \"\"\"Tushare 查前一日收盘价（用于验证 max_price），Baostock 降级\"\"\"\n    result = {}\n    # 算前一交易日\n    try:\n        from datetime import timedelta\n        prev_d = (datetime.strptime(ymd, \"%Y%m%d\") - timedelta(days=1)).strftime(\"%Y%m%d\")\n        # 往前多取几天确保有数据\n        start_d = (datetime.strptime(ymd, \"%Y%m%d\") - timedelta(days=10)).strftime(\"%Y%m%d\")\n    except Exception:\n        prev_d = (date.today() - timedelta(days=1)).strftime(\"%Y%m%d\")\n        start_d = (date.today() - timedelta(days=10)).strftime(\"%Y%m%d\")\n\n    # ── Tushare 主力 ──\n    try:\n        ts = _ts_api()\n        for code in codes:\n            ts_code = f\"{code}.SH\" if code.startswith(\"6\") else f\"{code}.SZ\"\n            try:\n                df = ts.daily(ts_code=ts_code, start_date=start_d, end_date=prev_d)\n                if len(df) > 0:\n                    result[code] = float(df.iloc[-1][\"close\"])\n            except Exception as e:\n                log.warning(f\"Tushare prev_close {ts_code} 失败: {e}\")\n        return result\n    except Exception as e:\n        log.warning(f\"Tushare prev_close 失败: {e}\")\n\n    # ── Baostock 降级 ──\n    lg = bs.login()\n    end = (datetime.strptime(prev_d, \"%Y%m%d\")).strftime(\"%Y-%m-%d\")\n    start = (datetime.strptime(start_d, \"%Y%m%d\")).strftime(\"%Y-%m-%d\")\n    for code in codes:\n        full = f\"sh.{code}\" if code.startswith(\"6\") else f\"sz.{code}\"\n        try:\n            rs = bs.query_history_k_data_plus(\n                full, \"date,close\", start_date=start, end_date=end,\n                frequency=\"d\", adjustflag=\"2\",\n            )\n            rows = []\n            while rs.error_code == \"0\" and rs.next():\n                rows.append(rs.get_row_data())\n            if rows:\n                result[code] = float(rows[-1][1])\n        except Exception:\n            pass\n    bs.logout()\n    return result\n\n\ndef step4_build_report(data: dict, quotes: dict, prev_close: dict, ymd: str) -> str:\n    \"\"\"生成复盘报告（Markdown）\"\"\"\n    positions = data.get(\"positions\", {})\n    daily_result = data.get(\"daily_result\", {})\n    trader_log = data.get(\"trader_log\", \"\")\n\n    # 资产信息（asset 是 dict）\n    asset_info = positions.get(\"asset\", {})\n    total_asset = float(asset_info.get(\"总资产\", 0))\n    available = float(asset_info.get(\"可用资金\", 0))\n\n    # 持仓列表\n    pos_list = positions.get(\"position\", [])\n    pos_codes = []\n    pos_rows = []\n    position_value = 0.0\n\n    # 用 Tushare 或 Baostock 查股票名字（如果 positions.json 里没有）\n    code_name_map = {}\n    for p in pos_list:\n        raw_code = str(p.get(\"stock_code\", p.get(\"证券代码\", \"\")))\n        code = raw_code.split(\".\")[0].zfill(6) if \".\" in raw_code else raw_code.zfill(6)\n        name = p.get(\"stock_name\", p.get(\"证券名称\", \"\"))\n        if not name:\n            code_name_map[code] = None  # 后面用 Baostock 查\n        else:\n            code_name_map[code] = name\n    # 批量查名字\n    missing_names = [c for c, n in code_name_map.items() if n is None]\n    if missing_names:\n        lg = bs.login()\n        for code in missing_names:\n            full = f\"sh.{code}\" if code.startswith(\"6\") else f\"sz.{code}\"\n            try:\n                rs = bs.query_stock_basic(code=full)\n                while rs.error_code == \"0\" and rs.next():\n                    row = rs.get_row_data()\n                    if row[1]:\n                        code_name_map[code] = row[1]\n                        break\n            except Exception:\n                pass\n        bs.logout()\n\n    for p in pos_list:\n        raw_code = str(p.get(\"stock_code\", p.get(\"证券代码\", \"\")))\n        code = raw_code.split(\".\")[0].zfill(6) if \".\" in raw_code else raw_code.zfill(6)\n        name = code_name_map.get(code, \"\")\n        volume = int(p.get(\"volume\", p.get(\"持仓数量\", 0)))\n        open_price = float(p.get(\"open_price\", p.get(\"成本价\", 0)))\n        market_val = float(p.get(\"market_value\", p.get(\"市值\", 0)))\n        # 优先用行情 close 作为现价（positions.json 的 market_value 可能不准确）\n        today_info = quotes.get(code, {})\n        current_price = float(today_info.get(\"close\", 0)) if today_info.get(\"close\") else (market_val / volume if volume > 0 else open_price)\n        if current_price > 0 and current_price != market_val / volume:\n            market_val = current_price * volume  # 用行情价重新算市值\n\n        position_value += market_val\n        pos_codes.append(code)\n        today_chg = today_info.get(\"pctChg\", 0)\n        profit_pct = ((current_price - open_price) / open_price * 100) if open_price > 0 else 0\n\n        pos_rows.append({\n            \"code\": code, \"name\": name, \"volume\": volume,\n            \"cost\": open_price, \"current\": current_price,\n            \"market_val\": market_val, \"profit_pct\": profit_pct,\n            \"today_chg\": today_chg,\n        })\n\n    # 大盘\n    sh = quotes.get(\"SH_INDEX\", {})\n    sh_chg = sh.get(\"pctChg\", 0)\n\n    # 交易记录（优先 daily_result，降级从 trader_log 解析）\n    trades = daily_result.get(\"trades\", [])\n    sells = daily_result.get(\"sells\", [])\n    buys = daily_result.get(\"buys\", [])\n\n    if not sells and not buys and trader_log:\n        # 从日志解析交易记录\n        import re\n        for line in trader_log.split(\"\\n\"):\n            line = line.strip()\n            m = re.match(r\"\\[.+?\\] \\[卖出\\] \\(?(.+?)\\)?\\((.+?)\\) (\\d+)股 单号:(\\d+)\", line)\n            if m:\n                name = m.group(1).strip() if m.group(1) else \"\"\n                sells.append({\"code\": m.group(2), \"name\": name, \"volume\": int(m.group(3)), \"order_id\": m.group(4)})\n            m = re.match(r\"\\[.+?\\] \\[买入\\] (.+?)\\((.+?)\\) (\\d+)手.*?单号:(\\d+)\", line)\n            if m:\n                buys.append({\"code\": m.group(2), \"name\": m.group(1), \"volume\": int(m.group(3)) * 100, \"order_id\": m.group(4)})\n\n    # 日志关键行\n    log_lines = trader_log.split(\"\\n\") if trader_log else []\n    log_summary = []\n    for line in log_lines:\n        line = line.strip()\n        if line and any(kw in line for kw in [\"═══\", \"买入\", \"卖出\", \"成交\", \"失败\", \"error\", \"ERROR\", \"计划\"]):\n            log_summary.append(line)\n    log_text = \"\\n\".join(log_summary[:20]) if log_summary else \"无关键日志\"\n\n    # 盈亏汇总\n    total_profit = sum(r[\"market_val\"] - r[\"cost\"] * r[\"volume\"] for r in pos_rows)\n    total_profit_pct = (total_profit / total_asset * 100) if total_asset > 0 else 0\n\n    # 构建 Markdown\n    md = f\"\"\"# 盘后复盘报告 - {ymd[:4]}年{ymd[4:6]}月{ymd[6:8]}日\n\n## 📊 资产概况\n\n| 项目 | 金额 |\n|:--|--:|\n| 总资产 | ¥{total_asset:,.2f} |\n| 可用资金 | ¥{available:,.2f} |\n| 持仓市值 | ¥{position_value:,.2f} |\n| 资金使用率 | {(position_value/total_asset*100) if total_asset > 0 else 0:.2f}% |\n| 持仓盈亏 | ¥{total_profit:+,.2f} ({total_profit_pct:+.2f}%) |\n\n## 📈 大盘表现\n\n| 指数 | 涨跌幅 |\n|:--|--:|\n| 上证指数 | {sh_chg:+.2f}% |\n\n\"\"\"\n\n    # 持仓明细\n    if pos_rows:\n        md += \"## 💼 持仓明细\\n\\n\"\n        md += \"| 代码 | 名称 | 持仓 | 成本 | 现价 | 市值 | 盈亏% | 今日涨跌 |\\n\"\n        md += \"|:--|:--|--:|--:|--:|--:|--:|--:|\\n\"\n        for r in pos_rows:\n            emoji = \"🟢\" if r[\"profit_pct\"] >= 0 else \"🔴\"\n            md += f\"| {r['code']} | {r['name']} | {r['volume']} | {r['cost']:.3f} | {r['current']:.3f} | ¥{r['market_val']:,.0f} | {emoji} {r['profit_pct']:+.2f}% | {r['today_chg']:+.2f}% |\\n\"\n    else:\n        md += \"## 💼 持仓\\n\\n当前空仓。\\n\"\n\n    # 今日交易\n    if trades or buys or sells:\n        md += \"## 🔄 今日交易\\n\\n\"\n        for t in buys:\n            md += f\"- **买入** {t.get('code','')} {t.get('name','')} {t.get('volume',0)}股 @ {t.get('price','')}\\n\"\n        for t in sells:\n            md += f\"- **卖出** {t.get('code','')} {t.get('name','')} {t.get('volume',0)}股 @ {t.get('price','')}\\n\"\n        if not buys and not sells:\n            md += \"今日无交易。\\n\"\n    else:\n        md += \"## 🔄 今日交易\\n\\n今日无交易。\\n\"\n\n    # 执行日志\n    md += f\"## 📋 执行日志\\n\\n```\\n{log_text}\\n```\\n\"\n\n    # 风险提示\n    md += f\"\"\"## ⚠️ 风险提示\n\n- 仓位使用率 {'极低 (<1%)，建议提高' if (position_value/total_asset*100 if total_asset > 0 else 0) < 1 else '正常'}\n- {'大盘表现弱于持仓，注意风险' if sh_chg < 0 and total_profit > 0 else '大盘与持仓表现一致'}\n\n---\n*柴荣量化系统自动生成 · {datetime.now().strftime('%Y-%m-%d %H:%M')}*\"\"\"\n\n    return md\n\n\ndef step5_send_email(md_report: str, ymd: str) -> bool:\n    \"\"\"发送复盘邮件\"\"\"\n    html = _md_to_html(md_report)\n    subject = f\"📊 QMT盘后复盘报告 - {ymd[:4]}年{ymd[4:6]}月{ymd[6:8]}日\"\n\n    msg = MIMEText(html, \"html\", \"utf-8\")\n    msg[\"From\"] = Header(\"柴荣量化系统\", \"utf-8\")\n    msg[\"To\"] = EMAIL_TO\n    msg[\"Cc\"] = EMAIL_CC\n    msg[\"Subject\"] = Header(subject, \"utf-8\")\n\n    try:\n        server = smtplib.SMTP(SMTP_SERVER, SMTP_PORT)\n        server.starttls()\n        server.login(SMTP_USER, SMTP_PASSWORD)\n        server.sendmail(SMTP_USER, [EMAIL_TO, EMAIL_CC], msg.as_string())\n        server.quit()\n        log.info(\"邮件发送成功\")\n        return True\n    except Exception as e:\n        log.error(f\"邮件发送失败: {e}\")\n        return False\n\n\ndef _md_to_html(md: str) -> str:\n    \"\"\"Markdown → HTML\"\"\"\n    lines = md.split(\"\\n\")\n    out = []\n    in_table = False\n    for line in lines:\n        s = line.strip()\n        if s.startswith(\"### \"):\n            out.append(f\"<h4>{s[4:]}</h4>\")\n        elif s.startswith(\"## \"):\n            out.append(f\"<h3>{s[3:]}</h3>\")\n        elif s.startswith(\"# \"):\n            out.append(f\"<h2>{s[2:]}</h2>\")\n        elif s.startswith(\"- \"):\n            out.append(f\"<li>{s[2:]}</li>\")\n        elif s.startswith(\"| \") and \"|\" in s[1:]:\n            cells = [c.strip() for c in s.split(\"|\")[1:-1]]\n            if all(set(c) <= set(\"-: \") for c in cells):\n                continue\n            if not in_table:\n                out.append('<table>')\n                in_table = True\n            out.append(\"<tr>\" + \"\".join(f\"<td>{c}</td>\" for c in cells) + \"</tr>\")\n        elif s == \"---\":\n            out.append(\"<hr>\")\n        elif s == \"\":\n            if in_table:\n                out.append(\"</table>\")\n                in_table = False\n            out.append(\"\")\n        elif s.startswith(\"```\"):\n            continue  # 跳过代码块标记\n        else:\n            if in_table:\n                out.append(\"</table>\")\n                in_table = False\n            out.append(f\"<p>{s}</p>\")\n    if in_table:\n        out.append(\"</table>\")\n\n    body = \"\\n\".join(out)\n    return f\"\"\"<html><head><meta charset=\"utf-8\"><style>\nbody {{ font-family: 'Microsoft YaHei', 'PingFang SC', Arial, sans-serif; font-size: 14px; line-height: 1.6; color: #333; max-width: 800px; margin: 0 auto; padding: 20px; }}\nh2 {{ color: #1a1a2e; border-bottom: 2px solid #e94560; padding-bottom: 8px; }}\nh3 {{ color: #16213e; margin-top: 24px; }}\nh4 {{ color: #0f3460; }}\ntable {{ border-collapse: collapse; width: 100%; font-size: 13px; margin: 12px 0; }}\nth {{ background: #1a1a2e; color: white; padding: 8px 12px; text-align: left; }}\ntd {{ border: 1px solid #ddd; padding: 8px 12px; }}\ntr:nth-child(even) {{ background: #f9f9f9; }}\nli {{ margin: 4px 0; }}\nhr {{ border: none; border-top: 1px solid #eee; margin: 20px 0; }}\n</style></head><body>{body}</body></html>\"\"\"\n\n\ndef main():\n    parser = argparse.ArgumentParser(description=\"盘后复盘全流程自动化\")\n    parser.add_argument(\"--date\", default=\"\", help=\"YYYYMMDD\")\n    parser.add_argument(\"--dry-run\", action=\"store_true\", help=\"只生成报告，不发邮件\")\n    args = parser.parse_args()\n\n    ymd = args.date.replace(\"-\", \"\") if args.date else date.today().strftime(\"%Y%m%d\")\n    log.info(f\"═══ 盘后复盘启动 date={ymd} ═══\")\n\n    # 交易日检查\n    if not _is_trading_day(ymd):\n        log.info(f\"今日 {ymd} 非交易日，跳过\")\n        return 0\n\n    # Step 1: SSH 拉取数据\n    _write_status(\"ssh_pull\", \"running\")\n    try:\n        data = step1_ssh_pull(ymd)\n        pos_count = len(data.get(\"positions\", {}).get(\"position\", []))\n        _write_status(\"ssh_pull\", \"done\", f\"持仓 {pos_count} 只\")\n        log.info(f\"Step 1 OK: 持仓 {pos_count} 只\")\n    except Exception as e:\n        _write_status(\"ssh_pull\", \"failed\", str(e))\n        log.error(f\"Step 1 失败: {e}\")\n        sys.exit(1)\n\n    # Step 1.5: 检查 positions.json 是否过期，过期则从 QMT 直接查询\n    pos_data = data.get(\"positions\", {})\n    pos_ts = pos_data.get(\"timestamp\", \"\")\n    today_str = f\"{ymd[:4]}-{ymd[4:6]}-{ymd[6:8]}\"\n    if pos_ts and pos_ts[:10] != today_str:\n        log.info(f\"positions.json 过期 ({pos_ts[:10]} ≠ {today_str})，从 QMT 直接查询\")\n        data = _refresh_positions_from_qmt(data, ymd)\n        pos_count = len(data.get(\"positions\", {}).get(\"position\", []))\n        log.info(f\"Step 1.5 OK: QMT 实时持仓 {pos_count} 只\")\n\n    # Step 2: 查行情\n    _write_status(\"fetch_quotes\", \"running\")\n    pos_codes = []\n    for p in data.get(\"positions\", {}).get(\"position\", []):\n        raw = str(p.get(\"stock_code\", p.get(\"证券代码\", \"\")))\n        code = raw.split(\".\")[0].zfill(6) if \".\" in raw else raw.zfill(6)\n        if code != \"000000\":\n            pos_codes.append(code)\n    quotes = step2_fetch_quotes(pos_codes, ymd)\n    sh = quotes.get(\"SH_INDEX\", {})\n    _write_status(\"fetch_quotes\", \"done\", f\"上证 {sh.get('pctChg',0):+.2f}%\")\n    log.info(f\"Step 2 OK: 上证 {sh.get('pctChg',0):+.2f}%, 查到 {len(quotes)-1}/{len(pos_codes)} 只行情\")\n\n    # Step 3: 查前收盘价\n    _write_status(\"fetch_prev_close\", \"running\")\n    prev_close = step3_fetch_prev_close(pos_codes, ymd)\n    _write_status(\"fetch_prev_close\", \"done\", f\"{len(prev_close)} 只\")\n    log.info(f\"Step 3 OK: 前收盘价 {len(prev_close)} 只\")\n\n    # Step 4: 生成报告\n    _write_status(\"build_report\", \"running\")\n    md = step4_build_report(data, quotes, prev_close, ymd)\n    REPORT_DIR.mkdir(parents=True, exist_ok=True)\n    report_path = REPORT_DIR / f\"post_market_review_{ymd}.md\"\n    report_path.write_text(md, encoding=\"utf-8\")\n    _write_status(\"build_report\", \"done\", str(report_path))\n    log.info(f\"Step 4 OK: 报告已保存到 {report_path}\")\n\n    # Step 5: 发邮件\n    if not args.dry_run:\n        _write_status(\"send_email\", \"running\")\n        ok = step5_send_email(md, ymd)\n        if ok:\n            _write_status(\"send_email\", \"done\")\n            log.info(\"Step 5 OK: 邮件已发送\")\n        else:\n            _write_status(\"send_email\", \"failed\")\n            log.error(\"Step 5 失败: 邮件发送失败\")\n            sys.exit(3)\n    else:\n        log.info(\"[DRY RUN] 跳过邮件\")\n\n    _write_status(\"complete\", \"done\")\n    log.info(\"═══ 盘后复盘完成 ═══\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1776162661579}}
