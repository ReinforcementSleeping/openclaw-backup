{"type":"message","id":"577aac7b","parentId":"9377b26e","timestamp":"2026-04-15T00:05:50.788Z","message":{"role":"toolResult","toolCallId":"call_0a7ee07b14b849239698e99c","toolName":"read","content":[{"type":"text","text":"from __future__ import annotations\n\nimport argparse\nimport os\nfrom dataclasses import replace\nfrom pathlib import Path\n\nfrom .config.settings import DEFAULT_SETTINGS, Settings, load_settings\nfrom .tasks.afterclose_review import run_afterclose\nfrom .tasks.prewarm_industry_cons import run as run_warm_cons\nfrom .tasks.preopen_run import run_preopen\nfrom .utils.dates import parse_yyyymmdd, today_local, yyyymmdd\nfrom .utils.paths import default_paths\n\n\ndef _parse_args() -> argparse.Namespace:\n    p = argparse.ArgumentParser(prog=\"myquant\")\n    sub = p.add_subparsers(dest=\"cmd\", required=True)\n\n    p_pre = sub.add_parser(\"preopen\")\n    p_pre.add_argument(\"--date\", default=\"\", help=\"YYYYMMDD or YYYY-MM-DD\")\n    p_pre.add_argument(\"--top-n\", type=int, default=None)\n    p_pre.add_argument(\"--top-k-industries\", type=int, default=None)\n    p_pre.add_argument(\"--skip-industry\", action=\"store_true\")\n\n    p_af = sub.add_parser(\"afterclose\")\n    p_af.add_argument(\"--date\", default=\"\", help=\"YYYYMMDD or YYYY-MM-DD\")\n    p_af.add_argument(\"--trades\", default=\"\", help=\"trades csv/xlsx path\")\n    p_af.add_argument(\"--positions\", default=\"\", help=\"positions csv/xlsx path\")\n\n    p_wc = sub.add_parser(\"warm-cons\")\n    p_wc.add_argument(\"--date\", default=\"\", help=\"YYYYMMDD or YYYY-MM-DD\")\n\n    return p.parse_args()\n\n\ndef main() -> int:\n    args = _parse_args()\n    paths = default_paths()\n\n    d = today_local() if not args.date else parse_yyyymmdd(args.date)\n    ymd = yyyymmdd(d)\n\n    settings: Settings = load_settings(project_root=paths.root)\n    os.environ[\"MYQUANT_LLM_TIMEOUT\"] = str(float(getattr(settings, \"llm_timeout_sec\", 45.0) or 45.0))\n    os.environ[\"MYQUANT_LLM_RETRIES\"] = str(int(getattr(settings, \"llm_retries\", 3) or 3))\n    os.environ[\"MYQUANT_LLM_BATCH_SIZE\"] = str(int(getattr(settings, \"llm_batch_size\", 20) or 20))\n    os.environ[\"MYQUANT_LLM_MAX_WORKERS\"] = str(int(getattr(settings, \"llm_max_workers\", 3) or 3))\n    os.environ[\"MYQUANT_INDUSTRY_NEWS_BOOST_MAX\"] = str(float(getattr(settings, \"industry_news_boost_max\", 0.03) or 0.03))\n    os.environ[\"MYQUANT_INDUSTRY_NEWS_BOOST_SCALE\"] = str(float(getattr(settings, \"industry_news_boost_scale\", 6.0) or 6.0))\n    os.environ[\"MYQUANT_POLICY_CYCLE_BOOST_MAX\"] = str(float(getattr(settings, \"policy_cycle_boost_max\", 0.02) or 0.02))\n    os.environ[\"MYQUANT_POLICY_CYCLE_BOOST_SCALE\"] = str(float(getattr(settings, \"policy_cycle_boost_scale\", 6.0) or 6.0))\n    if args.cmd == \"preopen\":\n        if args.top_n is not None:\n            settings = replace(settings, top_n=int(args.top_n))\n        if args.top_k_industries is not None:\n            settings = replace(settings, top_k_industries=int(args.top_k_industries))\n        run_preopen(run_date=d, settings=settings, paths=paths, skip_industry=bool(args.skip_industry))\n        return 0\n\n    if args.cmd == \"afterclose\":\n        trades = Path(args.trades) if args.trades else None\n        positions = Path(args.positions) if args.positions else None\n        run_afterclose(run_date=d, settings=settings, paths=paths, trades_path=trades, positions_path=positions)\n        return 0\n\n    if args.cmd == \"warm-cons\":\n        run_warm_cons(run_date=d, settings=settings, paths=paths, industries=None)\n        return 0\n\n    raise ValueError(f\"unsupported cmd: {args.cmd}\")\n"}],"isError":false,"timestamp":1776211550787}}
