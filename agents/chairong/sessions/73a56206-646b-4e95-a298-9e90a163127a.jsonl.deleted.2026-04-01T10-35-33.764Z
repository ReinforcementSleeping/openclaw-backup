{"type":"message","id":"4b5baa91","parentId":"a1156e00","timestamp":"2026-03-31T10:33:39.951Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"\nLet me try to debug the email issue by running a simpler test script.","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n"},{"type":"toolCall","id":"call_7c5151d9e2b341ed8dc2de59","name":"write","arguments":{"content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n测试邮件发送 (Test Email Sending)\n\"\"\"\n\nimport smtplib\nfrom email.mime.text import MIMEText\nfrom email.mime.multipart import MIMEMultipart\nimport time\n\ndef test_email():\n    \"\"\"测试邮件发送\"\"\"\n    \n    print(\"🧪 开始测试邮件发送...\")\n    \n    # 邮件配置\n    smtp_server = \"smtp.gmail.com\"\n    smtp_port = 587\n    sender_email = \"yuanlynch@gmail.com\"\n    sender_password = \"jsnjyjwpavymplev\"\n    recipient_email = \"l1cheeyuan@163.com\"\n    \n    try:\n        # 创建简单邮件\n        msg = MIMEMultipart()\n        msg['From'] = sender_email\n        msg['To'] = recipient_email\n        msg['Subject'] = \"📈 测试邮件 - 盘后复盘系统\"\n        \n        # 简单正文\n        body = \"\"\"\n# 测试邮件\n\n这是一封测试邮件，用于验证盘后复盘系统的邮件发送功能。\n\n## 系统状态\n- ✅ 邮件配置正常\n- ✅ 邮件发送功能正常\n- ✅ 盘后复盘报告已生成\n\n## 下一步\n- 主报告将发送至：l1cheeyuan@163.com\n- 报告内容：完整的盘后复盘分析\n\n---\n*测试时间：2026-03-31 18:30*\n*系统：柴荣量化复盘系统*\n\"\"\"\n        \n        msg.attach(MIMEText(body, 'markdown', 'utf-8'))\n        \n        print(f\"📧 连接邮件服务器: {smtp_server}:{smtp_port}\")\n        \n        # 连接服务器\n        server = smtplib.SMTP(smtp_server, smtp_port)\n        server.starttls()\n        print(\"✅ TLS连接建立成功\")\n        \n        print(\"🔑 登录邮件服务器...\")\n        server.login(sender_email, sender_password)\n        print(\"✅ 登录成功\")\n        \n        print(f\"📤 发送邮件至: {recipient_email}\")\n        text = msg.as_string()\n        server.sendmail(sender_email, recipient_email, text)\n        print(\"✅ 邮件发送成功\")\n        \n        server.quit()\n        print(\"✅ 邮件连接已关闭\")\n        \n        return True\n        \n    except Exception as e:\n        print(f\"❌ 邮件发送失败: {e}\")\n        print(f\"🔍 错误类型: {type(e).__name__}\")\n        return False\n\nif __name__ == \"__main__\":\n    print(\"=\" * 50)\n    success = test_email()\n    print(\"=\" * 50)\n    \n    if success:\n        print(\"🎉 测试成功! 邮件系统工作正常\")\n    else:\n        print(\"❌ 测试失败! 请检查邮件配置\")","path":"/Users/lynch/.openclaw/workspace-chairong/scripts/test_email.py"}}],"api":"openai-completions","provider":"custom-customb2","model":"glm-5-turbo","usage":{"input":16,"output":665,"cacheRead":58946,"cacheWrite":0,"totalTokens":59627,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774953206770}}
