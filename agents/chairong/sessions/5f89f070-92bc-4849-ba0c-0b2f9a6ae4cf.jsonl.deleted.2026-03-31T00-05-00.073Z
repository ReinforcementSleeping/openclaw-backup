{"type":"message","id":"72f89330","parentId":"faa19bd5","timestamp":"2026-03-30T00:04:31.198Z","message":{"role":"toolResult","toolCallId":"call_c8d6ab2ebf944e8f97c56897","toolName":"read","content":[{"type":"text","text":"                if catalyst_cnt >= 2:\n                    hotspot_score += 0.10\n\n                if top_hot_score >= 0.35:\n                    hotspot_reasons.append(\"top_hot_score\")\n                if concentration >= 0.08:\n                    hotspot_reasons.append(\"score_concentration\")\n                if top_rel_amt20 >= 0.20 or amt_z20 >= 1.0:\n                    hotspot_reasons.append(\"flow_surge\")\n                if top_industry_regime in {\"uptrend\", \"highvol\"}:\n                    hotspot_reasons.append(\"trend_or_highvol\")\n                if catalyst_cnt >= 2:\n                    hotspot_reasons.append(\"catalyst_count\")\n                if top_excess_ret5 >= 0.02:\n                    hotspot_reasons.append(\"excess_strength\")\n\n                hotspot_thr = float(getattr(settings, \"hotspot_threshold\", 0.55) or 0.55)\n                hotspot_min = int(getattr(settings, \"hotspot_min_reasons\", 2) or 2)\n                hotspot = bool(hotspot_score >= hotspot_thr and len(hotspot_reasons) >= hotspot_min)\n        except Exception:\n            pass\n    else:\n        if len(industry_score_map) >= 5:\n            scores = np.array(list(industry_score_map.values()), dtype=float)\n            if np.nanmax(scores) - np.nanmedian(scores) > 0.10 and int(news_counts.get(\"fiscal_industry\", 0)) >= 3:\n                hotspot = True\n                hotspot_reasons = [\"fallback_threshold\"]\n                hotspot_score = 0.60\n\n    hotspot_raw = bool(hotspot)\n    hist_hotspot, _ = _load_recent_hotspot_series(paths=paths, run_date=run_date, lookback_days=25)\n    hs_raw_series = hist_hotspot + [1 if hotspot_raw else 0]\n    hs_switch = int(getattr(settings, \"hotspot_switch_days\", 2) or 2)\n    hs_smooth_series = _smooth_bool(hs_raw_series, switch_days=hs_switch)\n    hotspot_smooth = bool(hs_smooth_series[-1]) if hs_smooth_series else hotspot_raw\n\n    market_regime = str(market_info.get(\"market_regime\") or \"unknown\")\n    regime = \"hotspot\" if hotspot_smooth else market_regime\n\n    cash_score_raw = float(cash_score)\n    cash_adj = 0.0\n    if market_regime == \"uptrend\":\n        cash_adj += float(getattr(settings, \"cash_adj_uptrend\", -0.03))\n    elif market_regime == \"downtrend\":\n        cash_adj += float(getattr(settings, \"cash_adj_downtrend\", 0.05))\n    elif market_regime == \"highvol\":\n        cash_adj += float(getattr(settings, \"cash_adj_highvol\", 0.05))\n    if hotspot_smooth:\n        cash_adj += float(getattr(settings, \"cash_adj_hotspot\", -0.02))\n    cash_score_adj = float(min(0.90, max(0.40, cash_score_raw + cash_adj)))\n\n    if hotspot_smooth:\n        w_p3, w_ind, w_p5 = 0.50, 0.35, 0.15\n    elif market_regime == \"uptrend\":\n        w_p3, w_ind, w_p5 = 0.50, 0.30, 0.20\n    elif market_regime in {\"downtrend\", \"highvol\"}:\n        w_p3, w_ind, w_p5 = 0.60, 0.30, 0.10\n    else:\n        w_p3, w_ind, w_p5 = 0.55, 0.35, 0.10\n    w_val = 0.05\n\n    pred[\"above_cash\"] = pred[\"p3\"] >= float(cash_score_adj)\n    pred[\"score\"] = w_p3 * pred[\"p3\"] + w_ind * pred[\"industry_score\"] + w_p5 * pred[\"p5\"] + 0.05 * pred[\"rs_mkt\"] + 0.03 * pred[\"rs_ind\"] + w_val * pred[\"value_score\"]\n    pred = pred.replace([np.inf, -np.inf], np.nan).dropna(subset=[\"score\"])\n\n    base_cols = [\n        \"code\",\n        \"name\",\n        \"industry\",\n        \"industry_score\",\n        \"pe_ttm\",\n        \"pb\",\n        \"total_mv\",\n        \"circ_mv\",\n        \"turnover_rate\",\n        \"dv_ttm\",\n        \"net_mf_amount\",\n        \"inst_net_3d\",\n        \"limit_status\",\n        \"fd_amount\",\n        \"up_stat\",\n        \"value_score\",\n        \"bench_ret5\",\n        \"bench_ret20\",\n        \"excess_mkt_ret5\",\n        \"excess_mkt_ret20\",\n        \"ind_mean_ret5\",\n        \"ind_mean_ret20\",\n        \"excess_ind_ret5\",\n        \"excess_ind_ret20\",\n        \"rs_mkt\",\n        \"rs_ind\",\n        \"p3\",\n        \"p5\",\n        \"plimit\",\n        \"above_cash\",\n        \"score\",\n        \"amt_z\",\n        \"rel_amt\",\n        \"up_amt_ratio20\",\n\n[52 more lines in file. Use offset=1000 to continue.]"}],"isError":false,"timestamp":1774829071194}}
