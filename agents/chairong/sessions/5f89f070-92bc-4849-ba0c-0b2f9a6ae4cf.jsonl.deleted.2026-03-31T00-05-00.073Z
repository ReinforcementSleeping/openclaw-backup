{"type":"message","id":"54112cf5","parentId":"a54bd944","timestamp":"2026-03-30T00:04:22.911Z","message":{"role":"toolResult","toolCallId":"call_4747f62dac2a4bf1b34a148e","toolName":"read","content":[{"type":"text","text":"from __future__ import annotations\n\nfrom datetime import date\n\nfrom ..config.settings import Settings\nfrom ..utils.paths import Paths\nfrom .preopen_news_signals import run as run_news\nfrom .preopen_rank_industries import run as run_industries\nfrom .preopen_rank_stocks import run as run_stocks\n\n\ndef run_preopen(run_date: date, settings: Settings, paths: Paths, skip_industry: bool = False) -> None:\n    news = run_news(run_date=run_date, settings=settings, paths=paths)\n    if skip_industry:\n        ind_sel = None\n        ind_score_map: dict[str, float] = {}\n        selected_industries: list[str] = []\n        industry_source = \"none\"\n    else:\n        ind_sel = run_industries(run_date=run_date, settings=settings, paths=paths, news_counts=news.counts)\n        ind_score_map = {str(r.industry): float(r.score) for r in ind_sel.table.itertuples(index=False)}\n        selected_industries = ind_sel.industries\n        industry_source = ind_sel.source\n    run_stocks(\n        run_date=run_date,\n        settings=settings,\n        paths=paths,\n        selected_industries=selected_industries,\n        industry_score_map=ind_score_map,\n        industry_source=industry_source,\n        cash_score=news.cash_score,\n        news_counts=news.counts,\n    )\n"}],"isError":false,"timestamp":1774829062908}}
