{"type":"message","id":"6b5be80d","parentId":"fa23c0a3","timestamp":"2026-04-14T00:03:50.380Z","message":{"role":"toolResult","toolCallId":"call_f16edec1e4004845b7928c16","toolName":"exec","content":[{"type":"text","text":"{\n  \"top_k_industries\": {\n    \"value\": 8,\n    \"desc\": \"盘前选出的强势行业数量（Top K）。越小越集中，越大越分散。建议 3~10。\"\n  },\n  \"top_n\": {\n    \"value\": 8,\n    \"desc\": \"最终输出榜单的股票数量（Top N）。如果你希望每个行业只选一只，一般设置为等于 top_k_industries。\"\n  },\n  \"exclude_st\": {\n    \"value\": true,\n    \"desc\": \"是否过滤 ST 股票。\"\n  },\n  \"min_turnover_cny\": {\n    \"value\": 30000000.0,\n    \"desc\": \"成交额过滤阈值（元）。低于该成交额的股票不纳入候选。\"\n  },\n  \"lookback_days\": {\n    \"value\": 60,\n    \"desc\": \"特征计算用的回看窗口（交易日）。影响趋势/波动等特征。\"\n  },\n  \"train_years\": {\n    \"value\": 3,\n    \"desc\": \"训练样本回看年数（用于概率模型训练）。\"\n  },\n  \"target_return_3\": {\n    \"value\": 0.03,\n    \"desc\": \"3日目标收益阈值（用于训练标签）。例如 0.03 表示 3日涨幅>=3% 视为命中。\"\n  },\n  \"target_return_5\": {\n    \"value\": 0.05,\n    \"desc\": \"5日目标收益阈值（用于训练标签）。例如 0.05 表示 5日涨幅>=5% 视为命中。\"\n  },\n  \"cash_score_base\": {\n    \"value\": 0.55,\n    \"desc\": \"现金门槛基础值（0~1）。越高越保守。\"\n  },\n  \"cash_score_risk_add\": {\n    \"value\": 0.1,\n    \"desc\": \"新闻风险贡献对现金门槛的上调系数（风险越大，越偏向空仓）。\"\n  },\n  \"cash_score_ease_sub\": {\n    \"value\": 0.08,\n    \"desc\": \"新闻利好贡献对现金门槛的下调系数（利好越多，越偏向开仓）。\"\n  },\n  \"cash_adj_uptrend\": {\n    \"value\": -0.03,\n    \"desc\": \"市场处于上升趋势时，对现金门槛的额外调整（负值=更激进）。\"\n  },\n  \"cash_adj_downtrend\": {\n    \"value\": 0.05,\n    \"desc\": \"市场处于下跌趋势时，对现金门槛的额外调整（正值=更保守）。\"\n  },\n  \"cash_adj_highvol\": {\n    \"value\": 0.05,\n    \"desc\": \"市场处于高波动时，对现金门槛的额外调整。\"\n  },\n  \"cash_adj_hotspot\": {\n    \"value\": -0.02,\n    \"desc\": \"热点状态机触发时，对现金门槛的额外调整（负值=更激进）。\"\n  },\n  \"market_regime_switch_days\": {\n    \"value\": 3,\n    \"desc\": \"市场 Regime 切换确认天数（越大越稳，越小越灵敏）。\"\n  },\n  \"industry_regime_switch_days\": {\n    \"value\": 3,\n    \"desc\": \"行业 Regime 切换确认天数（越大越稳，越小越灵敏）。\"\n  },\n  \"hotspot_switch_days\": {\n    \"value\": 2,\n    \"desc\": \"热点状态机切换确认天数。\"\n  },\n  \"hotspot_threshold\": {\n    \"value\": 0.5,\n    \"desc\": \"热点判定阈值（hotspot_score>=threshold 才算热点）。\"\n  },\n  \"hotspot_min_reasons\": {\n    \"value\": 2,\n    \"desc\": \"热点判定至少需要满足的理由数量（如 flow_surge / catalyst_count 等）。\"\n  },\n  \"llm_timeout_sec\": {\n    \"value\": 45.0,\n    \"desc\": \"LLM 单次请求超时（秒）。弱网可调大。\"\n  },\n  \"llm_retries\": {\n    \"value\": 3,\n    \"desc\": \"LLM 应用层重试次数（指数退避）。弱网可提高，注意会增加耗时。\"\n  },\n  \"llm_batch_size\": {\n    \"value\": 20,\n    \"desc\": \"LLM 批处理大小（每次请求包含多少条新闻）。过大易超时，过小易成本上升。\"\n  },\n  \"llm_max_workers\": {\n    \"value\": 5,\n    \"desc\": \"LLM 并发线程上限。过大易触发超时/限流。\"\n  },\n  \"mf_boost_max\": {\n    \"value\": 0.02,\n    \"desc\": \"主力资金净流入的最大加分（加到 p3/p5）。\"\n  },\n  \"mf_boost_scale_wan\": {\n    \"value\": 5000.0,\n    \"desc\": \"主力资金净流入加分的尺度参数（单位：万）。x/scale 越大，加分越接近 mf_boost_max。\"\n  },\n  \"limit_boost\": {\n    \"value\": 0.05,\n    \"desc\": \"昨日涨停状态的加分（加到 p3/p5；plimit 会额外放大）。\"\n  },\n  \"inst_boost_max\": {\n    \"value\": 0.08,\n    \"desc\": \"龙虎榜机构净买入（过去3天）的最大加分。\"\n  },\n  \"inst_boost_scale_wan\": {\n    \"value\": 5000.0,\n    \"desc\": \"机构净买入加分尺度参数（单位：万）。\"\n  },\n  \"inst_penalty_max\": {\n    \"value\": 0.1,\n    \"desc\": \"机构净卖出（过去3天）的最大惩罚幅度（负分）。\"\n  },\n  \"inst_penalty_scale_wan\": {\n    \"value\": 3000.0,\n    \"desc\": \"机构净卖出惩罚尺度参数（单位：万）。\"\n  },\n  \"inst_hard_filter_wan\": {\n    \"value\": -5000,\n    \"desc\": \"机构过去3天净卖出低于该阈值（单位：万）时，直接将 p3/p5/plimit 置 0（硬过滤）。\"\n  },\n  \"industry_news_boost_max\": {\n    \"value\": 0.03,\n    \"desc\": \"行业新闻加分的最大幅度（加到行业 score）。\"\n  },\n  \"industry_news_boost_scale\": {\n    \"value\": 6.0,\n    \"desc\": \"行业新闻加分的 tanh 尺度参数（越小越敏感）。\"\n  },\n  \"policy_cycle_boost_max\": {\n    \"value\": 0.02,\n    \"desc\": \"政策周期加分的最大幅度（加到行业 score）。\"\n  },\n  \"policy_cycle_boost_scale\": {\n    \"value\": 6.0,\n    \"desc\": \"政策周期加分的 tanh 尺度参数（越小越敏感）。\"\n  }\n}"}],"details":{