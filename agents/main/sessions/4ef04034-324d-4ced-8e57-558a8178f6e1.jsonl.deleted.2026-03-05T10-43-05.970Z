de>. Default to <code>annual</code>.\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"From date <code>YYYY-MM-DD</code>. Filter for endDate.\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"To date <code>YYYY-MM-DD</code>. Filter for endDate.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"freq\": \"annual\",\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 4.252,\n        \"success_rate\": 0\n      }\n    }\n  ],\n  \"search_id\": \"65d8dc4b-d3e2-4d0b-942b-1dcff0535a11\",\n  \"elapsed_time_ms\": 202.22\n}","cwd":"/Users/lynch/.openclaw/workspace"},"isError":false,"timestamp":1772535630669}}
