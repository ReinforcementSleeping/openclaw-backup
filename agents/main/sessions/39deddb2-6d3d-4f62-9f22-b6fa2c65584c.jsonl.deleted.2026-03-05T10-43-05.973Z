national\",\n            \"WirtschaftsWoche\",\n            \"Offshore Energy\",\n            \"Wired\",\n            \"Japan Times\",\n            \"E15\",\n            \"Upstream\",\n            \"S&P Global\",\n            \"The Moscow Times\",\n            \"American Banker\",\n            \"IntraFish\",\n            \"Energypost.eu\",\n            \"Engadget\",\n            \"AgFax\",\n            \"Der Spiegel\",\n            \"Carbon Capture Magazine\",\n            \"Transport Topics\",\n            \"Wall Street Journal\",\n            \"Fortune\"\n          ]\n        },\n        {\n          \"name\": \"lang\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The news story language\"\n          },\n          \"enum\": [\n            \"all\",\n            \"hi\",\n            \"de\",\n            \"ps\",\n            \"en-us\",\n            \"pt\",\n            \"zh-cn\",\n            \"yo\",\n            \"uk\",\n            \"cpe\",\n            \"id\",\n            \"ur\",\n            \"ig\",\n            \"aa\",\n            \"uz\",\n            \"mr\",\n            \"en\",\n            \"am\",\n            \"my\",\n            \"es\",\n            \"ar\",\n            \"vi\",\n            \"ne\",\n            \"ja\",\n            \"az\",\n            \"fa\",\n            \"fa-af\",\n            \"ro\",\n            \"en-gb\",\n            \"en-ca\",\n            \"ru\",\n            \"rw\",\n            \"fr\",\n            \"bn\",\n            \"br\",\n            \"si\",\n            \"es-ec\",\n            \"so\",\n            \"gd\",\n            \"om\",\n            \"sr\",\n            \"ko\",\n            \"sw\",\n            \"zh-tw\",\n            \"pt-br\",\n            \"ta\",\n            \"gu\",\n            \"ky\",\n            \"cs\",\n            \"te\",\n            \"pa\",\n            \"th\",\n            \"ti\",\n            \"cy\",\n            \"ha\",\n            \"pl\",\n            \"tr\"\n          ]\n        },\n        {\n          \"name\": \"sourceFeed\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Filter results by the original sourceFeed\"\n          }\n        },\n        {\n          \"name\": \"exactCategoryMatch\",\n          \"type\": \"boolean\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"If set to true, the api will return stories with only the requested category\"\n          }\n        },\n        {\n          \"name\": \"format\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Response format\"\n          },\n          \"enum\": [\n            \"json\",\n            \"xml\",\n            \"csv\"\n          ]\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"format\": \"json\",\n          \"displayType\": \"headline\"\n        }\n      },\n      \"provider_description\": \"Barchart OnDemand's market data APIs let you power your apps, websites and software with financial market data and information directly from exchanges around the world. Maintained through Amazon Web Services, Barchart OnDemand APIs are flexible and can be delivered in multiple formats including XML, JSON and CSV, and can be streamed over websockets.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 0,\n        \"success_rate\": 0\n      }\n    },\n    {\n      \"tool_id\": \"yahoo_finance.finance_news.v1\",\n      \"name\": \"Yahoo Finance News\",\n      \"description\": \"Get financial news and articles for stocks and companies\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Stock symbol to get news for (optional, uses general finance news if not provided)\"\n        },\n        {\n          \"name\": \"max_results\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": \"Maximum number of news articles to return (default: 10)\"\n        },\n        {\n          \"name\": \"news_type\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Type of news to retrieve\",\n          \"enum\": [\n            \"all\",\n            \"headlines\",\n            \"detailed\"\n          ]\n        },\n        {\n          \"name\": \"time_range\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Time range for news articles\",\n          \"enum\": [\n            \"1d\",\n            \"7d\",\n            \"30d\",\n            \"90d\",\n            \"1y\",\n            \"all\"\n          ]\n        }\n      ],\n      \"provider_description\": \"Yahoo Finance data provider using yfinance SDK for stock market data, news, and financial information\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 0,\n        \"success_rate\": 1\n      }\n    }\n  ],\n  \"search_id\": \"a33abb66-0733-4f33-affe-3aab46edfad5\",\n  \"elapsed_time_ms\": 185.31\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":5052,"aggregated":"{\n  \"query\": \"breaking news finance hot\",\n  \"total\": 10,\n  \"results\": [\n    {\n      \"tool_id\": \"qveris_finance.finance_news_aggregation_v1\",\n      \"name\": \"Finance News Aggregation\",\n      \"description\": \"Search and aggregate financial news from multiple sources\",\n      \"params\": [\n        {\n          \"name\": \"query\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Search query for financial news\"\n          }\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Maximum number of results to return\"\n          }\n        }\n      ],\n      \"provider_description\": \"Provider for finance-related skills\",\n      \"skill_type\": \"aggregation\"\n    },\n    {\n      \"tool_id\": \"eodhd.news.retrieve.v1.fe8bf94c\",\n      \"name\": \"Retrieve Financial News\",\n      \"description\": \"Returns the latest financial news headlines and full articles for a given ticker symbol or topic tag. Requires either a ticker (s) or a tag (t). Supports filtering by date, pagination, and JSON response format.\",\n      \"params\": [\n        {\n          \"name\": \"s\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The ticker code to retrieve news for, for example: AAPL.US\"\n          }\n        },\n        {\n          \"name\": \"t\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The topic tag to retrieve news for, for example: technology\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start date for filtering news (YYYY-MM-DD)\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End date for filtering news (YYYY-MM-DD)\"\n          }\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Number of results to return (default: 50, minimum: 1, maximum: 1000)\"\n          }\n        },\n        {\n          \"name\": \"offset\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Offset for pagination (default: 0)\"\n          }\n        },\n        {\n          \"name\": \"fmt\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Response format, either json or xml (default: json)\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {}\n      },\n      \"provider_description\": \"Access historical end-of-day stock prices, intraday data, US stock options, and real-time prices with free and advanced plans. EODHD provides financial data for 150,000+ tickers, including stocks, ETFs, funds, and currencies worldwide.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1.183,\n        \"success_rate\": 0.741\n      }\n    },\n    {\n      \"tool_id\": \"alphavantage.news_sentiment.retrieve.v1.7aca3c4a\",\n      \"name\": \"Retrieve Market News & Sentiment\",\n      \"description\": \"Returns live and historical market news & sentiment data from premier news outlets around the world, covering stocks, cryptocurrencies, forex, and various financial topics.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The function name.\"\n          },\n          \"enum\": [\n            \"NEWS_SENTIMENT\"\n          ]\n        },\n        {\n          \"name\": \"tickers\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of stock/crypto/forex symbols (e.g., COIN,CRYPTO:BTC,FOREX:USD). Filters articles that mention all listed tickers.\"\n          }\n        },\n        {\n          \"name\": \"topics\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of topics. Articles must cover all listed topics.\"\n          },\n          \"enum\": [\n            \"blockchain\",\n            \"earnings\",\n            \"ipo\",\n            \"mergers_and_acquisitions\",\n            \"financial_markets\",\n            \"economy_fiscal\",\n            \"economy_monetary\",\n            \"economy_macro\",\n            \"energy_transportation\",\n            \"finance\",\n            \"life_sciences\",\n            \"manufacturing\",\n            \"real_estate\",\n            \"retail_wholesale\",\n            \"technology\"\n          ]\n        },\n        {\n          \"name\": \"time_from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start time in YYYYMMDDTHHMM format (e.g., 20220410T0130).\"\n          }\n        },\n        {\n          \"name\": \"time_to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End time in YYYYMMDDTHHMM format.\"\n          }\n        },\n        {\n          \"name\": \"sort\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Sorting method.\"\n          },\n          \"enum\": [\n            \"LATEST\",\n            \"EARLIEST\",\n            \"RELEVANCE\"\n          ]\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Maximum number of results (up to 1000).\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"function\": \"NEWS_SENTIMENT\"\n        }\n      },\n      \"provider_description\": \"Alpha Vantage provides realtime and historical financial market data through a set of powerful and developer-friendly data APIs and spreadsheets. From traditional asset classes (e.g., stocks, ETFs, mutual funds) to economic indicators, from foreign exchange rates to commodities, from fundamental data to technical indicators, Alpha Vantage is your one-stop-shop for enterprise-grade global market data delivered through cloud-based APIs, MCP servers, spreadsheets, and more.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 660.49,\n        \"success_rate\": 0.973\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.news.retrieve.v1.2e72ea5d\",\n      \"name\": \"Market News\",\n      \"description\": \"Get latest market news.\",\n      \"params\": [\n        {\n          \"name\": \"category\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"This parameter can be 1 of the following values <code>general, forex, crypto, merger</code>.\"\n          }\n        },\n        {\n          \"name\": \"minId\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Use this field to get only news after this ID. Default to 0\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"category\": \"general\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\"\n    },\n    {\n      \"tool_id\": \"finnhub.news.retrieve.v1.51b2567e\",\n      \"name\": \"Market News\",\n      \"description\": \"Get latest market news.\",\n      \"params\": [\n        {\n          \"name\": \"category\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"This parameter can be 1 of the following values <code>general, forex, crypto, merger</code>.\"\n          }\n        },\n        {\n          \"name\": \"minId\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Use this field to get only news after this ID. Default to 0\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"category\": \"general\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 2.911,\n        \"success_rate\": 1\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.news.retrieve.v1\",\n      \"name\": \"Market News\",\n      \"description\": \"Get latest market news.\",\n      \"params\": [\n        {\n          \"name\": \"category\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"This parameter can be 1 of the following values <code>general, forex, crypto, merger</code>.\"\n          }\n        },\n        {\n          \"name\": \"minId\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Use this field to get only news after this ID. Default to 0\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"category\": \"general\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 807.31,\n        \"success_rate\": 0.997\n      }\n    },\n    {\n      \"tool_id\": \"alphavantage.news_sentiment.query.v1.7aca3c4a\",\n      \"name\": \"Market News & Sentiment\",\n      \"description\": \"Returns live and historical market news & sentiment data from global news outlets covering stocks, crypto, forex, and economic topics.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The function to call. In this case, NEWS_SENTIMENT\"\n          },\n          \"enum\": [\n            \"NEWS_SENTIMENT\"\n          ]\n        },\n        {\n          \"name\": \"tickers\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of stock/crypto/forex symbols to filter articles by (e.g., AAPL,CRYPTO:BTC).\"\n          }\n        },\n        {\n          \"name\": \"topics\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of topics to filter by.\"\n          },\n          \"enum\": [\n            \"blockchain\",\n            \"earnings\",\n            \"ipo\",\n            \"mergers_and_acquisitions\",\n            \"financial_markets\",\n            \"economy_fiscal\",\n            \"economy_monetary\",\n            \"economy_macro\",\n            \"energy_transportation\",\n            \"finance\",\n            \"life_sciences\",\n            \"manufacturing\",\n            \"real_estate\",\n            \"retail_wholesale\",\n            \"technology\"\n          ]\n        },\n        {\n          \"name\": \"time_from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start time in YYYYMMDDTHHMM format (e.g., 20220410T0130).\"\n          }\n        },\n        {\n          \"name\": \"time_to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End time in YYYYMMDDTHHMM format.\"\n          }\n        },\n        {\n          \"name\": \"sort\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Sorting method for results.\"\n          },\n          \"enum\": [\n            \"LATEST\",\n            \"EARLIEST\",\n            \"RELEVANCE\"\n          ]\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Maximum number of results (up to 1000).\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"function\": \"NEWS_SENTIMENT\"\n        }\n      },\n      \"provider_description\": \"Alpha Vantage provides realtime and historical financial market data through a set of powerful and developer-friendly data APIs and spreadsheets. From traditional asset classes (e.g., stocks, ETFs, mutual funds) to economic indicators, from foreign exchange rates to commodities, from fundamental data to technical indicators, Alpha Vantage is your one-stop-shop for enterprise-grade global market data delivered through cloud-based APIs, MCP servers, spreadsheets, and more.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 520.43,\n        \"success_rate\": 0.987\n      }\n    },\n    {\n      \"tool_id\": \"eodhd.financials.list.v2.e2500a07\",\n      \"name\": \"List Financials\",\n      \"description\": \"Retrieve a collection of financial posts.\",\n      \"params\": [\n        {\n          \"name\": \"context\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Scope under which the request is made; determines fields present in response.\"\n          },\n          \"enum\": [\n            \"view\",\n            \"embed\",\n            \"edit\"\n          ]\n        },\n        {\n          \"name\": \"page\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Current page of the collection.\"\n          }\n        },\n        {\n          \"name\": \"per_page\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Maximum number of items to be returned in result set.\"\n          }\n        },\n        {\n          \"name\": \"search\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Limit results to those matching a string.\"\n          }\n        },\n        {\n          \"name\": \"after\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Limit response to posts published after a given ISO8601 compliant date.\"\n          }\n        },\n        {\n          \"name\": \"modified_after\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Limit response to posts modified after a given ISO8601 compliant date.\"\n          }\n        },\n        {\n          \"name\": \"before\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Limit response to posts published before a given ISO8601 compliant date.\"\n          }\n        },\n        {\n          \"name\": \"modified_before\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Limit response to posts modified before a given ISO8601 compliant date.\"\n          }\n        },\n        {\n          \"name\": \"exclude\",\n          \"type\": \"array\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Ensure result set excludes specific IDs.\"\n          }\n        },\n        {\n          \"name\": \"include\",\n          \"type\": \"array\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Limit result set to specific IDs.\"\n          }\n        },\n        {\n          \"name\": \"search_semantics\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"How to interpret the search input.\"\n          },\n          \"enum\": [\n            \"exact\"\n          ]\n        },\n        {\n          \"name\": \"offset\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Offset the result set by a specific number of items.\"\n          }\n        },\n        {\n          \"name\": \"order\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Order sort attribute ascending or descending.\"\n          },\n          \"enum\": [\n            \"asc\",\n            \"desc\"\n          ]\n        },\n        {\n          \"name\": \"orderby\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Sort collection by post attribute.\"\n          },\n          \"enum\": [\n            \"author\",\n            \"date\",\n            \"id\",\n            \"include\",\n            \"modified\",\n            \"parent\",\n            \"relevance\",\n            \"slug\",\n            \"include_slugs\",\n            \"title\"\n          ]\n        },\n        {\n          \"name\": \"search_columns\",\n          \"type\": \"array\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Array of column names to be searched.\"\n          }\n        },\n        {\n          \"name\": \"slug\",\n          \"type\": \"array\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Limit result set to posts with one or more specific slugs.\"\n          }\n        },\n        {\n          \"name\": \"status\",\n          \"type\": \"array\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Limit result set to posts assigned one or more statuses.\"\n          }\n        }\n      ],\n      \"provider_description\": \"Access historical end-of-day stock prices, intraday data, US stock options, and real-time prices with free and advanced plans. EODHD provides financial data for 150,000+ tickers, including stocks, ETFs, funds, and currencies worldwide.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 0,\n        \"success_rate\": 0\n      }\n    },\n    {\n      \"tool_id\": \"barchart.ondemand.news.query.v1.655e0a3e\",\n      \"name\": \"Query News Articles\",\n      \"description\": \"The getNews API returns news headlines, articles and related photos based upon news sources, category, sub-category and/or keyword. With this API you can access breaking news, company press releases and global financial market coverage.\",\n      \"params\": [\n        {\n          \"name\": \"sources\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The news feed code\"\n          },\n          \"enum\": [\n            \"AP\",\n            \"APAI\",\n            \"BC\",\n            \"BCNEWS\",\n            \"CP\",\n            \"CNW\",\n            \"CRB\",\n            \"CMTX\",\n            \"CMTX:PCS\",\n            \"CMTX:PCC\",\n            \"CMTX:SEC\",\n            \"IF\",\n            \"USDA\",\n            \"PRNW\",\n            \"ZACKS\",\n            \"BRUG\",\n            \"AGWEB\",\n            \"SETZ\",\n            \"SPC\",\n            \"NASS\",\n            \"ESTMZ\",\n            \"DVND\",\n            \"LME-WHS\",\n            \"DLFRX\",\n            \"GLDRPT\",\n            \"COT\",\n            \"MAX\",\n            \"CMDTY_AGLITE\",\n            \"CMDTY_AG\",\n            \"CMDTY_ENERGY\",\n            \"SYNDTGAM\",\n            \"FCTGAM\",\n            \"BCSYND\",\n            \"HDLNE\",\n            \"HDLNEG\",\n            \"HDLNEP\"\n          ]\n        },\n        {\n          \"name\": \"symbols\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"A symbol or code that identifies a financial instrument\"\n          }\n        },\n        {\n          \"name\": \"category\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n