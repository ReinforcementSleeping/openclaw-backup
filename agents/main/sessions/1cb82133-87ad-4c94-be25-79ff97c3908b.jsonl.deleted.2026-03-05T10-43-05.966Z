          \"required\": true,\n          \"description\": {\n            \"en\": \"Technical indicator function name\"\n          },\n          \"enum\": [\n            \"macd\"\n          ]\n        },\n        {\n          \"name\": \"fast_period\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Fast period for MACD calculation\"\n          }\n        },\n        {\n          \"name\": \"slow_period\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Slow period for MACD calculation\"\n          }\n        },\n        {\n          \"name\": \"signal_period\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Signal period for MACD calculation\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"AAPL\",\n          \"function\": \"macd\"\n        }\n      },\n      \"provider_description\": \"Access historical end-of-day stock prices, intraday data, US stock options, and real-time prices with free and advanced plans. EODHD provides financial data for 150,000+ tickers, including stocks, ETFs, funds, and currencies worldwide.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 6.11,\n        \"success_rate\": 0\n      }\n    },\n    {\n      \"tool_id\": \"alphavantage.macd.retrieve.v1.467a92c0\",\n      \"name\": \"Moving Average Convergence Divergence (MACD)\",\n      \"description\": \"This API returns the moving average convergence / divergence (MACD) values.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The technical indicator of your choice. In this case, function=MACD\"\n          },\n          \"enum\": [\n            \"MACD\"\n          ]\n        },\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The name of the ticker of your choice. For example: symbol=IBM\"\n          }\n        },\n        {\n          \"name\": \"interval\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Time interval between two consecutive data points in the time series. The following values are supported: 1min, 5min, 15min, 30min, 60min, daily, weekly, monthly\"\n          },\n          \"enum\": [\n            \"1min\",\n            \"5min\",\n            \"15min\",\n            \"30min\",\n            \"60min\",\n            \"daily\",\n            \"weekly\",\n            \"monthly\"\n          ]\n        },\n        {\n          \"name\": \"series_type\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The desired price type in the time series. Four types are supported: close, open, high, low\"\n          },\n          \"enum\": [\n            \"close\",\n            \"open\",\n            \"high\",\n            \"low\"\n          ]\n        },\n        {\n          \"name\": \"fastperiod\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Positive integers are accepted. By default, fastperiod=12.\"\n          }\n        },\n        {\n          \"name\": \"slowperiod\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Positive integers are accepted. By default, slowperiod=26.\"\n          }\n        },\n        {\n          \"name\": \"signalperiod\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Positive integers are accepted. By default, signalperiod=9.\"\n          }\n        },\n        {\n          \"name\": \"month\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"By default, this parameter is not set and the technical indicator values will be calculated based on the default length of the underlying intraday, daily, weekly, or monthly time series data. You can use the month parameter (in YYYY-MM format) to return technical indicators for a specific month in history. For example, month=2009-01.\"\n          }\n        },\n        {\n          \"name\": \"datatype\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"By default, datatype=json. Strings json and csv are accepted with the following specifications: json returns the daily time series in JSON format; csv returns the time series as a CSV (comma separated value) file.\"\n          },\n          \"enum\": [\n            \"json\",\n            \"csv\"\n          ]\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"IBM\",\n          \"function\": \"MACD\",\n          \"interval\": \"daily\",\n          \"series_type\": \"close\"\n        }\n      },\n      \"provider_description\": \"Alpha Vantage provides realtime and historical financial market data through a set of powerful and developer-friendly data APIs and spreadsheets. From traditional asset classes (e.g., stocks, ETFs, mutual funds) to economic indicators, from foreign exchange rates to commodities, from fundamental data to technical indicators, Alpha Vantage is your one-stop-shop for enterprise-grade global market data delivered through cloud-based APIs, MCP servers, spreadsheets, and more.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 706.11,\n        \"success_rate\": 0.996\n      }\n    },\n    {\n      \"tool_id\": \"alphavantage.technical_indicators.kama.retrieve.v1.7aca3c4a\",\n      \"name\": \"Kaufman 