{"type":"message","id":"32a80aaf","parentId":"5e699ddc","timestamp":"2026-03-03T06:19:50.723Z","message":{"role":"toolResult","toolCallId":"call_function_7fzv6hcwzlyr_1","toolName":"exec","content":[{"type":"text","text":"{\n  \"query\": \"China A-share stock money flow capital inflow主力资金流向\",\n  \"total\": 5,\n  \"results\": [\n    {\n      \"tool_id\": \"ths_ifind.hk_connect_stats.v1\",\n      \"name\": \"iFinD 沪深港通交易统计 (HK Stock Connect Trading Stats)\",\n      \"description\": \"Query Shanghai-Shenzhen-Hong Kong Stock Connect trading statistics from 同花顺 (THS) iFinD database. Covers northbound (沪股通, 深股通) and southbound (港股通沪市, 港股通深市) channels. Returns trading volume, buy/sell amounts, net buy amount, transaction counts, and top-10 active stocks concentration ratios. Supports daily, weekly, monthly, and yearly aggregation. Useful for tracking cross-border capital flows between mainland China and Hong Kong markets.\",\n      \"params\": [\n        {\n          \"name\": \"sdate\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Start date. Supported formats: 'YYYY-MM-DD', 'YYYY/MM/DD', 'YYYYMMDD'.\"\n        },\n        {\n          \"name\": \"edate\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"End date. Supported formats: 'YYYY-MM-DD', 'YYYY/MM/DD', 'YYYYMMDD'.\"\n        },\n        {\n          \"name\": \"zq\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Aggregation period. Valid values: 'day', 'week', 'month', 'year'. Defaults to 'week'.\"\n        },\n        {\n          \"name\": \"lx\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Channel type filter. 'ALL'=all channels, '1'=沪股通, '2'=港股通(沪市), '3'=深股通, '4'=港股通(深市). Defaults to 'ALL'.\"\n        },\n        {\n          \"name\": \"bz\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Currency for amounts. Defaults to 'CNY'.\"\n        }\n      ],\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\"\n    },\n    {\n      \"tool_id\": \"nbsc_data.investment.foreign.direct.v2.741aab24\",\n      \"name\": \"Foreign Direct Investment Flows\",\n      \"description\": \"Query Foreign Direct Investment Flows statistical data from the National Bureau of Statistics of China. Data available for years 2015 to 2024.\",\n      \"params\": [\n        {\n          \"name\": \"m\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"API method name. Valid values: \\\"QueryData\\\" - queries statistical data from the database.\",\n            \"zh\": \"API方法名称。有效值：\\\"QueryData\\\" - 从数据库查询统计数据。\"\n          },\n          \"enum\": [\n            \"QueryData\"\n          ]\n        },\n        {\n          \"name\": \"dbcode\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Database code specifying the data type and granularity. Valid values: \\\"hgnd\\\" - national annual data, \\\"hgjd\\\" - national quarterly data, \\\"hgyd\\\" - national monthly data, \\\"fsnd\\\" - provincial annual data, \\\"fsjd\\\" - provincial quarterly data, \\\"fsyd\\\" - provincial monthly data.\",\n            \"zh\": \"数据库代码，指定数据类型和粒度。有效值：\\\"hgnd\\\" - 全国年度数据，\\\"hgjd\\\" - 全国季度数据，\\\"hgyd\\\" - 全国月度数据，\\\"fsnd\\\" - 分省年度数据，\\\"fsjd\\\" - 分省季度数据，\\\"fsyd\\\" - 分省月度数据。\"\n          },\n          \"enum\": [\n            \"hgnd\",\n            \"hgjd\",\n            \"hgyd\",\n            \"fsnd\",\n            \"fsjd\",\n            \"fsyd\"\n          ]\n        },\n        {\n          \"name\": \"rowcode\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Row dimension code specifying what appears in rows. Valid values: \\\"zb\\\" - indicators (statistical metrics), \\\"sj\\\" - time periods (years, quarters, months), \\\"reg\\\" - regions (provinces, cities).\",\n            \"zh\": \"行维度代码，指定行中显示的内容。有效值：\\\"zb\\\" - 指标（统计指标），\\\"sj\\\" - 时间（年、季度、月），\\\"reg\\\" - 地区（省、市）。\"\n          },\n          \"enum\": [\n            \"zb\",\n            \"sj\",\n            \"reg\"\n          ]\n        },\n        {\n          \"name\": \"colcode\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Column dimension code specifying what appears in columns. Valid values: \\\"zb\\\" - indicators (statistical metrics), \\\"sj\\\" - time periods (years, quarters, months), \\\"reg\\\" - regions (provinces, cities).\",\n            \"zh\": \"列维度代码，指定列中显示的内容。有效值：\\\"zb\\\" - 指标（统计指标），\\\"sj\\\" - 时间（年、季度、月），\\\"reg\\\" - 地区（省、市）。\"\n          },\n          \"enum\": [\n            \"zb\",\n            \"sj\",\n            \"reg\"\n          ]\n        },\n        {\n          \"name\": \"wds\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Fixed WHERE dimensions as a JSON array string. Used for additional filtering conditions. Typically use \\\"[]\\\" for empty (no additional filters).\",\n            \"zh\": \"固定WHERE维度，JSON数组字符串。用于附加筛选条件。通常使用\\\"[]\\\"表示空（无附加筛选）。\"\n          }\n        },\n        {\n          \"name\": \"dfwds\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Default WHERE dimensions as a JSON array string. Specifies the main filter criteria. For this indicator, use: [{\\\"wdcode\\\":\\\"zb\\\",\\\"valuecode\\\":\\\"A060F01\\\"}] to query by indicator code, or add [{\\\"wdcode\\\":\\\"sj\\\",\\\"valuecode\\\":\\\"YYYY\\\"}] to filter by specific year.\",\n            \"zh\": \"默认WHERE维度，JSON数组字符串。指定主要筛选条件。对于此指标，使用：[{\\\"wdcode\\\":\\\"zb\\\",\\\"valuecode\\\":\\\"A060F01\\\"}] 按指标代码查询，或添加 [{\\\"wdcode\\\":\\\"sj\\\",\\\"valuecode\\\":\\\"YYYY\\\"}] 按特定年份筛选。\"\n          }\n        },\n        {\n          \"name\": \"k1\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Timestamp in milliseconds. Used to prevent response caching. Optional - can be omitted or set to current timestamp in milliseconds.\",\n            \"zh\": \"时间戳（毫秒）。用于防止响应缓存。可选 - 可以省略或设置为当前时间戳（毫秒）。\"\n          }\n        },\n        {\n          \"name\": \"h\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Optional parameter, typically set to \\\"1\\\". Can be omitted.\",\n            \"zh\": \"可选参数，通常设置为\\\"1\\\"。可以省略。\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"m\": \"QueryData\",\n          \"k1\": \"1766219457369\",\n          \"wds\": \"[]\",\n          \"dfwds\": \"[{\\\"wdcode\\\": \\\"zb\\\", \\\"valuecode\\\": \\\"A060F01\\\"}]\",\n          \"dbcode\": \"hgnd\",\n          \"colcode\": \"sj\",\n          \"rowcode\": \"zb\"\n        }\n      },\n      \"provider_description\": \"Data from the National Bureau of Statistics of China (NBSC). This provider offers comprehensive access to official Chinese economic and social statistics data including GDP, population, employment, prices, trade, and more. All data is sourced directly from the official National Bureau of Statistics of China website. The API provides annual, quarterly, and monthly data covering various economic indicators. Data includes national statistics, provincial statistics, major cities data, and Hong Kong, Macao, Taiwan data. No authentication is required to access the public statistics data. This provider includes 107 tools covering different statistical indicators from multiple data sources.\"\n    },\n    {\n      \"tool_id\": \"ths_ifind.financial_statements.v1\",\n      \"name\": \"iFinD 同花顺财报 Financial Statements (Balance/Income/Cash Flow)\",\n      \"description\": \"Query balance sheet, income statement, or cash flow statement data for securities from THS iFinD Financial Statement database using a single entry point.\",\n      \"params\": [\n        {\n          \"name\": \"statement_type\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Which statement to query: 'balance', 'income', or 'cash_flow'\"\n        },\n        {\n          \"name\": \"codes\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Security codes, multiple codes separated by commas (max 50), e.g., '300033.SZ,600030.SH'\"\n        },\n        {\n          \"name\": \"year\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Year, e.g., '2024'\"\n        },\n        {\n          \"name\": \"period\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Reporting period: '0331' (Q1), '0630' (H1), '0930' (Q3), '1231' (Annual)\"\n        },\n        {\n          \"name\": \"type\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Report type: '1' (Consolidated), '2' (Parent Company), '3' (Consolidated Adjusted), '4' (Parent Company Adjusted)\"\n        }\n      ],\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\"\n    },\n    {\n      \"tool_id\": \"ths_ifind.cash_flow_statement.v1\",\n      \"name\": \"iFinD Cash Flow Statement - Financial Statement (财报_现金流量表)\",\n      \"description\": \"Query cash flow statement data for securities from THS iFinD Financial Statement database. Retrieve comprehensive cash flow indicators including operating activities, investing activities, and financing activities. Supports quarterly (Q1/0331), semi-annual (H1/0630), Q3 (0930), and annual (Y/1231) reports with multiple report types (consolidated, parent company, adjusted).\",\n      \"params\": [\n        {\n          \"name\": \"codes\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Security codes, multiple codes separated by commas (max 50), e.g., '300033.SZ,600030.SH'\"\n        },\n        {\n          \"name\": \"year\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Year, e.g., '2024'\"\n        },\n        {\n          \"name\": \"period\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Reporting period: '0331' (Q1), '0630' (H1), '0930' (Q3), '1231' (Annual)\"\n        },\n        {\n          \"name\": \"type\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Report type: '1' (Consolidated), '2' (Parent Company), '3' (Consolidated Adjusted), '4' (Parent Company Adjusted)\"\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"type\": \"1\",\n          \"year\": \"2024\",\n          \"codes\": \"300033.SZ,600030.SH\",\n          \"period\": \"0331\"\n        }\n      },\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 0,\n        \"success_rate\": 1\n      }\n    },\n    {\n      \"tool_id\": \"nbsc_data.import.amount.goods.v2.3a9d946e\",\n      \"name\": \"Import Amount Of Main Goods\",\n      \"description\": \"Query Import Amount Of Main Goods statistical data from the National Bureau of Statistics of China. Data available for years 2015 to 2024.\",\n      \"params\": [\n        {\n          \"name\": \"m\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"API method name. Valid values: \\\"QueryData\\\" - queries statistical data from the database.\",\n            \"zh\": \"API方法名称。有效值：\\\"QueryData\\\" - 从数据库查询统计数据。\"\n          },\n          \"enum\": [\n            \"QueryData\"\n          ]\n        },\n        {\n          \"name\": \"dbcode\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Database code specifying the data type and granularity. Valid values: \\\"hgnd\\\" - national annual data, \\\"hgjd\\\" - national quarterly data, \\\"hgyd\\\" - national monthly data, \\\"fsnd\\\" - provincial annual data, \\\"fsjd\\\" - provincial quarterly data, \\\"fsyd\\\" - provincial monthly data.\",\n            \"zh\": \"数据库代码，指定数据类型和粒度。有效值：\\\"hgnd\\\" - 全国年度数据，\\\"hgjd\\\" - 全国季度数据，\\\"hgyd\\\" - 全国月度数据，\\\"fsnd\\\" - 分省年度数据，\\\"fsjd\\\" - 分省季度数据，\\\"fsyd\\\" - 分省月度数据。\"\n          },\n          \"enum\": [\n            \"hgnd\",\n            \"hgjd\",\n            \"hgyd\",\n            \"fsnd\",\n            \"fsjd\",\n            \"fsyd\"\n          ]\n        },\n        {\n          \"name\": \"rowcode\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Row dimension code specifying what appears in rows. Valid values: \\\"zb\\\" - indicators (statistical metrics), \\\"sj\\\" - time periods (years, quarters, months), \\\"reg\\\" - regions (provinces, cities).\",\n            \"zh\": \"行维度代码，指定行中显示的内容。有效值：\\\"zb\\\" - 指标（统计指标），\\\"sj\\\" - 时间（年、季度、月），\\\"reg\\\" - 地区（省、市）。\"\n          },\n          \"enum\": [\n            \"zb\",\n            \"sj\",\n            \"reg\"\n          ]\n        },\n        {\n          \"name\": \"colcode\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Column dimension code specifying what appears in columns. Valid values: \\\"zb\\\" - indicators (statistical metrics), \\\"sj\\\" - time periods (years, quarters, months), \\\"reg\\\" - regions (provinces, cities).\",\n            \"zh\": \"列维度代码，指定列中显示的内容。有效值：\\\"zb\\\" - 指标（统计指标），\\\"sj\\\" - 时间（年、季度、月），\\\"reg\\\" - 地区（省、市）。\"\n          },\n          \"enum\": [\n            \"zb\",\n            \"sj\",\n            \"reg\"\n          ]\n        },\n        {\n          \"name\": \"wds\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Fixed WHERE dimensions as a JSON array string. Used for additional filtering conditions. Typically use \\\"[]\\\" for empty (no additional filters).\",\n            \"zh\": \"固定WHERE维度，JSON数组字符串。用于附加筛选条件。通常使用\\\"[]\\\"表示空（无附加筛选）。\"\n          }\n        },\n        {\n          \"name\": \"dfwds\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Default WHERE dimensions as a JSON array string. Specifies the main filter criteria. For this indicator, use: [{\\\"wdcode\\\":\\\"zb\\\",\\\"valuecode\\\":\\\"A060702\\\"}] to query by indicator code, or add [{\\\"wdcode\\\":\\\"sj\\\",\\\"valuecode\\\":\\\"YYYY\\\"}] to filter by specific year.\",\n            \"zh\": \"默认WHERE维度，JSON数组字符串。指定主要筛选条件。对于此指标，使用：[{\\\"wdcode\\\":\\\"zb\\\",\\\"valuecode\\\":\\\"A060702\\\"}] 按指标代码查询，或添加 [{\\\"wdcode\\\":\\\"sj\\\",\\\"valuecode\\\":\\\"YYYY\\\"}] 按特定年份筛选。\"\n          }\n        },\n        {\n          \"name\": \"k1\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Timestamp in milliseconds. Used to prevent response caching. Optional - can be omitted or set to current timestamp in milliseconds.\",\n            \"zh\": \"时间戳（毫秒）。用于防止响应缓存。可选 - 可以省略或设置为当前时间戳（毫秒）。\"\n          }\n        },\n        {\n          \"name\": \"h\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Optional parameter, typically set to \\\"1\\\". Can be omitted.\",\n            \"zh\": \"可选参数，通常设置为\\\"1\\\"。可以省略。\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"m\": \"QueryData\",\n          \"k1\": \"1766219369777\",\n          \"wds\": \"[]\",\n          \"dfwds\": \"[{\\\"wdcode\\\": \\\"zb\\\", \\\"valuecode\\\": \\\"A060702\\\"}]\",\n          \"dbcode\": \"hgnd\",\n          \"colcode\": \"sj\",\n          \"rowcode\": \"zb\"\n        }\n      },\n      \"provider_description\": \"Data from the National Bureau of Statistics of China (NBSC). This provider offers comprehensive access to official Chinese economic and social statistics data including GDP, population, employment, prices, trade, and more. All data is sourced directly from the official National Bureau of Statistics of China website. The API provides annual, quarterly, and monthly data covering various economic indicators. Data includes national statistics, provincial statistics, major cities data, and Hong Kong, Macao, Taiwan data. No authentication is required to access the public statistics data. This provider includes 107 tools covering different statistical indicators from multiple data sources.\"\n    }\n  ],\n  \"search_id\": \"2d09a030-5085-4d45-9072-112806f31b85\",\n  \"elapsed_time_ms\": 378.32\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":1589,"aggregated":"{\n  \"query\": \"China A-share stock money flow capital inflow主力资金流向\",\n  \"total\": 5,\n  \"results\": [\n    {\n      \"tool_id\": \"ths_ifind.hk_connect_stats.v1\",\n      \"name\": \"iFinD 沪深港通交易统计 (HK Stock Connect Trading Stats)\",\n      \"description\": \"Query Shanghai-Shenzhen-Hong Kong Stock Connect trading statistics from 同花顺 (THS) iFinD database. Covers northbound (沪股通, 深股通) and southbound (港股通沪市, 港股通深市) channels. Returns trading volume, buy/sell amounts, net buy amount, transaction counts, and top-10 active stocks concentration ratios. Supports daily, weekly, monthly, and yearly aggregation. Useful for tracking cross-border capital flows between mainland China and Hong Kong markets.\",\n      \"params\": [\n        {\n          \"name\": \"sdate\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Start date. Supported formats: 'YYYY-MM-DD', 'YYYY/MM/DD', 'YYYYMMDD'.\"\n        },\n        {\n          \"name\": \"edate\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"End date. Supported formats: 'YYYY-MM-DD', 'YYYY/MM/DD', 'YYYYMMDD'.\"\n        },\n        {\n          \"name\": \"zq\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Aggregation period. Valid values: 'day', 'week', 'month', 'year'. Defaults to 'week'.\"\n        },\n        {\n          \"name\": \"lx\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Channel type filter. 'ALL'=all channels, '1'=沪股通, '2'=港股通(沪市), '3'=深股通, '4'=港股通(深市). Defaults to 'ALL'.\"\n        },\n        {\n          \"name\": \"bz\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Currency for amounts. Defaults to 'CNY'.\"\n        }\n      ],\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\"\n    },\n    {\n      \"tool_id\": \"nbsc_data.investment.foreign.direct.v2.741aab24\",\n      \"name\": \"Foreign Direct Investment Flows\",\n      \"description\": \"Query Foreign Direct Investment Flows statistical data from the National Bureau of Statistics of China. Data available for years 2015 to 2024.\",\n      \"params\": [\n        {\n          \"name\": \"m\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"API method name. Valid values: \\\"QueryData\\\" - queries statistical data from the database.\",\n            \"zh\": \"API方法名称。有效值：\\\"QueryData\\\" - 从数据库查询统计数据。\"\n          },\n          \"enum\": [\n            \"QueryData\"\n          ]\n        },\n        {\n          \"name\": \"dbcode\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Database code specifying the data type and granularity. Valid values: \\\"hgnd\\\" - national annual data, \\\"hgjd\\\" - national quarterly data, \\\"hgyd\\\" - national monthly data, \\\"fsnd\\\" - provincial annual data, \\\"fsjd\\\" - provincial quarterly data, \\\"fsyd\\\" - provincial monthly data.\",\n            \"zh\": \"数据库代码，指定数据类型和粒度。有效值：\\\"hgnd\\\" - 全国年度数据，\\\"hgjd\\\" - 全国季度数据，\\\"hgyd\\\" - 全国月度数据，\\\"fsnd\\\" - 分省年度数据，\\\"fsjd\\\" - 分省季度数据，\\\"fsyd\\\" - 分省月度数据。\"\n          },\n          \"enum\": [\n            \"hgnd\",\n            \"hgjd\",\n            \"hgyd\",\n            \"fsnd\",\n            \"fsjd\",\n            \"fsyd\"\n          ]\n        },\n        {\n          \"name\": \"rowcode\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Row dimension code specifying what appears in rows. Valid values: \\\"zb\\\" - indicators (statistical metrics), \\\"sj\\\" - time periods (years, quarters, months), \\\"reg\\\" - regions (provinces, cities).\",\n            \"zh\": \"行维度代码，指定行中显示的内容。有效值：\\\"zb\\\" - 指标（统计指标），\\\"sj\\\" - 时间（年、季度、月），\\\"reg\\\" - 地区（省、市）。\"\n          },\n          \"enum\": [\n            \"zb\",\n            \"sj\",\n            \"reg\"\n          ]\n        },\n        {\n          \"name\": \"colcode\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Column dimension code specifying what appears in columns. Valid values: \\\"zb\\\" - indicators (statistical metrics), \\\"sj\\\" - time periods (years, quarters, months), \\\"reg\\\" - regions (provinces, cities).\",\n            \"zh\": \"列维度代码，指定列中显示的内容。有效值：\\\"zb\\\" - 指标（统计指标），\\\"sj\\\" - 时间（年、季度、月），\\\"reg\\\" - 地区（省、市）。\"\n          },\n          \"enum\": [\n            \"zb\",\n            \"sj\",\n            \"reg\"\n          ]\n        },\n        {\n          \"name\": \"wds\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Fixed WHERE dimensions as a JSON array string. Used for additional filtering conditions. Typically use \\\"[]\\\" for empty (no additional filters).\",\n            \"zh\": \"固定WHERE维度，JSON数组字符串。用于附加筛选条件。通常使用\\\"[]\\\"表示空（无附加筛选）。\"\n          }\n        },\n        {\n          \"name\": \"dfwds\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Default WHERE dimensions as a JSON array string. Specifies the main filter criteria. For this indicator, use: [{\\\"wdcode\\\":\\\"zb\\\",\\\"valuecode\\\":\\\"A060F01\\\"}] to query by indicator code, or add [{\\\"wdcode\\\":\\\"sj\\\",\\\"valuecode\\\":\\\"YYYY\\\"}] to filter by specific year.\",\n            \"zh\": \"默认WHERE维度，JSON数组字符串。指定主要筛选条件。对于此指标，使用：[{\\\"wdcode\\\":\\\"zb\\\",\\\"valuecode\\\":\\\"A060F01\\\"}] 按指标代码查询，或添加 [{\\\"wdcode\\\":\\\"sj\\\",\\\"valuecode\\\":\\\"YYYY\\\"}] 按特定年份筛选。\"\n          }\n        },\n        {\n          \"name\": \"k1\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Timestamp in milliseconds. Used to prevent response caching. Optional - can be omitted or set to current timestamp in milliseconds.\",\n            \"zh\": \"时间戳（毫秒）。用于防止响应缓存。可选 - 可以省略或设置为当前时间戳（毫秒）。\"\n          }\n        },\n        {\n          \"name\": \"h\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Optional parameter, typically set to \\\"1\\\". Can be omitted.\",\n            \"zh\": \"可选参数，通常设置为\\\"1\\\"。可以省略。\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"m\": \"QueryData\",\n          \"k1\": \"1766219457369\",\n          \"wds\": \"[]\",\n          \"dfwds\": \"[{\\\"wdcode\\\": \\\"zb\\\", \\\"valuecode\\\": \\\"A060F01\\\"}]\",\n          \"dbcode\": \"hgnd\",\n          \"colcode\": \"sj\",\n          \"rowcode\": \"zb\"\n        }\n      },\n      \"provider_description\": \"Data from the National Bureau of Statistics of China (NBSC). This provider offers comprehensive access to official Chinese economic and social statistics data including GDP, population, employment, prices, trade, and more. All data is sourced directly from the official National Bureau of Statistics of China website. The API provides annual, quarterly, and monthly data covering various economic indicators. Data includes national statistics, provincial statistics, major cities data, and Hong Kong, Macao, Taiwan data. No authentication is required to access the public statistics data. This provider includes 107 tools covering different statistical indicators from multiple data sources.\"\n    },\n    {\n      \"tool_id\": \"ths_ifind.financial_statements.v1\",\n      \"name\": \"iFinD 同花顺财报 Financial Statements (Balance/Income/Cash Flow)\",\n      \"description\": \"Query balance sheet, income statement, or cash flow statement data for securities from THS iFinD Financial Statement database using a single entry point.\",\n      \"params\": [\n        {\n          \"name\": \"statement_type\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Which statement to query: 'balance', 'income', or 'cash_flow'\"\n        },\n        {\n          \"name\": \"codes\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Security codes, multiple codes separated by commas (max 50), e.g., '300033.SZ,600030.SH'\"\n        },\n        {\n          \"name\": \"year\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Year, e.g., '2024'\"\n        },\n        {\n          \"name\": \"period\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Reporting period: '0331' (Q1), '0630' (H1), '0930' (Q3), '1231' (Annual)\"\n        },\n        {\n          \"name\": \"type\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Report type: '1' (Consolidated), '2' (Parent Company), '3' (Consolidated Adjusted), '4' (Parent Company Adjusted)\"\n        }\n      ],\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\"\n    },\n    {\n      \"tool_id\": \"ths_ifind.cash_flow_statement.v1\",\n      \"name\": \"iFinD Cash Flow Statement - Financial Statement (财报_现金流量表)\",\n      \"description\": \"Query cash flow statement data for securities from THS iFinD Financial Statement database. Retrieve comprehensive cash flow indicators including operating activities, investing activities, and financing activities. Supports quarterly (Q1/0331), semi-annual (H1/0630), Q3 (0930), and annual (Y/1231) reports with multiple report types (consolidated, parent company, adjusted).\",\n      \"params\": [\n        {\n          \"name\": \"codes\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Security codes, multiple codes separated by commas (max 50), e.g., '300033.SZ,600030.SH'\"\n        },\n        {\n          \"name\": \"year\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Year, e.g., '2024'\"\n        },\n        {\n          \"name\": \"period\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Reporting period: '0331' (Q1), '0630' (H1), '0930' (Q3), '1231' (Annual)\"\n        },\n        {\n          \"name\": \"type\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Report type: '1' (Consolidated), '2' (Parent Company), '3' (Consolidated Adjusted), '4' (Parent Company Adjusted)\"\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"type\": \"1\",\n          \"year\": \"2024\",\n          \"codes\": \"300033.SZ,600030.SH\",\n          \"period\": \"0331\"\n        }\n      },\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 0,\n        \"success_rate\": 1\n      }\n    },\n    {\n      \"tool_id\": \"nbsc_data.import.amount.goods.v2.3a9d946e\",\n      \"name\": \"Import Amount Of Main Goods\",\n      \"description\": \"Query Import Amount Of Main Goods statistical data from the National Bureau of Statistics of China. Data available for years 2015 to 2024.\",\n      \"params\": [\n        {\n          \"name\": \"m\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"API method name. Valid values: \\\"QueryData\\\" - queries statistical data from the database.\",\n            \"zh\": \"API方法名称。有效值：\\\"QueryData\\\" - 从数据库查询统计数据。\"\n          },\n          \"enum\": [\n            \"QueryData\"\n          ]\n        },\n        {\n          \"name\": \"dbcode\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Database code specifying the data type and granularity. Valid values: \\\"hgnd\\\" - national annual data, \\\"hgjd\\\" - national quarterly data, \\\"hgyd\\\" - national monthly data, \\\"fsnd\\\" - provincial annual data, \\\"fsjd\\\" - provincial quarterly data, \\\"fsyd\\\" - provincial monthly data.\",\n            \"zh\": \"数据库代码，指定数据类型和粒度。有效值：\\\"hgnd\\\" - 全国年度数据，\\\"hgjd\\\" - 全国季度数据，\\\"hgyd\\\" - 全国月度数据，\\\"fsnd\\\" - 分省年度数据，\\\"fsjd\\\" - 分省季度数据，\\\"fsyd\\\" - 分省月度数据。\"\n          },\n          \"enum\": [\n            \"hgnd\",\n            \"hgjd\",\n            \"hgyd\",\n            \"fsnd\",\n            \"fsjd\",\n            \"fsyd\"\n          ]\n        },\n        {\n          \"name\": \"rowcode\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Row dimension code specifying what appears in rows. 