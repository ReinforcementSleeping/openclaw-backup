lineVolInfo\",\n            \"TimelineTone\",\n            \"TimelineLang\",\n            \"TimelineSourceCountry\",\n            \"ToneChart\",\n            \"WordCloudImageTags\",\n            \"WordCloudImageWebTags\",\n            \"Timeline\",\n            \"WordCloudEnglish\",\n            \"artlist\",\n            \"timelinevol\",\n            \"timelinetone\",\n            \"timelinelang\",\n            \"timelinegeo\",\n            \"gexf\",\n            \"html\"\n          ]\n        },\n        {\n          \"name\": \"format\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Response format. Default is json for most modes.\"\n          },\n          \"enum\": [\n            \"html\",\n            \"json\",\n            \"jsonp\",\n            \"csv\",\n            \"rss\",\n            \"HTML\",\n            \"CSV\",\n            \"RSS\",\n            \"RSSArchive\",\n            \"JSON\",\n            \"JSONP\",\n            \"JSONFeed\"\n          ]\n        },\n        {\n          \"name\": \"callback\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Callback function name for JSONP output\"\n          }\n        },\n        {\n          \"name\": \"timespan\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Time range to search backwards from now (e.g., '1d', '2w', '3m'). Minimum 15 minutes.\"\n          }\n        },\n        {\n          \"name\": \"startdatetime\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start date/time in YYYYMMDDHHMMSS format.\"\n          }\n        },\n        {\n          \"name\": \"enddatetime\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End date/time in YYYYMMDDHH