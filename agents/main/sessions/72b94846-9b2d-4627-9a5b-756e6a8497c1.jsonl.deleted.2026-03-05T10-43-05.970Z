go-1200x675.jpg\\\", \\\"source\\\": \\\"MarketBeat\\\", \\\"category_within_source\\\": \\\"General\\\", \\\"source_domain\\\": \\\"MarketBeat\\\", \\\"topics\\\": [{\\\"topic\\\": \\\"earnings\\\", \\\"relevance_score\\\": \\\"0.929844\\\"}, {\\\"topic\\\": \\\"financial_markets\\\", \\\"relevance_score\\\": \\\"0.846206\\\"}, {\\\"topic\\\": \\\"finance\\\", \\\"relevance_score\\\": \\\"0.743424\\\"}, {\\\"topic\\\": \\\"economy_macro\\\", \\\"relevance_score\\\": \\\"0.621494\\\"}, {\\\"topic\\\": \\\"technology\\\", \\\"relevance_score\\\": \\\"0.634570\\\"}], \\\"overall_sentiment_score\\\": -0.089142, \\\"overall_sentiment_label\\\": \\\"Neutral\\\", \\\"ticker_sentiment\\\": [{\\\"ticker\\\": \\\"LDOS\\\", \\\"relevance_score\\\": \\\"1.000000\\\", \\\"ticker_sentiment_score\\\": \\\"-0.079468\\\", \\\"ticker_sentiment_label\\\": \\\"Neutral\\\"}]}, {\\\"title\\\": \\\"Vornado Realty Trust $VNO Shares Sold by Fox Run Management L.L.C.\\\", \\\"url\\\": \\\"https://www.marketbeat.com/instant-alerts/filing-vornado-realty-trust-vno-shares-sold-by-fox-run-management-llc-2026-03-03/\\\", \\\"time_published\\\": \\\"20260303T104747\\\", \\\"authors\\\": [\\\"MarketBeat\\\"], \\\"summary\\\": \\\"Fox Run Management L.L.C. significantly reduced its stake in Vornado Realty Trust (NYSE:VNO) by 85.1% in the third quarter, selling 39,900 shares and retaining 7,012 shares. Despite missing EPS estimates, Vornado reported higher-than-expected revenue. The stock trades near $27.40, has a P/E of 6.54, a market cap of $5.22 billion, and recently paid an annual dividend of $0.74 per share.\\\", \\\"banner_image\\\": \\\"https://www.marketbeat.com/logos/vornado-realty-trust-logo-1200x675.jpg?v=20240424115714\\\", \\\"source\\\": \\\"MarketBeat\\\", \\\"category_within_source\\\": \\\"General\\\", \\\"source_domain\\\": \\\"MarketBeat\\\", \\\"topics\\\": [{\\\"topic\\\": \\\"earnings\\\", \\\"relevance_score\\\": \\\"0.924768\\\"}, {\\\"topic\\\": \\\"real_estate\\\", \\\"relev