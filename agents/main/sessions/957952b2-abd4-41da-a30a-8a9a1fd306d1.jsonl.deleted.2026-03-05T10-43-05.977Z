    \"description\": \"Function mode: '1' (query date range), '2' (query date count), default is '1'\"\n        },\n        {\n          \"name\": \"date_type\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Date type: '0' (trading days), '1' (calendar days), default is '0'\"\n        },\n        {\n          \"name\": \"period\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Time period: 'D' (daily), 'W' (weekly), 'M' (monthly), 'Q' (quarterly), 'S' (semi-annual), 'Y' (yearly), default is 'D'\"\n        },\n        {\n          \"name\": \"date_format\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Date format: '0' (YYYY-MM-DD), '1' (YYYY/MM/DD), '2' (YYYYMMDD), default is '0'\"\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"enddate\": \"2023-12-31\",\n          \"startdate\": \"2023-01-01\",\n          \"marketcode\": \"212001\"\n        }\n      },\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 625.98,\n        \"success_rate\": 0.753\n      }\n    },\n    {\n      \"tool_id\": \"ths_ifind.etf_constituents.v1\",\n      \"name\": \"iFinD ETF成分股票列表 (ETF Constituent Stock List)\",\n      \"description\": \"Query the constituent stock list of an ETF from 同花顺 (THS) iFinD database. Returns detailed information about each constituent stock including stock code, name, share quantity, cash substitution flag, subscription/redemption premium ratios and fixed substitution amounts. Useful for analyzing ETF composition and tracking ETF holdings.\",\n      \"params\": [\n        {\n          \"name\": \"thscode\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"ETF security code, e.g., '510300.SH', '159001.SZ'\"\n        },\n        {\n          \"name\": \"date\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Query date. Supported formats: 'YYYY-MM-DD', 'YYYY/MM/DD', 'YYYYMMDD'. Defaults to today.\"\n        }\n      ],\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 644.44,\n        \"success_rate\": 0.91\n      }\n    },\n    {\n      \"tool_id\": \"ths_ifind.code_converter.v1\",\n      \"name\": \"iFinD 同花顺证券代码转换 (THS Security Code Converter)\",\n      \"description\": \"Convert security codes or security names to 同花顺 (THS) standard code format. Supports querying by security code or security name, can specify security type and market, supports exact match or fuzzy match. Returns converted THS codes and related security information.\",\n      \"params\": [\n        {\n          \"name\": \"seccode\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Security code, e.g., '000001'. Either seccode or secname\"\n        },\n        {\n          \"name\": \"secname\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Security name, e.g., '平安银行'. Either seccode or secname\"\n        },\n        {\n          \"name\": \"mode\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Query mode: 'seccode' (query by code) or 'secname' (query by name)\"\n        },\n        {\n          \"name\": \"sectype\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Security type, e.g., '001' (stock), default is empty (query all types)\"\n        },\n        {\n          \"name\": \"market\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Market code, e.g., '212001' (SSE), '212100' (SZSE), default is empty (query all markets)\"\n        },\n        {\n          \"name\": \"tradestatus\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Trading status: '0' (normal trading), '1' (suspended), '2' (all), default is '0'\"\n        },\n        {\n          \"name\": \"isexact\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Exact match: '1' (exact match), '0' (fuzzy match), default is '1'\"\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"mode\": \"seccode\",\n          \"seccode\": \"000001\"\n        }\n      },\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 582.28,\n        \"success_rate\": 0.98\n      }\n    }\n  ],\n  \"search_id\": \"ca0c0205-7e34-4e9c-8361-8bf7773a0e35\",\n  \"elapsed_time_ms\": 1358.96\n}\n","name":"cd /Users/lynch/.openclaw/workspace"},"isError":false,"timestamp":1772587942693}}
