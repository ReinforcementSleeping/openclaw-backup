,\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 2750.14,\n        \"success_rate\": 0.9\n      }\n    },\n    {\n      \"tool_id\": \"ths_ifind.hk_connect_stats.v1\",\n      \"name\": \"iFinD 沪深港通交易统计 (HK Stock Connect Trading Stats)\",\n      \"description\": \"Query Shanghai-Shenzhen-Hong Kong Stock Connect trading statistics from 同花顺 (THS) iFinD database. Covers northbound (沪股通, 深股通) and southbound (港股通沪市, 港股通深市) channels. Returns trading volume, buy/sell amounts, net buy amount, transaction counts, and top-10 active stocks concentration ratios. Supports daily, weekly, monthly, and yearly aggregation. Useful for tracking cross-border capital flows between mainland China and Hong Kong markets.\",\n      \"params\": [\n        {\n          \"name\": \"sdate\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Start date. Supported formats: 'YYYY-MM-DD', 'YYYY/MM/DD', 'YYYYMMDD'.\"\n        },\n        {\n          \"name\": \"edate\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"End date. Supported formats: 'YYYY-MM-DD', 'YYYY/MM/DD', 'YYYYMMDD'.\"\n        },\n        {\n          \"name\": \"zq\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Aggregation period. Valid values: 'day', 'week', 'month', 'year'. Defaults to 'week'.\"\n        },\n        {\n          \"name\": \"lx\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Channel type filter. 'ALL'=all channels, '1'=沪股通, '2'=港股通(沪市), '3'=深股通, '4'=港股通(深市). Defaults to 'ALL'.\"\n        },\n        {\n          \"name\": \"bz\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Currency for amounts. Defaults to 'CNY'.\"\n        }\n      ],\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 715.71,\n        \"success_rate\": 0.532\n      }\n    },\n    {\n      \"tool_id\": \"ths_ifind.etf_constituents.v1\",\n      \"name\": \"iFinD ETF成分股票列表 (ETF Constituent Stock List)\",\n      \"description\": \"Query the constituent stock list of an ETF from 同花顺 (THS) iFinD database. Returns detailed information about each constituent stock including stock code, name, share quantity, cash substitution flag, subscription/redemption premium ratios and fixed substitution amounts. Useful for analyzing ETF composition and tracking ETF holdings.\",\n      \"params\": [\n        {\n          \"name\": \"thscode\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"ETF security code, e.g., '510300.SH', '159001.SZ'\"\n        },\n        {\n          \"name\": \"date\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Query date. Supported formats: 'YYYY-MM-DD', 'YYYY/MM/DD', 'YYYYMMDD'. Defaults to today.\"\n        }\n      ],\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 644.44,\n        \"success_rate\": 0.91\n      }\n    },\n    {\n      \"tool_id\": \"eodhd.live_prices.retrieve.v1.178541d4\",\n      \"name\": \"Live (Delayed) Stock Prices\",\n      \"description\": \"Retrieve live or delayed stock prices and macroeconomic data.\",\n      \"params\": [\n        {\n          \"name\": \"ticker\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Ticker symbol with exchange suffix (e.g., AAPL.US).\"\n          }\n        },\n        {\n          \"name\": \"s\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Optional filter parameter.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"ticker\": \"AAPL.US\"\n        }\n      },\n      \"provider_description\": \"Access historical end-of-day stock prices, intraday data, US stock options, and real-time prices with free and advanced plans. EODHD provides financial data for 150,000+ tickers, including stocks, ETFs, funds, and currencies worldwide.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1207.16,\n        \"success_rate\": 0.946\n      }\n    },\n    {\n      \"tool_id\": \"ths_ifind.company_basics.v1\",\n      \"name\": \"iFinD 公司基础信息 (Company Basics)\",\n      \"description\": \"Retrieve the latest (or a specific date) company basics indicators from THS iFinD. Includes company name, industry, comparable/peer companies, concept tags, codes, established date, registration info, main business, and major products.\",\n      \"params\": [\n        {\n          \"name\": \"codes\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Security codes, comma-separated (max 50), e.g., '300033.SZ,600030.SH'\"\n        },\n        {\n          \"name\": \"date\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Date, format: 'YYYYMMDD'. Use this field to query historical values. Defaults to latest.\"\n        }\n      ],\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 780.08,\n        \"success_rate\": 0.914\n      }\n    },\n    {\n      \"tool_id\": \"ths_ifind.financial_statements.v1\",\n      \"name\": \"iFinD 同花顺财报 Financial Statements (Balance/Income/Cash Flow)\",\n      \"description\": \"Query balance sheet, income statement, or cash flow statement data for securities from THS iFinD Financial Statement database using a single entry point.\",\n      \"params\": [\n        {\n          \"name\": \"statement_type\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Which statement to query: 'balance', 'income', or 'cash_flow'\"\n        },\n        {\n          \"name\": \"codes\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Security codes, multiple codes separated by commas (max 50), e.g., '300033.SZ,600030.SH'\"\n        },\n        {\n          \"name\": \"year\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Year, e.g., '2024'\"\n        },\n        {\n          \"name\": \"period\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Reporting period: '0331' (Q1), '0630' (H1), '0930' (Q3), '1231' (Annual)\"\n        },\n        {\n          \"name\": \"type\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Report type: '1' (Consolidated), '2' (Parent Company), '3' (Consolidated Adjusted), '4' (Parent Company Adjusted)\"\n        }\n      ],\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 654.98,\n        \"success_rate\": 0.877\n      }\n    },\n    {\n      \"tool_id\": \"ths_ifind.smart_stock_picking.v1\",\n      \"name\": \"iFinD 同花顺智能选股 (THS Intelligent Stock Picking)\",\n      \"description\": \"同花顺 (THS) intelligent stock picking tool that supports filtering stocks in the market through natural language queries. Users can use descriptive query statements to quickly obtain stock data that meets the criteria, including stock codes, names, company cities, concepts, and detailed explanations.\",\n      \"params\": [\n        {\n          \"name\": \"searchstring\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Natural language search query, e.g., '属于杭州的deepseek概念公司'\"\n        }\n      ],\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 988.17,\n        \"success_rate\": 0.812\n      }\n    },\n    {\n      \"tool_id\": \"finnhub_io_api.stock.quote\",\n      \"name\": \"Quote\",\n      \"description\": \"Get real-time quote data for US stocks.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Stock symbol\"\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 853.46,\n        \"success_rate\": 0.951\n      }\n    },\n    {\n      \"tool_id\": \"ths_ifind.code_converter.v1\",\n      \"name\": \"iFinD 同花顺证券代码转换 (THS Security Code Converter)\",\n      \"description\": \"Convert security codes or security names to 同花顺 (THS) standard code format. Supports querying by security code or security name, can specify security type and market, supports exact match or fuzzy match. Returns converted THS codes and related security information.\",\n      \"params\": [\n        {\n          \"name\": \"seccode\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Security code, e.g., '000001'. Either seccode or secname\"\n        },\n        {\n          \"name\": \"secname\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Security name, e.g., '平安银行'. Either seccode or secname\"\n        },\n        {\n          \"name\": \"mode\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Query mode: 'seccode' (query by code) or 'secname' (query by name)\"\n        },\n        {\n          \"name\": \"sectype\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Security type, e.g., '001' (stock), default i