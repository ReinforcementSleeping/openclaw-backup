            \"zh-cn\",\n            \"yo\",\n            \"uk\",\n            \"cpe\",\n            \"id\",\n            \"ur\",\n            \"ig\",\n            \"aa\",\n            \"uz\",\n            \"mr\",\n            \"en\",\n            \"am\",\n            \"my\",\n            \"es\",\n            \"ar\",\n            \"vi\",\n            \"ne\",\n            \"ja\",\n            \"az\",\n            \"fa\",\n            \"fa-af\",\n            \"ro\",\n            \"en-gb\",\n            \"en-ca\",\n            \"ru\",\n            \"rw\",\n            \"fr\",\n            \"bn\",\n            \"br\",\n            \"si\",\n            \"es-ec\",\n            \"so\",\n            \"gd\",\n            \"om\",\n            \"sr\",\n            \"ko\",\n            \"sw\",\n            \"zh-tw\",\n            \"pt-br\",\n            \"ta\",\n            \"gu\",\n            \"ky\",\n            \"cs\",\n            \"te\",\n            \"pa\",\n            \"th\",\n            \"ti\",\n            \"cy\",\n            \"ha\",\n            \"pl\",\n            \"tr\"\n          ]\n        },\n        {\n          \"name\": \"sourceFeed\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Filter results by the original sourceFeed\"\n          }\n        },\n        {\n          \"name\": \"exactCategoryMatch\",\n          \"type\": \"boolean\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"If set to true, the api will return stories with only the requested category\"\n          }\n        },\n        {\n          \"name\": \"format\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Response format\"\n          },\n          \"enum\": [\n            \"json\",\n            \"xml\",\n            \"csv\"\n          ]\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"format\": \"json\",\n          \"displayType\": \"headline\"\n        }\n      },\n      \"provider_description\": \"Barchart OnDemand's market data APIs let you power your apps, websites and software with financial market data and information directly from exchanges around the world. Maintained through Amazon Web Services, Barchart OnDemand APIs are flexible and can be delivered in multiple formats including XML, JSON and CSV, and can be streamed over websockets.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 0,\n        \"success_rate\": 0\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.companynews.retrieve.v1\",\n      \"name\": \"Company News\",\n      \"description\": \"List latest company news by symbol. This endpoint is only available for North American companies.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Company symbol.\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"From date <code>YYYY-MM-DD</code>.\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"To date <code>YYYY-MM-DD</code>.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"to\": \"2025-11-24\",\n          \"from\": \"2025-11-17\",\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 642.03,\n        \"success_rate\": 0.21\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.companynews.retrieve.v1.e428b704\",\n      \"name\": \"Company News\",\n      \"description\": \"List latest company news by symbol. This endpoint is only available for North American companies.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Company symbol.\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"From date <code>YYYY-MM-DD</code>.\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"To date <code>YYYY-MM-DD</code>.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"to\": \"2025-11-24\",\n          \"from\": \"2025-11-01\",\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1300.12,\n        \"success_rate\": 0.833\n      }\n    }\n  ],\n  \"search_id\": \"24fe851f-69cc-4408-b686-1d5e07d3d550\",\n  \"elapsed_time_ms\": 490.08\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":6135,"aggregated":"{\n  \"query\": \"stock market breaking news API\",\n  \"total\": 10,\n  \"results\": [\n    {\n      \"tool_id\": \"finnhub.news.retrieve.v1.2e72ea5d\",\n      \"name\": \"Market News\",\n      \"description\": \"Get latest market news.\",\n      \"params\": [\n        {\n          \"name\": \"category\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"This parameter can be 1 of the following values <code>general, forex, crypto, merger</code>.\"\n          }\n        },\n        {\n          \"name\": \"minId\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Use this field to get only news after this ID. Default to 0\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"category\": \"general\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1283.49,\n        \"success_rate\": 0.762\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.news.retrieve.v1\",\n      \"name\": \"Market News\",\n      \"description\": \"Get latest market news.\",\n      \"params\": [\n        {\n          \"name\": \"category\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"This parameter can be 1 of the following values <code>general, forex, crypto, merger</code>.\"\n          }\n        },\n        {\n          \"name\": \"minId\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Use this field to get only news after this ID. Default to 0\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"category\": \"general\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 769.91,\n        \"success_rate\": 0.986\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.news.retrieve.v1.51b2567e\",\n      \"name\": \"Market News\",\n      \"description\": \"Get latest market news.\",\n      \"params\": [\n        {\n          \"name\": \"category\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"This parameter can be 1 of the following values <code>general, forex, crypto, merger</code>.\"\n          }\n        },\n        {\n          \"name\": \"minId\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Use this field to get only news after this ID. Default to 0\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"category\": \"general\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 542.57,\n        \"success_rate\": 0.916\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.market.news.list.v1\",\n      \"name\": \"Market News\",\n      \"description\": \"Get latest market news.\",\n      \"params\": [\n        {\n          \"name\": \"category\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"News category. Available values: \\\\`general\\\\` \\\\`forex\\\\` \\\\`crypto\\\\` \\\\`merger\\\\`\"\n          },\n          \"enum\": [\n            \"general\",\n            \"forex\",\n            \"crypto\",\n            \"merger\"\n          ]\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"category\": \"general\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1371.22,\n        \"success_rate\": 0.868\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.news.execute.v1\",\n      \"name\": \"Market News\",\n      \"description\": \"Get general, forex, crypto or merger news. Additional market news topics: economy, earnings, financial, healthcare, market, sector, technology, top. This endpoint is available on all plans. This is not a search API but returns news by category.\",\n      \"params\": [\n        {\n          \"name\": \"category\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"This parameter can be 1 of the following values <code>general, forex, crypto, merger</code>.\"\n          },\n          \"enum\": [\n            \"general\",\n            \"forex\",\n            \"crypto\",\n            \"merger\"\n          ]\n        },\n        {\n          \"name\": \"minId\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Use this field to get only news after this ID. Default to 0\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"category\": \"general\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 921.41,\n        \"success_rate\": 0.84\n      }\n    },\n    {\n      \"tool_id\": \"alphavantage.news_sentiment.retrieve.v1.7aca3c4a\",\n      \"name\": \"Retrieve Market News & Sentiment\",\n      \"description\": \"Returns live and historical market news & sentiment data from premier news outlets around the world, covering stocks, cryptocurrencies, forex, and various financial topics.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The function name.\"\n          },\n          \"enum\": [\n            \"NEWS_SENTIMENT\"\n          ]\n        },\n        {\n          \"name\": \"tickers\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of stock/crypto/forex symbols (e.g., COIN,CRYPTO:BTC,FOREX:USD). Filters articles that mention all listed tickers.\"\n          }\n        },\n        {\n          \"name\": \"topics\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of topics. Articles must cover all listed topics.\"\n          },\n          \"enum\": [\n            \"blockchain\",\n            \"earnings\",\n            \"ipo\",\n            \"mergers_and_acquisitions\",\n            \"financial_markets\",\n            \"economy_fiscal\",\n            \"economy_monetary\",\n            \"economy_macro\",\n            \"energy_transportation\",\n            \"finance\",\n            \"life_sciences\",\n            \"manufacturing\",\n            \"real_estate\",\n            \"retail_wholesale\",\n            \"technology\"\n          ]\n        },\n        {\n          \"name\": \"time_from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start time in YYYYMMDDTHHMM format (e.g., 20220410T0130).\"\n          }\n        },\n        {\n          \"name\": \"time_to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End time in YYYYMMDDTHHMM format.\"\n          }\n        },\n        {\n          \"name\": \"sort\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Sorting method.\"\n          },\n          \"enum\": [\n            \"LATEST\",\n            \"EARLIEST\",\n            \"RELEVANCE\"\n          ]\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Maximum number of results (up to 1000).\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"function\": \"NEWS_SENTIMENT\"\n        }\n      },\n      \"provider_description\": \"Alpha Vantage provides realtime and historical financial market data through a set of powerful and developer-friendly data APIs and spreadsheets. From traditional asset classes (e.g., stocks, ETFs, mutual funds) to economic indicators, from foreign exchange rates to commodities, from fundamental data to technical indicators, Alpha Vantage is your one-stop-shop for enterprise-grade global market data delivered through cloud-based APIs, MCP servers, spreadsheets, and more.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 672.29,\n        \"success_rate\": 0.893\n      }\n    },\n    {\n      \"tool_id\": \"eodhd.news.retrieve.v1.fe8bf94c\",\n      \"name\": \"Retrieve Financial News\",\n      \"description\": \"Returns the latest financial news headlines and full articles for a given ticker symbol or topic tag. Requires either a ticker (s) or a tag (t). Supports filtering by date, pagination, and JSON response format.\",\n      \"params\": [\n        {\n          \"name\": \"s\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The ticker code to retrieve news for, for example: AAPL.US\"\n          }\n        },\n        {\n          \"name\": \"t\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The topic tag to retrieve news for, for example: technology\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start date for filtering news (YYYY-MM-DD)\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End date for filtering news (YYYY-MM-DD)\"\n          }\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Number of results to return (default: 50, minimum: 1, maximum: 1000)\"\n          }\n        },\n        {\n          \"name\": \"offset\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Offset for pagination (default: 0)\"\n          }\n        },\n        {\n          \"name\": \"fmt\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Response format, either json or xml (default: json)\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {}\n      },\n      \"provider_description\": \"Access historical end-of-day stock prices, intraday data, US stock options, and real-time prices with free and advanced plans. EODHD provides financial data for 150,000+ tickers, including stocks, ETFs, funds, and currencies worldwide.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1913.94,\n        \"success_rate\": 0.987\n      }\n    },\n    {\n      \"tool_id\": \"barchart.ondemand.news.query.v1.655e0a3e\",\n      \"name\": \"Query News Articles\",\n      \"description\": \"The getNews API returns news headlines, articles and related photos based upon news sources, category, sub-category and/or keyword. With this API you can access breaking news, company press releases and global financial market coverage.\",\n      \"params\": [\n        {\n          \"name\": \"sources\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The news feed code\"\n          },\n          \"enum\": [\n            \"AP\",\n            \"APAI\",\n            \"BC\",\n            \"BCNEWS\",\n            \"CP\",\n            \"CNW\",\n            \"CRB\",\n            \"CMTX\",\n            \"CMTX:PCS\",\n            \"CMTX:PCC\",\n            \"CMTX:SEC\",\n            \"IF\",\n            \"USDA\",\n            \"PRNW\",\n            \"ZACKS\",\n            \"BRUG\",\n            \"AGWEB\",\n            \"SETZ\",\n            \"SPC\",\n            \"NASS\",\n            \"ESTMZ\",\n            \"DVND\",\n            \"LME-WHS\",\n            \"DLFRX\",\n            \"GLDRPT\",\n            \"COT\",\n            \"MAX\",\n            \"CMDTY_AGLITE\",\n            \"CMDTY_AG\",\n            \"CMDTY_ENERGY\",\n            \"SYNDTGAM\",\n            \"FCTGAM\",\n            \"BCSYND\",\n            \"HDLNE\",\n            \"HDLNEG\",\n            \"HDLNEP\"\n          ]\n        },\n        {\n          \"name\": \"symbols\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"A symbol or code that identifies a financial instrument\"\n          }\n        },\n        {\n          \"name\": \"category\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"A grouping of related news content\"\n          },\n          \"enum\": [\n            \"companies\",\n            \"politics\",\n            \"geography\",\n            \"commodities\",\n            \"economics\",\n            \"stocks\",\n            \"futures\"\n          ]\n        },\n        {\n          \"name\": \"subCategory\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"A more specific category of related news content\"\n          },\n          \"enum\": [\n            \"private companies\",\n            \"stock equities\",\n            \"stock trading\",\n            \"stock options\",\n            \"regu