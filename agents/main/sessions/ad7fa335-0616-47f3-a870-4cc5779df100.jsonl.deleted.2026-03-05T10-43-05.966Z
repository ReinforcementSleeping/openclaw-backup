"call_function_cb5svtc9imn5_1","name":"exec","arguments":{"command":"cd ~/.openclaw/workspace && node -e '\nconst API_KEY = process.env.QVERIS_API_KEY;\n\nasync function test() {\n  // Try Yahoo Finance with specific tickers to get more relevant data\n  const execRes = await fetch(\"https://qveris.ai/api/v1/tools/execute\", {\n    method: \"POST\",\n    headers: {\n      \"Content-Type\": \"application/json\",\n      \"Authorization\": \"Bearer \" + API_KEY\n    },\n    body: JSON.stringify({ \n      tool_id: \"yahoo_finance.finance_news.v1\",\n      params: { max_results: 20, time_range: \"1d\" }\n    })\n  });\n  const execData = await execRes.json();\n  \n  // Print just the articles to see their structure\n  if (execData.result && execData.result.data && execData.result.data.articles) {\n    console.log(\"Found\", execData.result.data.articles.length, \"articles\");\n    console.log(JSON.stringify(execData.result.data.articles.slice(0,3), null, 2));\n  }\n}\ntest();\n'","timeout":60}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":30845,"output":661,"cacheRead":13984,"cacheWrite":0,"totalTokens":45490,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772518448132}}
