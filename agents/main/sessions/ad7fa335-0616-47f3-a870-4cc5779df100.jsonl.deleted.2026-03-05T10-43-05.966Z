 worldwide.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1278.53,\n        \"success_rate\": 0.999\n      }\n    },\n    {\n      \"tool_id\": \"alphavantage.news_sentiment.query.v1.7aca3c4a\",\n      \"name\": \"Market News & Sentiment\",\n      \"description\": \"Returns live and historical market news & sentiment data from global news outlets covering stocks, crypto, forex, and economic topics.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The function to call. In this case, NEWS_SENTIMENT\"\n          },\n          \"enum\": [\n            \"NEWS_SENTIMENT\"\n          ]\n        },\n        {\n          \"name\": \"tickers\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of stock/crypto/forex symbols to filter articles by (e.g., AAPL,CRYPTO:BTC).\"\n          }\n        },\n        {\n          \"name\": \"topics\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of topics to filter by.\"\n          },\n          \"enum\": [\n            \"blockchain\",\n            \"earnings\",\n            \"ipo\",\n            \"mergers_and_acquisitions\",\n            \"financial_markets\",\n            \"economy_fiscal\",\n            \"economy_monetary\",\n            \"economy_macro\",\n            \"energy_transportation\",\n            \"finance\",\n            \"life_sciences\",\n            \"manufacturing\",\n            \"real_estate\",\n            \"retail_wholesale\",\n            \"technology\"\n          ]\n        },\n        {\n          \"name\": \"time_from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start time in YYYYMMDDTHHMM format (e.g., 20220410T0130).\"\n          }\n        },\n        {\n          \"name\": \"time_to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End time in YYYYMMDDTHHMM format.\"\n          }\n        },\n        {\n          \"name\": \"sort\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Sorting method for results.\"\n          },\n          \"enum\": [\n            \"LATEST\",\n            \"EARLIEST\",\n            \"RELEVANCE\"\n          ]\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Maximum number of results (up to 1000).\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"function\": \"NEWS_SENTIMENT\"\n        }\n      },\n      \"provider_description\": \"Alpha Vantage provides realtime and historical financial market data through a set of powerful and developer-friendly data APIs and spreadsheets. From traditional asset classes (e.g., stocks, ETFs, mutual funds) to economic indicators, from foreign exchange rates to commodities, from fundamental data to technical indicators, Alpha Vantage is your one-stop-shop for enterprise-grade global market data delivered through cloud-based APIs, MCP servers, spreadsheets, and more.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 520.43,\n        \"success_rate\": 0.987\n      }\n    },\n    {\n      \"tool_id\": \"alphavantage.news_sentiment.retrieve.v1.7aca3c4a\",\n      \"name\": \"Retrieve Market News & Sentiment\",\n      \"description\": \"Returns live and historical market news & sentiment data from premier news outlets around the world, covering stocks, cryptocurrencies, forex, and various financial topics.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"t