ss_rate\": 0.463\n      }\n    },\n    {\n      \"tool_id\": \"openweathermap.weather.retrieve.v2\",\n      \"name\": \"Current Weather Data\",\n      \"description\": \"Obtain real-time weather data for any location globally. Provides comprehensive weather details including temperature, pressure, humidity, wind, and more. Supports JSON, XML, or HTML formats, geocoding, language options, and different measurement units.\",\n      \"params\": [\n        {\n          \"name\": \"q\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"City name, state code and country code divided by comma (e.g. city,country or city,state,country). Refer to ISO 3166. Supports non-English if in predefined list.\"\n          }\n        },\n        {\n          \"name\": \"lat\",\n          \"type\": \"number\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Latitude coordinates\"\n          }\n        },\n        {\n          \"name\": \"lon\",\n          \"type\": \"number\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Longitude coordinates\"\n          }\n        },\n        {\n          \"name\": \"id\",\n          \"type\": \"number\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"City ID. List available in city.list.json.gz\"\n          }\n        },\n        {\n          \"name\": \"zip\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"ZIP code, country code optional (default USA)\"\n          }\n        },\n        {\n          \"name\": \"mode\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Response format. Default JSON\"\n          },\n          \"enum\": [\n            \"xml\",\n            \"html\"\n          ]\n        },\n        {\n          \"name\": \"units\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Units of measurement. Default standard (Kelvin, m/s, hPa). Metric: Celsius, m/s. Imperial: Fahrenheit, mph.\"\n          },\n          \"enum\": [\n            \"standard\",\n            \"metric\",\n            \"imperial\"\n          ]\n        },\n        {\n          \"name\": \"lang\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Language for output (city name and description fields)\"\n          },\n          \"enum\": [\n            \"sq\",\n            \"af\",\n            \"ar\",\n            \"az\",\n            \"eu\",\n            \"be\",\n            \"bg\",\n            \"ca\",\n            \"zh_cn\",\n            \"zh_tw\",\n            \"hr\",\n            \"cz\",\n            \"da\",\n            \"nl\",\n            \"en\",\n            \"fi\",\n            \"fr\",\n            \"gl\",\n            \"de\",\n            \"el\",\n            \"he\",\n            \"hi\",\n            \"hu\",\n            \"is\",\n            \"id\",\n            \"it\",\n            \"ja\",\n            \"kr\",\n            \"ku\",\n            \"la\",\n            \"lt\",\n            \"mk\",\n            \"no\",\n            \"fa\",\n            \"pl\",\n            \"pt\",\n            \"pt_br\",\n            \"ro\",\n            \"ru\",\n            \"sr\",\n            \"sk\",\n            \"sl\",\n            \"es\",\n            \"se\",\n            \"th\",\n            \"tr\",\n            \"ua\",\n            \"vi\",\n            \"zu\"\n          ]\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"q\": \"London,uk\"\n        }\n      },\n      \"provider_description\": \"Explore OpenWeather s user-friendly weather data products and APIs, offering short and long-term forecasts, historical observations, and specialized solutions like Road Risk and Solar Energy Prediction. Ideal for range of applications, from simple ones to complex enterprise level systems.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 3.017,\n        \"success_rate\": 1\n      }\n    },\n    {\n      \"tool_id\": \"weather_gov.offices.headlines.retrieve.v1.604dcfd6\",\n      \"name\": \"office_headlines\",\n      \"description\": \"Returns a list of news headlines for a given NWS office\",\n      \"params\": [\n        {\n          \"name\": \"officeId\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"NWS office ID\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"officeId\": \"BOU\"\n        }\n      },\n      \"provider_description\": \"The National Weather Service (NWS) API allows developers access to critical forecasts, alerts, and observations, along with other weather data. The API is based upon JSON-LD to promote machine data discovery.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1.585,\n        \"success_rate\": 1\n      }\n    },\n    {\n      \"tool_id\": \"weather_gov.offices.headlines.retrieve.v3.36ea67a2\",\n      \"name\": \"office_headlines\",\n      \"description\": \"Returns a list of news headlines for a given NWS office\",\n      \"params\": [\n        {\n          \"name\": \"officeId\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"NWS office ID\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"officeId\": \"BOX\"\n        }\n      },\n      \"provider_description\": \"The National Weather Service (NWS) API allows developers access to critical forecasts, alerts, and observations, along with other weather data. The API is based upon JSON-LD to promote machine data discovery.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1.74,\n        \"success_rate\": 1\n      }\n    },\n    {\n      \"tool_id\": \"alphavantage.news_sentiment.query.v1.7aca3c4a\",\n      \"name\": \"Market News & Sentiment\",\n      \"description\": \"Returns live and historical market news & sentiment data from global news outlets covering stocks, crypto, forex, and economic topics.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The function to call. In this case, NEWS_SENTIMENT\"\n          },\n          \"enum\": [\n            \"NEWS_SENTIMENT\"\n          ]\n        },\n        {\n          \"name\": \"tickers\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of stock/crypto/forex symbols to filter articles by (e.g., AAPL,CRYPTO:BTC).\"\n          }\n        },\n        {\n          \"name\": \"topics\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of topics to filter by.\"\n          },\n          \"enum\": [\n            \"blockchain\",\n            \"earnings\",\n            \"ipo\",\n            \"mergers_and_acquisitions\",\n            \"financial_markets\",\n            \"economy_fiscal\",\n            \"economy_monetary\",\n            \"economy_macro\",\n            \"energy_transportation\",\n            \"finance\",\n            \"life_sciences\",\n            \"manufacturing\",\n            \"real_estate\",\n            \"retail_wholesale\",\n            \"technology\"\n          ]\n        },\n        {\n          \"name\": \"time_from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start time in YYYYMMDDTHHMM format (e.g., 20220410T0130).\"\n          }\n        },\n        {\n          \"name\": \"time_to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End time in YYYYMMDDTHHMM format.\"\n          }\n        },\n        {\n          \"name\": \"sort\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Sorting method for results.\"\n          },\n          \"enum\": [\n            \"LATEST\",\n            \"EARLIEST\",\n            \"RELEVANCE\"\n          ]\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Maximum number of results (up to 1000).\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"function\": \"NEWS_SENTIMENT\"\n        }\n      },\n      \"provider_description\": \"Alpha Vantage provides realtime and historical financial market data through a set of powerful and developer-friendly data APIs and spreadsheets. From traditional asset classes (e.g., stocks, ETFs, mutual funds) to economic indicators, from foreign exchange rates to commodities, from fundamental data to technical indicators, Alpha Vantage is your one-stop-shop for enterprise-grade global market data delivered through cloud-based APIs, MCP servers, spreadsheets, and more.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 520.43,\n        \"success_rate\": 0.987\n      }\n    },\n    {\n      \"tool_id\": \"eodhd.news.retrieve.v1.fe8bf94c\",\n      \"name\": \"Retrieve Financial News\",\n      \"description\": \"Returns the latest financial news headlines and full articles for a given ticker symbol or topic tag. Requires either a ticker (s) or a tag (t). Supports filtering by date, pagination, and JSON response format.\",\n      \"params\": [\n        {\n          \"name\": \"s\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The ticker code to retrieve news for, for example: AAPL.US\"\n          }\n        },\n        {\n          \"name\": \"t\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The topic tag to retrieve news for, for example: technology\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start date for filtering news (YYYY-MM-DD)\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End date for filtering news (YYYY-MM-DD)\"\n          }\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Number of results to return (default: 50, minimum: 1, maximum: 1000)\"\n          }\n        },\n        {\n          \"name\": \"offset\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Offset for pagination (default: 0)\"\n          }\n        },\n        {\n          \"name\": \"fmt\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Response format, either json or xml (default: json)\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {}\n      },\n      \"provider_description\": \"Access historical end-of-day stock prices, intraday data, US stock options, and real-time prices with free and advanced plans. EODHD provides financial data for 150,000+ tickers, including stocks, ETFs, funds, and currencies worldwide.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1.183,\n        \"success_rate\": 0.741\