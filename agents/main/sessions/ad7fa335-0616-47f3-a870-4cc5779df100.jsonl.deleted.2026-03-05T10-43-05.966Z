{"type":"message","id":"cf6455d8","parentId":"307820d8","timestamp":"2026-03-03T06:13:02.708Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Yahoo Finance works! But it doesn't have the heat/temperature data. Let me check what other news APIs are available that might have heat/temperature scores. Let me search for news with \"sentiment\" or \"heat\".","thinkingSignature":"25cd9ed5ad4f2125dd23a433f4ce7f88ff3d0d6a7093d2bca078c2b80402b14c"},{"type":"toolCall","id":"call_function_tcmhzu48w35x_1","name":"exec","arguments":{"command":"cd ~/.openclaw/workspace && node -e '\nconst API_KEY = process.env.QVERIS_API_KEY;\n\nasync function test() {\n  const searchRes = await fetch(\"https://qveris.ai/api/v1/search\", {\n    method: \"POST\",\n    headers: {\n      \"Content-Type\": \"application/json\",\n      \"Authorization\": \"Bearer \" + API_KEY\n    },\n    body: JSON.stringify({ query: \"financial news sentiment heat trending\", limit: 15 })\n  });\n  const searchData = await searchRes.json();\n  console.log(JSON.stringify(searchData, null, 2));\n}\ntest();\n'","timeout":30}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":28012,"output":208,"cacheRead":13984,"cacheWrite":0,"totalTokens":42204,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772518375729}}
{"type":"message","id":"1d6faf34","parentId":"cf6455d8","timestamp":"2026-03-03T06:13:05.864Z","message":{"role":"toolResult","toolCallId":"call_function_tcmhzu48w35x_1","toolName":"exec","content":[{"type":"text","text":"{\n  \"query\": \"financial news sentiment heat trending\",\n  \"total\": 15,\n  \"results\": [\n    {\n      \"tool_id\": \"alphavantage.news_sentiment.query.v1.7aca3c4a\",\n      \"name\": \"Market News & Sentiment\",\n      \"description\": \"Returns live and historical market news & sentiment data from global news outlets covering stocks, crypto, forex, and economic topics.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The function to call. In this case, NEWS_SENTIMENT\"\n          },\n          \"enum\": [\n            \"NEWS_SENTIMENT\"\n          ]\n        },\n        {\n          \"name\": \"tickers\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of stock/crypto/forex symbols to filter articles by (e.g., AAPL,CRYPTO:BTC).\"\n          }\n        },\n        {\n          \"name\": \"topics\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of topics to filter by.\"\n          },\n          \"enum\": [\n            \"blockchain\",\n            \"earnings\",\n            \"ipo\",\n            \"mergers_and_acquisitions\",\n            \"financial_markets\",\n            \"economy_fiscal\",\n            \"economy_monetary\",\n            \"economy_macro\",\n            \"energy_transportation\",\n            \"finance\",\n            \"life_sciences\",\n            \"manufacturing\",\n            \"real_estate\",\n            \"retail_wholesale\",\n            \"technology\"\n          ]\n        },\n        {\n          \"name\": \"time_from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start time in YYYYMMDDTHHMM format (e.g., 20220410T0130).\"\n          }\n        },\n        {\n          \"name\": \"time_to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End time in YYYYMMDDTHHMM format.\"\n          }\n        },\n        {\n          \"name\": \"sort\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Sorting method for results.\"\n          },\n          \"enum\": [\n            \"LATEST\",\n            \"EARLIEST\",\n            \"RELEVANCE\"\n          ]\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Maximum number of results (up to 1000).\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"function\": \"NEWS_SENTIMENT\"\n        }\n      },\n      \"provider_description\": \"Alpha Vantage provides realtime and historical financial market data through a set of powerful and developer-friendly data APIs and spreadsheets. From traditional asset classes (e.g., stocks, ETFs, mutual funds) to economic indicators, from foreign exchange rates to commodities, from fundamental data to technical indicators, Alpha Vantage is your one-stop-shop for enterprise-grade global market data delivered through cloud-based APIs, MCP servers, spreadsheets, and more.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 520.43,\n        \"success_rate\": 0.987\n      }\n    },\n    {\n      \"tool_id\": \"alphavantage.news_sentiment.retrieve.v1.7aca3c4a\",\n      \"name\": \"Retrieve Market News & Sentiment\",\n      \"description\": \"Returns live and historical market news & sentiment data from premier news outlets around the world, covering stocks, cryptocurrencies, forex, and various financial topics.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The function name.\"\n          },\n          \"enum\": [\n            \"NEWS_SENTIMENT\"\n          ]\n        },\n        {\n          \"name\": \"tickers\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of stock/crypto/forex symbols (e.g., COIN,CRYPTO:BTC,FOREX:USD). Filters articles that mention all listed tickers.\"\n          }\n        },\n        {\n          \"name\": \"topics\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of topics. Articles must cover all listed topics.\"\n          },\n          \"enum\": [\n            \"blockchain\",\n            \"earnings\",\n            \"ipo\",\n            \"mergers_and_acquisitions\",\n            \"financial_markets\",\n            \"economy_fiscal\",\n            \"economy_monetary\",\n            \"economy_macro\",\n            \"energy_transportation\",\n            \"finance\",\n            \"life_sciences\",\n            \"manufacturing\",\n            \"real_estate\",\n            \"retail_wholesale\",\n            \"technology\"\n          ]\n        },\n        {\n          \"name\": \"time_from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start time in YYYYMMDDTHHMM format (e.g., 20220410T0130).\"\n          }\n        },\n        {\n          \"name\": \"time_to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End time in YYYYMMDDTHHMM format.\"\n          }\n        },\n        {\n          \"name\": \"sort\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Sorting method.\"\n          },\n          \"enum\": [\n            \"LATEST\",\n            \"EARLIEST\",\n            \"RELEVANCE\"\n          ]\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Maximum number of results (up to 1000).\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"function\": \"NEWS_SENTIMENT\"\n        }\n      },\n      \"provider_description\": \"Alpha Vantage provides realtime and historical financial market data through a set of powerful and developer-friendly data APIs and spreadsheets. From traditional asset classes (e.g., stocks, ETFs, mutual funds) to economic indicators, from foreign exchange rates to commodities, from fundamental data to technical indicators, Alpha Vantage is your one-stop-shop for enterprise-grade global market data delivered through cloud-based APIs, MCP servers, spreadsheets, and more.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 660.49,\n        \"success_rate\": 0.973\n      }\n    },\n    {\n      \"tool_id\": \"eodhd.sentiments.retrieve.v1.c2c27d35\",\n      \"name\": \"Retrieve Sentiment Data\",\n      \"description\": \"Get sentiment scores for one or more financial instruments (stocks, ETFs, crypto) calculated from news and social media, normalized on a scale from -1 (very negative) to 1 (very positive).\",\n      \"params\": [\n        {\n          \"name\": \"s\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"One or more comma-separated tickers, for example: AAPL.US,BTC-USD.CC\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start date for filtering sentiment data (YYYY-MM-DD)\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End date for filtering sentiment data (YYYY-MM-DD)\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"s\": \"AAPL.US,BTC-USD.CC\"\n        }\n      },\n      \"provider_description\": \"Access historical end-of-day stock prices, intraday data, US stock options, and real-time prices with free and advanced plans. EODHD provides financial data for 150,000+ tickers, including stocks, ETFs, funds, and currencies worldwide.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1278.53,\n        \"success_rate\": 0.999\n      }\n    },\n    {\n      \"tool_id\": \"eodhd.news.retrieve.v1.fe8bf94c\",\n      \"name\": \"Retrieve Financial News\",\n      \"description\": \"Returns the latest financial news headlines and full articles for a given ticker symbol or topic tag. Requires either a ticker (s) or a tag (t). Supports filtering by date, pagination, and JSON response format.\",\n      \"params\": [\n        {\n          \"name\": \"s\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The ticker code to retrieve news for, for example: AAPL.US\"\n          }\n        },\n        {\n          \"name\": \"t\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The topic tag to retrieve news for, for example: technology\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start date for filtering news (YYYY-MM-DD)\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End date for filtering news (YYYY-MM-DD)\"\n          }\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Number of results to return (default: 50, minimum: 1, maximum: 1000)\"\n          }\n        },\n        {\n          \"name\": \"offset\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Offset for pagination (default: 0)\"\n          }\n        },\n        {\n          \"name\": \"fmt\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Response format, either json or xml (default: json)\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {}\n      },\n      \"provider_description\": \"Access historical end-of-day stock prices, intraday data, US stock options, and real-time prices with free and advanced plans. EODHD provides financial data for 150,000+ tickers, including stocks, ETFs, funds, and currencies worldwide.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1.183,\n        \"success_rate\": 0.741\n      }\n    },\n    {\n      \"tool_id\": \"alphavantage.news_sentiment.query.v1.467a92c0\",\n      \"name\": \"Market News & Sentiment Trending\",\n      \"description\": \"This API returns live and historical market news & sentiment data from a large & growing selection of premier news outlets around the world, covering stocks, cryptocurrencies, forex, and a wide range of topics such as fiscal policy, mergers & acquisitions, IPOs, etc.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The function of your choice. In this case, function=NEWS_SENTIMENT\"\n          },\n          \"enum\": [\n            \"NEWS_SENTIMENT\"\n          ]\n        },\n        {\n          \"name\": \"tickers\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The stock/crypto/forex symbols of your choice. For example: tickers=IBM will filter for articles that mention the IBM ticker; tickers=COIN,CRYPTO:BTC,FOREX:USD will filter for articles that simultaneously mention Coinbase (COIN), Bitcoin (CRYPTO:BTC), and US Dollar (FOREX:USD) in their content.\"\n          }\n        },\n        {\n          \"name\": \"topics\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The news topics of your choice. For example: topics=technology will filter for articles that write about the technology sector; topics=technology,ipo will filter for articles that simultaneously cover technology and IPO in their content. Below is the full list of supported topics: Blockchain: blockchain, Earnings: earnings, IPO: ipo, Mergers & Acquisitions: mergers_and_acquisitions, Financial Markets: financial_markets, Economy - Fiscal Policy (e.g., tax reform, government spending): economy_fiscal, Economy - Monetary Policy (e.g., interest rates, inflation): economy_monetary, Economy - Macro/Overall: economy_macro, Energy & Transportation: energy_transportation, Finance: finance, Life Sciences: life_sciences, Manufacturing: manufacturing, Real Estate & Construction: real_estate, Retail & Wholesale: retail_wholesale, Technology: technology.\"\n          }\n        },\n        {\n          \"name\": \"time_from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The time range of the news articles you are targeting, in YYYYMMDDTHHMM format. For example: time_from=20220410T0130. If time_from is specified but time_to is missing, the API will return articles published between the time_from value and the current time.\"\n          }\n        },\n        {\n          \"name\": \"time_to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The time range of the news articles you are targeting, in YYYYMMDDTHHMM format.\"\n          }\n        },\n        {\n          \"name\": \"sort\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"By default, sort=LATEST and the API will return the latest articles first. You can also set sort=EARLIEST or sort=RELEVANCE based on your use case.\"\n          },\n          \"enum\": [\n            \"LATEST\",\n            \"EARLIEST\",\n            \"RELEVANCE\"\n          ]\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"By default, limit=50 and the API will return up to 50 matching results. You can also set limit=1000 to output up to 1000 results.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"function\": \"NEWS_SENTIMENT\"\n        }\n      },\n      \"provider_description\": \"Alpha Vantage provides realtime and historical financial market data through a set of powerful and developer-friendly data APIs and spreadsheets. From traditional asset classes (e.g., stocks, ETFs, mutual funds) to economic indicators, from foreign exchange rates to commodities, from fundamental data to technical indicators, Alpha Vantage is your one-stop-shop for enterprise-grade global market data delivered through cloud-based APIs, MCP servers, spreadsheets, and more.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 883.34,\n        \"success_rate\": 0.946\n      }\n    },\n    {\n      \"tool_id\": \"qveris_finance.finance_news_aggregation_v1\",\n      \"name\": \"Finance News Aggregation\",\n      \"description\": \"Search and aggregate financial news from multiple sources\",\n      \"params\": [\n        {\n          \"name\": \"query\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Search query for financial news\"\n          }\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Maximum number of results to return\"\n          }\n        }\n      ],\n      \"provider_description\": \"Provider for finance-related skills\",\n      \"skill_type\": \"aggregation\"\n    },\n    {\n      \"tool_id\": \"finnhub.stock.recommendation.retrieve.v1.c29836a7\",\n      \"name\": \"Recommendation Trends\",\n      \"description\": \"Get latest analyst recommendation trends for a company.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Symbol of the company: AAPL.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 3.707,\n        \"success_rate\": 1\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.stock.recommendation.retrieve.v1\",\n      \"name\": \"Recommendation Trends\",\n      \"description\": \"Get latest analyst recommendation trends for a company.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Symbol of the company: AAPL.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 4.592,\n        \"success_rate\": 1\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.stock.recommendation.retrieve.v1.b67c9ec5\",\n      \"name\": \"Recommendation Trends\",\n      \"description\": \"Get latest analyst recommendation trends for a company.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Symbol of the company: AAPL.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 4.791,\n        \"success_rate\": 1\n      }\n    },\n    {\n      \"tool_id\": \"qveris_social.x_domain_hot_topics_v1\",\n      \"name\": \"X Domain Hot Topics Tracker\",\n      \"description\": \"Track and aggregate hot topics from domain experts (KOLs) on X/Twitter platform. Supports multiple domains: AI, Finance, Crypto, Tech, etc.\",\n      \"params\": [\n        {\n          \"name\": \"domains\",\n          \"type\": \"array\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"List of domains to query. Available: AI, Finance, Crypto, Tech, Science. If not specified, queries all domains.\",\n            \"zh\": \"要查询的领域列表。可选：AI、Finance、Crypto、Tech、Science。如不指定则查询所有领域。\"\n          },\n          \"enum\": [\n            \"AI\",\n            \"Finance\",\n            \"Crypto\",\n            \"Tech\",\n            \"Science\"\n          ]\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Maximum number of results to return per domain\",\n            \"zh\": \"每个领域返回结果的最大数量\"\n          }\n        },\n        {\n          \"name\": \"min_engagement\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Minimum engagement (likes + retweets + replies) for filtering posts\",\n            \"zh\": \"用于过滤的最小互动量（点赞+转发+回复）\"\n          }\n        }\n      ],\n      \"provider_description\": \"Social media monitoring and analysis skills\",\n      \"skill_package_url\": \"https://qveris.ai/api/v1/skills/qveris_social.x_domain_hot_topics_v1/package\",\n      \"skill_type\": \"package\"\n    },\n    {\n      \"tool_id\": \"finnhub.news.retrieve.v1.2e72ea5d\",\n      \"name\": \"Market News\",\n      \"description\": \"Get latest market news.\",\n      \"params\": [\n        {\n          \"name\": \"category\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"This parameter can be 1 of the following values <code>general, forex, crypto, merger</code>.\"\n          }\n        },\n        {\n          \"name\": \"minId\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Use this field to get only news after this ID. Default to 0\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"category\": \"general\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\"\n    },\n    {\n      \"tool_id\": \"finnhub.news.retrieve.v1.51b2567e\",\n      \"name\": \"Market News\",\n      \"description\": \"Get latest market news.\",\n      \"params\": [\n        {\n          \"name\": \"category\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"This parameter can be 1 of the following values <code>general, forex, crypto, merger</code>.\"\n          }\n        },\n        {\n          \"name\": \"minId\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Use this field to get only news after this ID. Default to 0\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"category\": \"general\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 2.911,\n        \"success_rate\": 1\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.news.retrieve.v1\",\n      \"name\": \"Market News\",\n      \"description\": \"Get latest market news.\",\n      \"params\": [\n        {\n          \"name\": \"category\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"This parameter can be 1 of the following values <code>general, forex, crypto, merger</code>.\"\n          }\n        },\n        {\n          \"name\": \"minId\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Use this field to get only news after this ID. Default to 0\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"category\": \"general\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 807.31,\n        \"success_rate\": 0.997\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.stock.insidersentiment.retrieve.v1.dff02940\",\n      \"name\": \"Insider Sentiment\",\n      \"description\": \"Get insider sentiment data for US companies calculated using method discussed <a href=\\\"https://medium.com/@stock-api/finnhub-insiders-sentiment-analysis-cc43f9f64b3a\\\" target=\\\"_blank\\\">here</a>. The MSPR ranges from -100 for the most negative to 100 for the most positive which can signal price changes in the coming 30-90 days.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Symbol of the company: AAPL.\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"From date: 2020-03-15.\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"To date: 2020-03-16.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"to\": \"2020-03-16\",\n          \"from\": \"2020-03-15\",\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 3.579,\n        \"success_rate\": 1\n      }\n    },\n    {\n      \"tool_id\": \"cryptopanic.api.posts.list.v2.db871245\",\n      \"name\": \"List News Posts\",\n      \"description\": \"Retrieve a list of cryptocurrency news posts with filtering and pagination options.\",\n      \"params\": [\n        {\n          \"name\": \"api_plan\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Your API plan tier, must be growth.\"\n          },\n          \"enum\": [\n            \"growth\"\n          ]\n        },\n        {\n          \"name\": \"public\",\n          \"type\": \"boolean\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Enable public usage mode.\"\n          }\n        },\n        {\n          \"name\": \"currencies\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of currency codes to filter by (e.g., BTC,ETH).\"\n          }\n        },\n        {\n          \"name\": \"regions\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated language region codes (e.g., en,fr,es).\"\n          },\n          \"enum\": [\n            \"en\",\n            \"de\",\n            \"nl\",\n            \"es\",\n            \"fr\",\n            \"it\",\n            \"pt\",\n            \"ru\",\n            \"tr\",\n            \"ar\",\n            \"zh\",\n            \"ja\",\n            \"ko\"\n          ]\n        },\n        {\n          \"name\": \"filter\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Filter posts by sentiment or activity type.\"\n          },\n          \"enum\": [\n            \"rising\",\n            \"hot\",\n            \"bullish\",\n            \"bearish\",\n            \"important\",\n            \"saved\",\n            \"lol\"\n          ]\n        },\n        {\n          \"name\": \"kind\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Type of content to include.\"\n          },\n          \"enum\": [\n            \"news\",\n            \"media\",\n            \"blog\",\n            \"twitter\",\n            \"reddit\",\n            \"all\"\n          ]\n        },\n        {\n          \"name\": \"following\",\n          \"type\": \"boolean\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Include only posts from followed sources.\"\n          }\n        },\n        {\n          \"name\": \"last_pull\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"ISO 8601 timestamp to fetch posts published after this time.\"\n          }\n        },\n        {\n          \"name\": \"panic_period\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Time window for panic score calculation.\"\n          },\n          \"enum\": [\n            \"1h\",\n            \"6h\",\n            \"24h\"\n          ]\n        },\n        {\n          \"name\": \"panic_sort\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Sort order for panic score (asc or desc).\"\n          },\n          \"enum\": [\n            \"asc\",\n            \"desc\"\n          ]\n        },\n        {\n          \"name\": \"size\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Number of results per page (1–500).\"\n          }\n        },\n        {\n          \"name\": \"with_content\",\n          \"type\": \"boolean\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Include full article content in response.\"\n          }\n        },\n        {\n          \"name\": \"search\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Keyword to search within post titles or content.\"\n          }\n        },\n        {\n          \"name\": \"format\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Response format; use 'rss' for RSS feed output.\"\n          },\n          \"enum\": [\n            \"json\",\n            \"rss\"\n          ]\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"api_plan\": \"growth\"\n        }\n      },\n      \"provider_description\": \"Get real-time crypto news, sentiment, and market signals—delivered via a structured API, built for apps, bots, dashboards, and analytics platforms.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 0,\n        \"success_rate\": 0\n      }\n    }\n  ],\n  \"search_id\": \"7eeea04f-dfbd-464a-8996-7e18797b0a93\",\n  \"elapsed_time_ms\": 220.06\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":3149,"aggregated":"{\n  \"query\": \"financial news sentiment heat trending\",\n  \"total\": 15,\n  \"results\": [\n    {\n      \"tool_id\": \"alphavantage.news_sentiment.query.v1.7aca3c4a\",\n      \"name\": \"Market News & Sentiment\",\n      \"description\": \"Returns live and historical market news & sentiment data from global news outlets covering stocks, crypto, forex, and economic topics.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The function to call. In this case, NEWS_SENTIMENT\"\n          },\n          \"enum\": [\n            \"NEWS_SENTIMENT\"\n          ]\n        },\n        {\n          \"name\": \"tickers\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of stock/crypto/forex symbols to filter articles by (e.g., AAPL,CRYPTO:BTC).\"\n          }\n        },\n        {\n          \"name\": \"topics\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of topics to filter by.\"\n          },\n          \"enum\": [\n            \"blockchain\",\n            \"earnings\",\n            \"ipo\",\n            \"mergers_and_acquisitions\",\n            \"financial_markets\",\n            \"economy_fiscal\",\n            \"economy_monetary\",\n            \"economy_macro\",\n            \"energy_transportation\",\n            \"finance\",\n            \"life_sciences\",\n            \"manufacturing\",\n            \"real_estate\",\n            \"retail_wholesale\",\n            \"technology\"\n          ]\n        },\n        {\n          \"name\": \"time_from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start time in YYYYMMDDTHHMM format (e.g., 20220410T0130).\"\n          }\n        },\n        {\n          \"name\": \"time_to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End time in YYYYMMDDTHHMM format.\"\n          }\n        },\n        {\n          \"name\": \"sort\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Sorting method for results.\"\n          },\n          \"enum\": [\n            \"LATEST\",\n            \"EARLIEST\",\n            \"RELEVANCE\"\n          ]\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Maximum number of results (up to 1000).\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"function\": \"NEWS_SENTIMENT\"\n        }\n      },\n      \"provider_description\": \"Alpha Vantage provides realtime and historical financial market data through a set of powerful and developer-friendly data APIs and spreadsheets. From traditional asset classes (e.g., stocks, ETFs, mutual funds) to economic indicators, from foreign exchange rates to commodities, from fundamental data to technical indicators, Alpha Vantage is your one-stop-shop for enterprise-grade global market data delivered through cloud-based APIs, MCP servers, spreadsheets, and more.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 520.43,\n        \"success_rate\": 0.987\n      }\n    },\n    {\n      \"tool_id\": \"alphavantage.news_sentiment.retrieve.v1.7aca3c4a\",\n      \"name\": \"Retrieve Market News & Sentiment\",\n      \"description\": \"Returns live and historical market news & sentiment data from premier news outlets around the world, covering stocks, cryptocurrencies, forex, and various financial topics.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The function name.\"\n          },\n          \"enum\": [\n            \"NEWS_SENTIMENT\"\n          ]\n        },\n        {\n          \"name\": \"tickers\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of stock/crypto/forex symbols (e.g., COIN,CRYPTO:BTC,FOREX:USD). Filters articles that mention all listed tickers.\"\n          }\n        },\n        {\n          \"name\": \"topics\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of topics. Articles must cover all listed topics.\"\n          },\n          \"enum\": [\n            \"blockchain\",\n            \"earnings\",\n            \"ipo\",\n            \"mergers_and_acquisitions\",\n            \"financial_markets\",\n            \"economy_fiscal\",\n            \"economy_monetary\",\n            \"economy_macro\",\n            \"energy_transportation\",\n            \"finance\",\n            \"life_sciences\",\n            \"manufacturing\",\n            \"real_estate\",\n            \"retail_wholesale\",\n            \"technology\"\n          ]\n        },\n        {\n          \"name\": \"time_from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start time in YYYYMMDDTHHMM format (e.g., 20220410T0130).\"\n          }\n        },\n        {\n          \"name\": \"time_to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End time in YYYYMMDDTHHMM format.\"\n          }\n        },\n        {\n          \"name\": \"sort\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Sorting method.\"\n          },\n          \"enum\": [\n            \"LATEST\",\n            \"EARLIEST\",\n            \"RELEVANCE\"\n          ]\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Maximum number of results (up to 1000).\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"function\": \"NEWS_SENTIMENT\"\n        }\n      },\n      \"provider_description\": \"Alpha Vantage provides realtime and historical financial market data through a set of powerful and developer-friendly data APIs and spreadsheets. From traditional asset classes (e.g., stocks, ETFs, mutual funds) to economic indicators, from foreign exchange rates to commodities, from fundamental data to technical indicators, Alpha Vantage is your one-stop-shop for enterprise-grade global market data delivered through cloud-based APIs, MCP servers, spreadsheets, and more.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 660.49,\n        \"success_rate\": 0.973\n      }\n    },\n    {\n      \"tool_id\": \"eodhd.sentiments.retrieve.v1.c2c27d35\",\n      \"name\": \"Retrieve Sentiment Data\",\n      \"description\": \"Get sentiment scores for one or more financial instruments (stocks, ETFs, crypto) calculated from news and social media, normalized on a scale from -1 (very negative) to 1 (very positive).\",\n      \"params\": [\n        {\n          \"name\": \"s\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"One or more comma-separated tickers, for example: AAPL.US,BTC-USD.CC\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start date for filtering sentiment data (YYYY-MM-DD)\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End date for filtering sentiment data (YYYY-MM-DD)\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"s\": \"AAPL.US,BTC-USD.CC\"\n        }\n      },\n      \"provider_description\": \"Access historical end-of-day stock prices, intraday data, US stock options, and real-time prices with free and advanced plans. EODHD provides financial data for 150,000+ tickers, including stocks, ETFs, funds, and currencies worldwide.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1278.53,\n        \"success_rate\": 0.999\n      }\n    },\n    {\n      \"tool_id\": \"eodhd.news.retrieve.v1.fe8bf94c\",\n      \"name\": \"Retrieve Financial News\",\n      \"description\": \"Returns the latest financial news headlines and full articles for a given ticker symbol or topic tag. Requires either a ticker (s) or a tag (t). Supports filtering by date, pagination, and JSON response format.\",\n      \"params\": [\n        {\n          \"name\": \"s\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The ticker code to retrieve news for, for example: AAPL.US\"\n          }\n        },\n        {\n          \"name\": \"t\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The topic tag to retrieve news for, for example: technology\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start date for filtering news (YYYY-MM-DD)\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End date for filtering news (YYYY-MM-DD)\"\n          }\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Number of results to return (default: 50, minimum: 1, maximum: 1000)\"\n          }\n        },\n        {\n          \"name\": \"offset\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Offset for pagination (default: 0)\"\n          }\n        },\n        {\n          \"name\": \"fmt\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Response format, either json or xml (default: json)\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {}\n      },\n      \"provider_description\": \"Access historical end-of-day stock prices, intraday data, US stock options, and real-time prices with free and advanced plans. EODHD provides financial data for 150,000+ tickers, including stocks, ETFs, funds, and currencies worldwide.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1.183,\n        \"success_rate\": 0.741\n      }\n    },\n    {\n      \"tool_id\": \"alphavantage.news_sentiment.query.v1.467a92c0\",\n      \"name\": \"Market News & Sentiment Trending\",\n      \"description\": \"This API returns live and historical market news & sentiment data from a large & growing selection of premier news outlets around the world, covering stocks, cryptocurrencies, forex, and a wide range of topics such as fiscal policy, mergers & acquisitions, IPOs, etc.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The function of your choice. In this case, function=NEWS_SENTIMENT\"\n          },\n          \"enum\": [\n            \"NEWS_SENTIMENT\"\n          ]\n        },\n        {\n          \"name\": \"tickers\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The stock/crypto/forex symbols of your choice. For example: tickers=IBM will filter for articles that mention the IBM ticker; tickers=COIN,CRYPTO:BTC,FOREX:USD will filter for articles that simultaneously mention Coinbase (COIN), Bitcoin (CRYPTO:BTC), and US Dollar (FOREX:USD) in their content.\"\n          }\n        },\n        {\n          \"name\": \"topics\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The news topics of your choice. For example: topics=technology will filter for articles that write about the technology sector; topics=technology,ipo will filter for articles that simultaneously cover technology and IPO in their content. Below is the full list of supported topics: Blockchain: blockchain, Earnings: earnings, IPO: ipo, Mergers & Acquisitions: mergers_and_acquisitions, Financial Markets: financial_markets, Economy - Fiscal Policy (e.g., tax reform, government spending): economy_fiscal, Economy - Monetary Policy (e.g., interest rates, inflation): economy_monetary, Economy - Macro/Overall: economy_macro, Energy & Transportation: energy_transportation, Finance: finance, Life Sciences: life_sciences, Manufacturing: manufacturing, Real Estate & Construction: real_estate, Retail & Wholesale: retail_wholesale, Technology: technology.\"\n          }\n        },\n        {\n          \"name\": \"time_from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The time range of the news articles you are targeting, in YYYYMMDDTHHMM format. For example: time_from=20220410T0130. If time_from is specified but time_to is missing, the API will return articles published between the time_from value and the current time.\"\n          }\n        },\n        {\n          \"name\": \"time_to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The time range of the news articles you are targeting, in YYYYMMDDTHHMM format.\"\n          }\n        },\n        {\n          \"name\": \"sort\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"By default, sort=LATEST and the API will return the latest articles first. You can also set sort=EARLIEST or sort=RELEVANCE based on your use case.\"\n          },\n          \"enum\": [\n            \"LATEST\",\n            \"EARLIEST\",\n            \"RELEVANCE\"\n          ]\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"By default, limit=50 and the API will return up to 50 matching results. You can also set limit=1000 to output up to 1000 results.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"function\": \"NEWS_SENTIMENT\"\n        }\n      },\n      \"provider_description\": \"Alpha Vantage provides realtime and historical financial market data through a set of powerful and developer-friendly data APIs and spreadsheets. From traditional asset classes (e.g., stocks, ETFs, mutual funds) to economic indicators, from foreign exchange rates to commodities, from fundamental data to technical indicators, Alpha Vantage is your one-stop-shop for enterprise-grade global market data delivered through cloud-based APIs, MCP servers, spreadsheets, and more.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 883.34,\n        \"success_rate\": 0.946\n      }\n    },\n    {\n      \"tool_id\": \"qveris_finance.finance_news_aggregation_v1\",\n      \"name\": \"Finance News Aggregation\",\n      \"description\": \"Search and aggregate financial news from multiple sources\",\n      \"params\": [\n        {\n          \"name\": \"query\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Search query for financial news\"\n          }\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Maximum number of results to return\"\n          }\n        }\n      ],\n      \"provider_description\": \"Provider for finance-related skills\",\n      \"skill_type\": \"aggregation\"\n    },\n    {\n      \"tool_id\": \"finnhub.stock.recommendation.retrieve.v1.c29836a7\",\n      \"name\": \"Recommendation Trends\",\n      \"description\": \"Get latest analyst recommendation trends for a company.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Symbol of the company: AAPL.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"AAPL\"\n        }\n      },\n    