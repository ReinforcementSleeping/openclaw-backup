{"type":"message","id":"705659f0","parentId":"c3532321","timestamp":"2026-03-03T12:32:31.379Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"这可能是qveris脚本的bug。让我直接用curl调用QVeris API试试。或者，也许问题在于参数格式。让我先查看脚本看看它期望什么格式。","thinkingSignature":"ed4db38240a5ecfe1683322de05d21245e6e876ffe8a88a69e672f7aa85f2aef"},{"type":"toolCall","id":"call_function_3iqh83x1qp9o_1","name":"read","arguments":{"file_path":"~/.openclaw/workspace/scripts/qveris_tool.mjs","limit":100}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":9717,"output":84,"cacheRead":13984,"cacheWrite":0,"totalTokens":23785,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772541147800}}
{"type":"message","id":"b4f943db","parentId":"705659f0","timestamp":"2026-03-03T12:32:31.381Z","message":{"role":"toolResult","toolCallId":"call_function_3iqh83x1qp9o_1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env node\n\nconst API_BASE = 'https://qveris.ai/api/v1';\nconst API_KEY = process.env.QVERIS_API_KEY;\n\nasync function search(query, limit = 10) {\n  const res = await fetch(`${API_BASE}/search`, {\n    method: 'POST',\n    headers: {\n      'Content-Type': 'application/json',\n      'Authorization': `Bearer ${API_KEY}`\n    },\n    body: JSON.stringify({ query, limit })\n  });\n  const data = await res.json();\n  return data;\n}\n\nasync function execute(toolId, params, searchId = null) {\n  const res = await fetch(`${API_BASE}/tools/execute`, {\n    method: 'POST',\n    headers: {\n      'Content-Type': 'application/json',\n      'Authorization': `Bearer ${API_KEY}`\n    },\n    body: JSON.stringify({ tool_id: toolId, params, search_id: searchId })\n  });\n  const data = await res.json();\n  return data;\n}\n\nasync function getByIds(...ids) {\n  const res = await fetch(`${API_BASE}/tools/get-by-ids`, {\n    method: 'POST',\n    headers: {\n      'Content-Type': 'application/json',\n      'Authorization': `Bearer ${API_KEY}`\n    },\n    body: JSON.stringify({ ids })\n  });\n  const data = await res.json();\n  return data;\n}\n\nconst cmd = process.argv[2];\nconst args = process.argv.slice(3);\n\nasync function main() {\n  try {\n    if (cmd === 'search') {\n      const query = args[0];\n      const limit = args.includes('--limit') ? parseInt(args[args.indexOf('--limit') + 1]) : 10;\n      const result = await search(query, limit);\n      console.log(JSON.stringify(result, null, 2));\n    } else if (cmd === 'execute') {\n      const toolId = args[0];\n      const searchIdIdx = args.indexOf('--search-id');\n      const searchId = searchIdIdx > -1 ? args[searchIdIdx + 1] : null;\n      const paramsIdx = args.indexOf('--params');\n      const params = paramsIdx > -1 ? JSON.parse(args[paramsIdx + 1]) : {};\n      const result = await execute(toolId, params, searchId);\n      console.log(JSON.stringify(result, null, 2));\n    } else if (cmd === 'get-by-ids') {\n      const result = await getByIds(...args.filter(a => !a.startsWith('--')));\n      console.log(JSON.stringify(result, null, 2));\n    } else {\n      console.error('Unknown command:', cmd);\n      process.exit(1);\n    }\n  } catch (err) {\n    console.error('Error:', err.message);\n    process.exit(1);\n  }\n}\n\nmain();\n"}],"isError":false,"timestamp":1772541151380}}
