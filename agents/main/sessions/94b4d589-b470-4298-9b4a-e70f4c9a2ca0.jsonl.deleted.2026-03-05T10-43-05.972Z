ch query.\",\n      \"params\": [\n        {\n          \"name\": \"country\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Country code, e.g. 'de'.\"\n          }\n        },\n        {\n          \"name\": \"category\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"News category, e.g. 'business'.\"\n          }\n        },\n        {\n          \"name\": \"q\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Search query, e.g. 'trump'.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"country\": \"us\"\n        }\n      },\n      \"provider_description\": \"A simple, easy-to-use REST API that returns JSON search results for current and historic news articles published by over 150,000 worldwide sources. Search through hundreds of millions of articles in 14 languages from 55 countries.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 5.457,\n        \"success_rate\": 0\n      }\n    },\n    {\n      \"tool_id\": \"nytimes.topstories.section.list.v2\",\n      \"name\": \"Top Stories by Section\",\n      \"description\": \"The Top Stories API returns an array of articles currently on the specified section.\",\n      \"params\": [\n        {\n          \"name\": \"section\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The section of top stories. Use 'home' to get articles currently on the homepage. Possible values: arts, automobiles, books/review, business, fashion, food, health, home, insider, magazine, movies, nyregion, obituaries, opinion, politics, realestate, science, sports, sundayreview, technology, theater, t-magazine, travel, upshot, us, world.\"\n          },\n          \"enum\": [\n            \"arts\",\n            \"automobiles\",\n            \"books/review\",\n            \"business\",\n            \"fashion\",\n            \"food\",\n            \"health\",\n            \"home\",\n            \"insider\",\n            \"magazine\",\n            \"movies\",\n            \"nyregion\",\n            \"obituaries\",\n            \"opinion\",\n            \"politics\",\n            \"realestate\",\n            \"science\",\n            \"sports\",\n            \"sundayreview\",\n            \"technology\",\n            \"theater\",\n            \"t-magazine\",\n            \"travel\",\n            \"upshot\",\n            \"us\",\n            \"world\"\n          ]\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"section\": \"arts\"\n        }\n      },\n      \"provider_description\": \"API provider for New York Times\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 381.88,\n        \"success_rate\": 0.899\n      }\n    },\n    {\n      \"tool_id\": \"coingecko.search.trending.retrieve.v3.548c6bf0\",\n      \"name\": \"Trending Search List\",\n      \"description\": \"This endpoint allows you **query trending search coins, NFTs and categories on CoinGecko in the last 24 hours**\",\n      \"provider_description\": \"CoinGecko API provides onchain DEX data across 250+ blockchain networks, 1,700+ decentralized exchanges (DEXes), and 15M+ tokens, powered by GeckoTerminal. It offers price feeds, market data, metadata, and historical data of crypto assets, NFTs, and exchanges. Includes WebSocket API for real-time data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 0,\n        \"success_rate\": 0\n      }\n    },\n    {\n      \"tool_id\": \"dataforseo.keywords_data.google_trends.explore.task_post.create.v3.edeec36e\",\n      \"name\": \"Setting ‘Google Trends Explore’ Tasks\",\n      \"description\": \"This endpoint will provide you with the keyword popularity data from the ‘Explore’ feature of Google Trends. You 