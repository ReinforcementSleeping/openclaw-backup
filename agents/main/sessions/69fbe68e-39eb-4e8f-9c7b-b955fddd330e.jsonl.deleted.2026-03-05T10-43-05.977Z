ription\": {\n            \"en\": \"This parameter can be 1 of the following values <code>general, forex, crypto, merger</code>.\"\n          }\n        },\n        {\n          \"name\": \"minId\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Use this field to get only news after this ID. Default to 0\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"category\": \"general\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1283.49,\n        \"success_rate\": 0.762\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.news.retrieve.v1\",\n      \"name\": \"Market News\",\n      \"description\": \"Get latest market news.\",\n      \"params\": [\n        {\n          \"name\": \"category\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"This parameter can be 1 of the following values <code>general, forex, crypto, merger</code>.\"\n          }\n        },\n        {\n          \"name\": \"minId\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Use this field to get only news after this ID. Default to 0\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"category\": \"general\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 769.91,\n        \"success_rate\": 0.986\n      }\n    }\n  ],\n  \"search_id\": \"31d6b8a9-a716-4033-9761-16ad716b775c\",\n  \"elapsed_time_ms\": 250.