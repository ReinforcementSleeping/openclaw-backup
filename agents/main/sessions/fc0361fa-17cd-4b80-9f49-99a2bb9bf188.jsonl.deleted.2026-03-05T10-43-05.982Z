": \"string\",\n          \"required\": true,\n          \"description\": \"Year, e.g., '2024'\"\n        },\n        {\n          \"name\": \"period\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Reporting period: '0331' (Q1), '0630' (H1), '0930' (Q3), '1231' (Annual)\"\n        },\n        {\n          \"name\": \"type\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Report type: '1' (Consolidated), '2' (Parent Company), '3' (Consolidated Adjusted), '4' (Parent Company Adjusted)\"\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"type\": \"1\",\n          \"year\": \"2024\",\n          \"codes\": \"300033.SZ,600030.SH\",\n          \"period\": \"1231\"\n        }\n      },\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 658.95,\n        \"success_rate\": 0.9\n      }\n    },\n    {\n      \"tool_id\": \"ths_ifind.code_converter.v1\",\n      \"name\": \"iFinD 同花顺证券代码转换 (THS Security Code Converter)\",\n      \"description\": \"Convert security codes or security names to 同花顺 (THS) standard code format. Supports querying by security code or security name, can specify security type and market, supports exact match or fuzzy match. Returns converted THS codes and related security information.\",\n      \"params\": [\n        {\n          \"name\": \"seccode\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Security code, e.g., '000001'. Either seccode or secname\"\n        },\n        {\n          \"name\": \"secname\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Security name, e.g., '平安银行'. Either seccode or secname\"\n        },\n        {\n          \"name\": \"mode\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Query mode: 'seccode' (query by code) or 'secname' (query by name)\"\n        },\n        {\n          \"name\": \"sectype\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Security type, e.g., '001' (stock), default is empty (query all types)\"\n        },\n        {\n          \"name\": \"market\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Market code, e.g., '212001' (SSE), '212100' (SZSE), default is empty (query all markets)\"\n        },\n        {\n          \"name\": \"tradestatus\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Trading status: '0' (normal trading), '1' (suspended), '2' (all), default is '0'\"\n        },\n        {\n          \"name\": \"isexact\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Exact match: '1' (exact match), '0' (fuzzy match), default is '1'\"\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"mode\": \"seccode\",\n          \"seccode\": \"000001\"\n        }\n      },\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 582.28,\n        \"success_rate\": 0.98\n      }\n    },\n    {\n      \"tool_id\": \"nbsc_data.carbonate).(sodium.soda.v2.A03010K\",\n      \"name\": \"National Quarterly Data Soda Ash (sodium Carbonate)\",\n      \"description\": \"Query National Quarterly Data Soda Ash (sodium Carbonate) statistical data from the National Bureau of Statistics of China. Data source: National quarterly data. Provides demographic statistics including population counts, birth rates, and age structure. Data available for periods 2019B to 2020B.\",\n      \"params\": [\n        {\n          \"name\": \"m\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"API method name. Valid values: \\\"QueryData\\\" - queries statistical data from the database.\",\n            \"zh\": \"API方法名称。有效值：\\\"QueryData\\\" - 从数据库查询统计数据。\"\n          },\n          \"enum\": [\n            \"QueryData\"\n          ]\n        },\n        {\n          \"name\": \"dbcode\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Database code specifying the data type and granularity. Valid values: \\\"hgjd\\\" - national quarterly data.\",\n            \"zh\": \"数据库代码，指定数据类型和粒度。有效值：\\\"hgjd\\\" - 全国季度数据。\"\n          },\n          \"enum\": [\n            \"hgjd\"\n          ]\n        },\n        {\n          \"name\": \"rowcode\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Row dimension code specifying what appears in rows. Valid values: \\\"zb\\\" - indicators (statistical metrics), \\\"sj\\\" - time periods (years, quarters, months), \\\"reg\\\" - regions (provinces, cities).\",\n            \"zh\": \"行维度代码，指定行中显示的内容。有效值：\\\"zb\\\" - 指标（统计指标），\\\"sj\\\" - 时间（年、季度、月），\\\"reg\\\" - 地区（省、市）。\"\n          },\n          \"enum\": [\n            \"zb\",\n            \"sj\",\n            \"reg\"\n          ]\n        },\n        {\n          \"name\": \"colcode\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Column dimension code specifying what appears in columns. Valid values: \\\"zb\\\" - indicators (statistical metrics), \\\"sj\\\" - time periods (years, quarters, months), \\\"reg\\\" - regions (provinces, cities).\",\n            \"zh\": \"列维度代码，指定列中显示的内容。有效值：\\\"zb\\\" - 指标（统计指标），\\\"sj\\\" - 时间（年、季度、月），\\\"reg\\\" - 地区（省、市）。\"\n          },\n          \"enum\": [\n            \"zb\",\n            \"sj\",\n            \"reg\"\n          ]\n        },\n        {\n          \"name\": \"wds\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Fixed WHERE dimensions as a JSON array string. Used for additional filtering conditions. Typically use \\\"[]\\\" for empty (no additional filters).\",\n            \"zh\": \"固定WHERE维度，JSON数组字符串。用于附加筛选条件。通常使用\\\"[]\\\"表示空（无附加筛选）。\"\n          }\n        },\n        {\n          \"name\": \"dfwds\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Default WHERE dimensions as a JSON array string. Specifies the main filter criteria. For this indicator, use: [{\\\"wdcode\\\":\\\"zb\\\",\\\"valuecode\\\":\\\"A03010K\\\"}] to query by indicator code, or add [{\\\"wdcode\\\":\\\"sj\\\",\\\"valuecode\\\":\\\"YYYY\\\"}] to filter by specific year.\",\n            \"zh\": \"默认WHERE维度，JSON数组字符串。指定主要筛选条件。对于此指标，使用：[{\\\"wdcode\\\":\\\"zb\\\",\\\"valuecode\\\":\\\"A03010K\\\"}] 按指标代码查询，或添加 [{\\\"wdcode\\\":\\\"sj\\\",\\\"valuecode\\\":\\\"YYYY\\\"}] 按特定年份筛选。\"\n          }\n        },\n        {\n          \"name\": \"k1\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Timestamp in milliseconds. Used to prevent response caching. Optional - can be omitted or set to current timestamp in milliseconds.\",\n            \"zh\": \"时间戳（毫秒）。用于防止响应缓存。可选 - 可以省略或设置为当前时间戳（毫秒）。\"\n          }\n        },\n        {\n          \"name\": \"h\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Optional parameter, typically set to \\\"1\\\". Can be omitted.\",\n            \"zh\": \"可选参数，通常设置为\\\"1\\\"。可以省略。\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"m\": \"QueryData\",\n          \"k1\": \"1766394243735\",\n          \"wds\": \"[]\",\n          \"dfwds\": \"[{\\\"wdcode\\\": \\\"zb\\\", \\\"valuecode\\\": \\\"A03010K\\\"}]\",\n          \"dbcode\": \"hgjd\",\n          \"colcode\": \"sj\",\n          \"rowcode\": \"zb\"\n        }\n      },\n      \"provider_description\": \"Data from the National Bureau of Statistics of China (NBSC). This provider offers comprehensive access to official Chinese economic and social statistics data including GDP, population, employment, prices, trade, and more. All data is sourced directly from the official National Bureau of Statistics of China website. The API provides annual, quarterly, and monthly data covering various economic indicators. Data includes national statistics, provincial statistics, major cities data, and Hong Kong, Macao, Taiwan data. No authentication is required to access the public statistics data. This provider includes 107 tools covering different statistical indicators from multiple data sources.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 896.74,\n        \"success_rate\": 1\n      }\n    }\n  ],\n  \"search_id\": \"7f03d17f-27ba-4463-9f24-827d268d9642\",\n  \"elapsed_time_ms\": 197.94\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":5792,"aggregated":"{\n  \"query\": \"a-shares stock quotes china\",\n  \"total\": 10,\n  \"results\": [\n    {\n      \"tool_id\": \"ths_ifind.hk_connect_stats.v1\",\n      \"name\": \"iFinD 沪深港通交易统计 (HK Stock Connect Trading Stats)\",\n      \"description\": \"Query Shanghai-Shenzhen-Hong Kong Stock Connect trading statistics from 同花顺 (THS) iFinD database. Covers northbound (沪股通, 深股通) and southbound (港股通沪市, 港股通深市) channels. Returns trading volume, buy/sell amounts, net buy amount, transaction counts, and top-10 active stocks concentration ratios. Supports daily, weekly, monthly, and yearly aggregation. Useful for tracking cross-border capital flows between mainland China and Hong Kong markets.\",\n      \"params\": [\n        {\n          \"name\": \"sdate\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Start date. Supported formats: 'YYYY-MM-DD', 'YYYY/MM/DD', 'YYYYMMDD'.\"\n        },\n        {\n          \"name\": \"edate\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"End date. Supported formats: 'YYYY-MM-DD', 'YYYY/MM/DD', 'YYYYMMDD'.\"\n        },\n        {\n          \"name\": \"zq\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Aggregation period. Valid values: 'day', 'week', 'month', 'year'. Defaults to 'week'.\"\n        },\n        {\n          \"name\": \"lx\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Channel type filter. 'ALL'=all channels, '1'=沪股通, '2'=港股通(沪市), '3'=深股通, '4'=港股通(深市). Defaults to 'ALL'.\"\n        },\n        {\n          \"name\": \"bz\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Currency for amounts. Defaults to 'CNY'.\"\n        }\n      ],\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\",\n      \"stats\": {\n  