ealtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 783.81,\n        \"success_rate\": 0.931\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.stock.marketstatus.retrieve.v1.20b47b4f\",\n      \"name\": \"Market Status\",\n      \"description\": \"Get current market status for global exchanges (whether exchanges are open or close).\",\n      \"params\": [\n        {\n          \"name\": \"exchange\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Exchange code.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"exchange\": \"US\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 828.9,\n        \"success_rate\": 0.993\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.stock.marketstatus.retrieve.v1.4d8383b5\",\n      \"name\": \"Market Status\",\n      \"description\": \"Get current market status for global exchanges (whether exchanges are open or close).\",\n      \"params\": [\n        {\n          \"name\": \"exchange\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Exchange code.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"exchange\": \"US\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 2099.32,\n        \"success_rate\": 0.992\n      }\n    },\n    {\n      \"tool_id\": \"ths_ifind.real_time_quotation.v1\",\n      \"