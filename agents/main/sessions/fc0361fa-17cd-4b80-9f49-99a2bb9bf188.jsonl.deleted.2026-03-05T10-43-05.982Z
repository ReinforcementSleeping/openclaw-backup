rue,\n          \"description\": {\n            \"en\": \"This parameter can be 1 of the following values <code>general, forex, crypto, merger</code>.\"\n          }\n        },\n        {\n          \"name\": \"minId\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Use this field to get only news after this ID. Default to 0\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"category\": \"general\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1283.49,\n        \"success_rate\": 0.762\n      }\n    }\n  ],\n  \"search_id\": \"3429e9d6-78a3-4b16-a23a-3710e0e87a71\",\n  \"elapsed_time_ms\": 200.24\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":5745,"aggregated":"{\n  \"query\": \"realtime stock price API Asia\",\n  \"total\": 10,\n  \"results\": [\n    {\n      \"tool_id\": \"eodhd.live_prices.retrieve.v1.178541d4\",\n      \"name\": \"Live (Delayed) Stock Prices\",\n      \"description\": \"Retrieve live or delayed stock prices and macroeconomic data.\",\n      \"params\": [\n        {\n          \"name\": \"ticker\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Ticker symbol with exchange suffix (e.g., AAPL.US).\"\n          }\n        },\n        {\n          \"name\": \"s\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Optional filter parameter.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"ticker\": \"AAPL.US\"\n        }\n      },\n      \"provider_description\": \"Access historical end-of-day stock prices, intraday data, US st