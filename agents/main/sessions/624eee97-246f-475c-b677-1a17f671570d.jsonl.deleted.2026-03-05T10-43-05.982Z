"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The function name.\"\n          },\n          \"enum\": [\n            \"NEWS_SENTIMENT\"\n          ]\n        },\n        {\n          \"name\": \"tickers\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of stock/crypto/forex symbols (e.g., COIN,CRYPTO:BTC,FOREX:USD). Filters articles that mention all listed tickers.\"\n          }\n        },\n        {\n          \"name\": \"topics\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of topics. Articles must cover all listed topics.\"\n          },\n          \"enum\": [\n            \"blockchain\",\n            \"earnings\",\n            \"ipo\",\n            \"mergers_and_acquisitions\",\n            \"financial_markets\",\n            \"economy_fiscal\",\n            \"economy_monetary\",\n            \"economy_macro\",\n            \"energy_transportation\",\n            \"finance\",\n            \"life_sciences\",\n            \"manufacturing\",\n            \"real_estate\",\n            \"retail_wholesale\",\n            \"technology\"\n          ]\n        },\n        {\n          \"name\": \"time_from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start time in YYYYMMDDTHHMM format (e.g., 20220410T0130).\"\n          }\n        },\n        {\n          \"name\": \"time_to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End time in YYYYMMDDTHHMM format.\"\n          }\n        },\n        {\n          \"name\": \"sort\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Sorting 