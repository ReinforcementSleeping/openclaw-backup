"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"To date <code>YYYY-MM-DD</code>.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"to\": \"2023-01-31\",\n          \"from\": \"2023-01-01\",\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 878.52,\n        \"success_rate\": 0.998\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.companynews.execute.v1\",\n      \"name\": \"Company News\",\n      \"description\": \"List latest company news by symbol. This endpoint is only available for North American companies.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Company symbol.\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"From date <code>YYYY-MM-DD</code>.\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"To date <code>YYYY-MM-DD</code>.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"to\": \"2025-11-24\",\n          \"from\": \"2025-11-17\",\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 556.19,\n        \"success_rate\": 0.766\n      }\n    }\n  ],\n  \"search_id\": \"cc143105-f780-4d2a-8bd3-fa7deb4b2567\",\n  \"elapsed_time_ms\": 315.16\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":5960,"aggregated":"{\n  \"query\": \"finnhub stock buzz\",\n  \"total\": 5,\n  \"results\": [\n    {\n      \"tool_id\": \"finnhub.stock.financialsreported.retrieve.v1.6cea1d1e\",\n      \"name\": \"Financials As Reported\",\n      \"description\": \"Get financials as reported. This data is available for bulk download on <a href=\\\"https://www.kaggle.com/finnhub/reported-financials\\\" target=\\\"_blank\\\">Kaggle SEC Financials database</a>.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Symbol.\"\n          }\n        },\n        {\n          \"name\": \"cik\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"CIK.\"\n          }\n        },\n        {\n          \"name\": \"accessNumber\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Access number of a specific report you want to retrieve financials from.\"\n          }\n        },\n        {\n          \"name\": \"freq\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Frequency. Can be either <code>annual</code> or <code>quarterly</code>. Default to <code>annual</code>.\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"From date <code>YYYY-MM-DD</code>. Filter for endDate.\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"To date <code>YYYY-MM-DD</code>. Filter for endDate.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"freq\": \"annual\",\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 557.65,\n        \"success_rate\": 0.951\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.companynews.retrieve.v1\",\n      \"name\": \"Company News\",\n      \"description\": \"List latest company news by symbol. This endpoint is only available for North American companies.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Company symbol.\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"From date <code>YYYY-MM-DD</code>.\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"To date <code>YYYY-MM-DD</code>.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"to\": \"2025-11-24\",\n          \"from\": \"2025-11-17\",\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 642.03,\n        \"success_rate\": 0.21\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.companynews.retrieve.v1.e428b704\",\n      \"name\": \"Company News\",\n      \"description\": \"List latest company news by symbol. This endpoint is only available for North American companies.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Company symbol.\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"From date <code>YYYY-MM-DD</code>.\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"To date <code>YYYY-MM-DD</code>.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"to\": \"2025-11-24\",\n          \"from\": \"2025-11-01\",\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1300.12,\n        \"success_rate\": 0.833\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.companynews.retrieve.v1.4d11f47b\",\n      \"name\": \"Company News\",\n      \"description\": \"List latest company news by symbol. This endpoint is only available for North American companies.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Company symbol.\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"From date <code>YYYY-MM-DD</code>.\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"To date <code>YYYY-MM-DD</code>.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"to\": \"2023-01-31\",\n          \"from\": \"2023-01-01\",\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 878.52,\n        \"success_rate\": 0.998\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.companynews.execute.v1\",\n      \"name\": \"Company News\",\n      \"description\": \"List latest company news by symbol. This endpoint is only available for North American companies.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Company symbol.\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"From date <code>YYYY-MM-DD</code>.\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"To date <code>YYYY-MM-DD</code>.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"to\": \"2025-11-24\",\n          \"from\": \"2025-11-17\",\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 556.19,\n        \"success_rate\": 0.766\n      }\n    }\n  ],\n  \"search_id\": \"cc143105-f780-4d2a-8bd3-fa7deb4b2567\",\n  \"elapsed_tim