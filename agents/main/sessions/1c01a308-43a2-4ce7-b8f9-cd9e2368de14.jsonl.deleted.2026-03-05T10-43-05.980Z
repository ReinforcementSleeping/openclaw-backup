section\": \"arts\"\n        }\n      },\n      \"provider_description\": \"API provider for New York Times\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 376.89,\n        \"success_rate\": 0.91\n      }\n    },\n    {\n      \"tool_id\": \"hackernews.top_stories_get.v1\",\n      \"name\": \"hackernews.top_stories_get\",\n      \"description\": \"Fetch the top stories from HackerNews.\",\n      \"provider_description\": \"Hacker News is a social news website focusing on computer science and entrepreneurship, run by Y Combinator. This API allows you to fetch top stories, new stories, ask stories, show stories, and job postings from Hacker News.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 495.9,\n        \"success_rate\": 1\n      }\n    },\n    {\n      \"tool_id\": \"newsapi.top_headlines.list.v2.38face94\",\n      \"name\": \"Top Headlines\",\n      \"description\": \"Retrieve top headlines filtered by country, category, or search query.\",\n      \"params\": [\n        {\n          \"name\": \"country\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Country code, e.g. 'de'.\"\n          }\n        },\n        {\n          \"name\": \"category\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"News category, e.g. 'business'.\"\n          }\n        },\n        {\n          \"name\": \"q\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Search query, e.g. 'trump'.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"country\": \"us\"\n        }\n      },\n      \"provider_description\": \"A simple, easy-to-use REST API that returns JSON search results for current and historic news articles published by over 150,000 worldwide sources. Search through hundreds of millions of articles in 14 languages from 55 countries.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 466.44,\n        \"success_rate\": 0.956\n      }\n    },\n    {\n      \"tool_id\": \"coingecko.search.trending.retrieve.v3.548c6bf0\",\n      \"name\": \"Trending Search List\",\n      \"description\": \"This endpoint allows you **query trending search coins, NFTs and categories on CoinGecko in the last 24 hours**\",\n      \"provider_description\": \"CoinGecko API provides onchain DEX data across 250+ blockchain networks, 1,700+ decentralized exchanges (DEXes), and 15M+ tokens, powered by GeckoTerminal. It offers price feeds, market data, metadata, and historical data of crypto assets, NFTs, and exchanges. Includes WebSocket API for real-time data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 0,\n        \"success_rate\": 0\n      }\n    },\n    {\n      \"tool_id\": \"qveris_social.x_domain_new_posts_v1\",\n      \"name\": \"X Domain New Posts Today\",\n      \"description\": \"Search today's new posts from domain experts (KOLs) on X/Twitter with full fields: text, images, media, metrics. Supports AI, Finance, Crypto, Tech, Science.\",\n      \"params\": [\n        {\n          \"name\": \"domains\",\n          \"type\": \"array\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Domains to query\",\n            \"zh\": \"要查询的领域\"\n          },\n          \"enum\": [\n            \"AI\",\n            \"Finance\",\n            \"Crypto\",\n            \"Tech\",\n            \"Science\"\n          ]\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": null\n        }\n      ],\n      \"provider_description\": \"Social media monitoring and analysis skills\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 7737.01,\n        \"success_rate\": 1\n      },\n      \"skill_package_url\": \"https://qveris.ai/api/v1/skills/qve