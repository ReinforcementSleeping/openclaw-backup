ion\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1371.22,\n        \"success_rate\": 0.868\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.companynews.retrieve.v1\",\n      \"name\": \"Company News\",\n      \"description\": \"List latest company news by symbol. This endpoint is only available for North American companies.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Company symbol.\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"From date <code>YYYY-MM-DD</code>.\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"To date <code>YYYY-MM-DD</code>.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"to\": \"2025-11-24\",\n          \"from\": \"2025-11-17\",\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 642.03,\n        \"success_rate\": 0.21\n      }\n    }\n  ],\n  \"search_id\": \"93fbe312-3d03-4ec2-b9c5-6801941f4e89\",\n  \"elapsed_time_ms\": 182.71\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":5867,"aggregated":"{\n  \"query\": \"finnhub market news sentiment heat\",\n  \"total\": 10,\n  \"results\": [\n    {\n      \"tool_id\": \"alphavantage.news_sentiment.query.v1.7aca3c4a\",\n      \"name\": \"Market News & Sentimen