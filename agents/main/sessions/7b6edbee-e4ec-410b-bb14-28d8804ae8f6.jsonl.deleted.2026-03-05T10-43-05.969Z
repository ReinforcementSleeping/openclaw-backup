ub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\"\n    },\n    {\n      \"tool_id\": \"finnhub.companynews.execute.v1\",\n      \"name\": \"Company News\",\n      \"description\": \"List latest company news by symbol. This endpoint is only available for North American companies.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Company symbol.\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"From date <code>YYYY-MM-DD</code>.\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"To date <code>YYYY-MM-DD</code>.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"to\": \"2025-11-24\",\n          \"from\": \"2025-11-17\",\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 922.8,\n        \"success_rate\": 0.981\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.companynews.retrieve.v1\",\n      \"name\": \"Company News\",\n      \"description\": \"List latest company news by symbol. This endpoint is only available for North American companies.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Company symbol.\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"From date <code>YYYY-MM-DD</code>.\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"To date <code>YYYY-MM-DD</code>.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"to\": \"2025-11-24\",\n          \"from\": \"2025-11-17\",\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 634.97,\n        \"success_rate\": 0.463\n      }\n    },\n    {\n      \"tool_id\": \"eodhd.news.retrieve.v1.fe8bf94c\",\n      \"name\": \"Retrieve Financial News\",\n      \"description\": \"Returns the latest financial news headlines and full articles for a given ticker symbol or topic tag. Requires either a ticker (s) or a tag (t). Supports filtering by date, pagination, and JSON response format.\",\n      \"params\": [\n        {\n          \"name\": \"s\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The ticker code to retrieve news for, for example: AAPL.US\"\n          }\n        },\n        {\n          \"name\": \"t\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The topic tag to retrieve news for, for example: technology\"\n          }\n        },\n        {\n          \"name\": \"from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start date for filtering news (YYYY-MM-DD)\"\n          }\n        },\n        {\n          \"name\": \"to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End date for filtering news (YYYY-MM-DD)\"\n          }\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Number of results to return (default: 50, minimum: 1, maximum: 1000)\"\n          }\n        },\n        {\n          \"name\": \"offset\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Offset for pagination (default: 0)\"\n          }\n        },\n        {\n          \"name\": \"fmt\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Response format, either json or xml (default: json)\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {}\n      },\n      \"provider_description\": \"Access historical end-of-day stock prices, intraday data, US stock options, and real-time prices with free and advanced plans. EODHD provides financial data for 150,000+ tickers, including stocks, ETFs, funds, and currencies worldwide.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1.183,\n        \"success_rate\": 0.741\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.market.news.list.v1\",\n      \"name\": \"Market News\",\n      \"description\": \"Get latest market news.\",\n      \"params\": [\n        {\n          \"name\": \"category\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"News category. Available values: \\\\`general\\\\` \\\\`forex\\\\` \\\\`crypto\\\\` \\\\`merger\\\\`\"\n          },\n          \"enum\": [\n            \"general\",\n            \"forex\",\n            \"crypto\",\n            \"merger\"\n          ]\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"category\": \"general\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1.874,\n        \"success_rate\": 1\n      }\n    },\n    {\n      \"tool_id\": \"barchart.ondemand.news.query.v1.655e0a3e\",\n      \"name\": \"Query News Articles\",\n      \"description\": \"The getNews API returns news headlines, articles and related photos based upon news sources, category, sub-category and/or keyword. With this API you can access breaking news, company press releases and global financial market coverage.\",\n      \"params\": [\n        {\n          \"name\": \"sources\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The news feed code\"\n          },\n          \"enum\": [\n            \"AP\",\n            \"APAI\",\n            \"BC\",\n            \"BCNEWS\",\n            \"CP\",\n            \"CNW\",\n            \"CRB\",\n            \"CMTX\",\n            \"CMTX:PCS\",\n            \"CMTX:PCC\",\n            \"CMTX:SEC\",\n            \"IF\",\n            \"USDA\",\n            \"PRNW\",\n            \"ZACKS\",\n            \"BRUG\",\n            \"AGWEB\",\n            \"SETZ\",\n            \"SPC\",\n            \"NASS\",\n            \"ESTMZ\",\n            \"DVND\",\n            \"LME-WHS\",\n            \"DLFRX\",\n            \"GLDRPT\",\n            \"COT\",\n            \"MAX\",\n            \"CMDTY_AGLITE\",\n            \"CMDTY_AG\",\n            \"CMDTY_ENERGY\",\n            \"SYNDTGAM\",\n            \"FCTGAM\",\n            \"BCSYND\",\n            \"HDLNE\",\n            \"HDLNEG\",\n            \"HDLNEP\"\n          ]\n        },\n        {\n          \"name\": \"symbols\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n     