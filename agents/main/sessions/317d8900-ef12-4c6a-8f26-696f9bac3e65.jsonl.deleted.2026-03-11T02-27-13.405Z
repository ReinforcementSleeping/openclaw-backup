{"type":"message","id":"d1e8d56e","parentId":"5b63882f","timestamp":"2026-03-10T01:30:09.894Z","message":{"role":"toolResult","toolCallId":"call_function_2cxxr01yndmn_1","toolName":"web_search","content":[{"type":"text","text":"{\n  \"error\": \"missing_brave_api_key\",\n  \"message\": \"web_search needs a Brave Search API key. Run `openclaw configure --section web` to store it, or set BRAVE_API_KEY in the Gateway environment.\",\n  \"docs\": \"https://docs.openclaw.ai/tools/web\"\n}"}],"details":{"error":"missing_brave_api_key","message":"web_search needs a Brave Search API key. Run `openclaw configure --section web` to store it, or set BRAVE_API_KEY in the Gateway environment.","docs":"https://docs.openclaw.ai/tools/web"},"isError":false,"timestamp":1773106209892}}
