},\n        {\n          \"name\": \"time_to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End time in YYYYMMDDTHHMM format.\"\n          }\n        },\n        {\n          \"name\": \"sort\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Sorting method.\"\n          },\n          \"enum\": [\n            \"LATEST\",\n            \"EARLIEST\",\n            \"RELEVANCE\"\n          ]\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Maximum number of results (up to 1000).\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"function\": \"NEWS_SENTIMENT\"\n        }\n      },\n      \"provider_description\": \"Alpha Vantage provides realtime and historical financial market data through a set of powerful and developer-friendly data APIs and spreadsheets. From traditional asset classes (e.g., stocks, ETFs, mutual funds) to economic indicators, from foreign exchange rates to commodities, from fundamental data to technical indicators, Alpha Vantage is your one-stop-shop for enterprise-grade global market data delivered through cloud-based APIs, MCP servers, spreadsheets, and more.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 672.29,\n        \"success_rate\": 0.893\n      }\n    },\n    {\n      \"tool_id\": \"alphavantage.news_sentiment.query.v1.7aca3c4a\",\n      \"name\": \"Market News & Sentiment\",\n      \"description\": \"Returns live and historical market news & sentiment data from global news outlets covering stocks, crypto, forex, and economic topics.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The function to call. In this case, NEWS_SENTIMENT\"\n          },\n          \"enum\": [\n            \"NEWS_SENTIMENT\"\n          ]\n        },\n        {\n          \"name\": \"tickers\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of stock/crypto/forex symbols to filter articles by (e.g., AAPL,CRYPTO:BTC).\"\n          }\n        },\n        {\n          \"name\": \"topics\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of topics to filter by.\"\n          },\n          \"enum\": [\n            \"blockchain\",\n            \"earnings\",\n            \"ipo\",\n            \"mergers_and_acquisitions\",\n            \"financial_markets\",\n            \"economy_fiscal\",\n            \"economy_monetary\",\n            \"economy_macro\",\n            \"energy_transportation\",\n            \"finance\",\n            \"life_sciences\",\n            \"manufacturing\",\n            \"real_estate\",\n            \"retail_wholesale\",\n            \"technology\"\n          ]\n        },\n        {\n          \"name\": \"time_from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start time in YYYYMMDDTHHMM format (e.g., 20220410T0130).\"\n          }\n        },\n        {\n          \"name\": \"time_to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End time in YYYYMMDDTHHMM format.\"\n          }\n        },\n        {\n          \"name\": \"sort\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Sorting method for results.\"\n          },\n          \"enum\": [\n            \"LATEST\",\n            \"EARLIEST\",\n            \"RELEVANCE\"\n          ]\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Maximum number of results (up to 1000).\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"function\": \"NEWS_SENTIMENT\"\n        }\n      },\n      \"provider_description\": \"Alpha Vantage provides realtime and historical financial market data through a set of powerful and developer-friendly data APIs and spreadsheets. From traditional asset classes (e.g., stocks, ETFs, mutual funds) to economic indicators, from foreign exchange rates to commodities, from fundamental data to technical indicators, Alpha Vantage is your one-stop-shop for enterprise-grade global market data delivered through cloud-based APIs, MCP servers, spreadsheets, and more.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 538.66,\n        \"success_rate\": 0.734\n      }\n    },\n    {\n      \"tool_id\": \"coingecko.search.trending.retrieve.v3.548c6bf0\",\n      \"name\": \"Trending Search List\",\n      \"description\": \"This endpoint allows you **query trending search coins, NFTs and categories on CoinGecko in the last 24 hours**\",\n      \"provider_description\": \"CoinGecko API provides onchain DEX data across 250+ blockchain networks, 1,700+ decentralized exchanges (DEXes), and 15M+ tokens, powered by GeckoTerminal. It offers price feeds, market data, metadata, and historical data of crypto assets, NFTs, and exchanges. Includes WebSocket API for real-time data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 0,\n        \"success_rate\": 0\n      }\n    },\n    {\n      \"tool_id\": \"alphavantage.news_sentiment.query.v1.467a92c0\",\n      \"name\": \"Market News & Sentiment Trending\",\n      \"description\": \"This API returns live and historical market news & sentiment data from a large & growing selection of premier news outlets around the world, covering stocks, cryptocurrencies, forex, and a wide range of topics such as fiscal policy, mergers & acquisitions, IPOs, etc.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The function of your choice. In this case, function=NEWS_SENTIMENT\"\n          },\n          \"enum\": [\n            \"NEWS_SENTIMENT\"\n          ]\n        },\n        {\n          \"name\": \"tickers\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The stock/crypto/forex symbols of your choice. For example: tickers=IBM will filter for articles that mention the IBM ticker; tickers=COIN,CRYPTO:BTC,FOREX:USD will filter for articles that simultaneously mention Coinbase (COIN), Bitcoin (CRYPTO:BTC), and US Dollar (FOREX:USD) in their content.\"\n          }\n        },\n        {\n          \"name\": \"topics\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The news topics of your choice. For example: topics=technology will filter for articles that write about the technology sector; topics=technology,ipo will filter for articles that simultaneously cover technology and IPO in their content. Below is the full list of supported topics: Blockchain: blockchain, Earnings: earnings, IPO: ipo, Mergers & Acquisitions: mergers_and_acquisitions, Financial Markets: financial_markets, Economy - Fiscal Policy (e.g., tax reform, government spending): economy_fiscal, Economy - Monetary Policy (e.g., interest rates, inflation): economy_monetary, Economy - Macro/Overall: economy_macro, Energy & Transportation: energy_transportation, Finance: finance, Life Sciences: life_sciences, Manufacturing: manufacturing, Real Estate & Construction: real_estate, Retail & Wholesale: retail_wholesale, Technology: technology.\"\n          }\n        },\n        {\n          \"name\": \"time_from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The time range of the news articles you are targeting, in YYYYMMDDTHHMM format. For example: time_from=20220410T0130. If time_from is specified but time_to is missing, the API will return articles published between the time_from value and the current time.\"\n          }\n        },\n        {\n          \"name\": \"time_to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The time range of the news articles you are targeting, in YYYYMMDDTHHMM format.\"\n          }\n        },\n        {\n          \"name\": \"sort\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"By default, sort=LATEST and the API will return the latest articles first. You can also set sort=EARLIEST or sort=RELEVANCE based on your use case.\"\n          },\n          \"enum\": [\n            \"LATEST\",\n            \"EARLIEST\",\n            \"RELEVANCE\"\n          ]\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"By default, limit=50 and the API will return up to 50 matching results. You can also set limit=1000 to output up to 1000 results.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"function\": \"NEWS_SENTIMENT\"\n        }\n      },\n      \"provider_description\": \"Alpha Vantage provides realtime and historical financial market data through a set of powerful and developer-friendly data APIs and spreadsheets. From traditional asset classes (e.g., stocks, ETFs, mutual funds) to economic indicators, from foreign exchange rates to commodities, from fundamental data to technical indicators, Alpha Vantage is your one-stop-shop for enterprise-grade global market data delivered through cloud-based APIs, MCP servers, spreadsheets, and more.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 939.67,\n        \"success_rate\": 0.908\n      }\n    },\n    {\n      \"tool_id\": \"qveris_social.x_domain_hot_topics_v1\",\n      \"name\": \"X Domain Hot Topics Tracker\",\n      \"description\": \"Track and aggregate hot topics from domain experts (KOLs) on X/Twitter platform. Supports multiple domains: AI, Finance, Crypto, Tech, etc.\",\n      \"params\": [\n        {\n          \"name\": \"domains\",\n          \"type\": \"array\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"List of domains to query. Available: AI, Finance, Crypto, Tech, Science. If not specified, queries all domains.\",\n            \"zh\": \"要查询的领域列表。可选：AI、Finance、Crypto、Tech、Science。如不指定则查询所有领域。\"\n          },\n          \"enum\": [\n            \"AI\",\n            \"Finance\",\n            \"Crypto\",\n            \"Tech\",\n            \"Science\"\n          ]\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Maximum number of results to return per domain\",\n            \"zh\": \"每个领域返回结果的最大数量\"\n          }\n        },\n        {\n          \"name\": \"min_engagement\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Minimum engagement (likes + retweets + replies) for filtering posts\",\n            \"zh\": \"用于过滤的最小互动量（点赞+转发+回复）\"\n          }\n        }\n      ],\n      \"provider_description\": \"Social media monitoring and analysis skills\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 11206.49,\n        \"success_rate\": 1\n      },\n      \"skill_package_url\": \"https://qveris.ai/api/v1/skills/qveris_social.x_domain_hot_topics_v1/package\",\n      \"skill_type\": \"package\"\n    },\n    {\n      \"tool_id\": \"finnhub.news.retrieve.v1.2e72ea5d\",\n      \"name\": \"Market News\",\n      \"description\": \"Get latest market news.\",\n      \"params\": [\n        {\n          \"name\": \"category\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"This parameter can be 1 of the following values <code>general, forex, crypto, merger</code>.\"\n          }\n        },\n        {\n          \"name\": \"minId\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Use this field to get only news after this ID. Default to 0\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"category\": \"general\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1283.49,\n        \"success_rate\": 0.762\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.news.retrieve.v1\",\n      \"name\": \"Market News\",\n      \"description\": \"Get latest market news.\",\n      \"params\": [\n        {\n          \"name\": \"category\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"This parameter can be 1 of the following values <code>general, forex, crypto, merger</code>.\"\n          }\n        },\n        {\n          \"name\": \"minId\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Use this field to get only news after this ID. Default to 0\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"category\": \"general\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 769.91,\n        \"success_rate\": 0.986\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.news.retrieve.v1.51b2567e\",\n      \"name\": \"Market News\",\n      \"description\": \"Get latest market news.\",\n      \"params\": [\n        {\n          \"name\": \"category\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"This parameter can be 1 of the following values <code>general, forex, crypto, merger</code>.\"\n          }\n        },\n        {\n          \"name\": \"minId\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Use this field to get only news after this ID. Default to 0\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"category\": \"general\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 542.57,\n        \"success_rate\": 0.916\n      }\n    },\n    {\n      \"tool_id\": \"x_developer.2.trends.by.woeid.retrieve.v2.21f95686\",\n      \"name\": \"Get Trends by WOEID\",\n      \"description\": \"Retrieves trending topics for a specific location identified by its WOEID.\",\n      \"params\": [\n        {\n          \"name\": \"woeid\",\n          \"type\": \"integer\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The WOEID of the place to lookup a trend for.\"\n          }\n        },\n        {\n          \"name\": \"max_trends\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The maximum number of results.\"\n          }\n        },\n        {\n          \"name\": \"trend.fields\",\n          \"type\": \"array\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"A comma separated list of Trend fields to display.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"woeid\": 1\n        }\n      },\n      \"provider_description\": \"Use X API to fetch posts, users, trends, etc.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 731.12,\n        \"success_rate\": 0.223\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.stock.recommendation.retrieve.v1.b67c9ec5\",\n      \"name\": \"Recommendation Trends\",\n      \"description\": \"Get latest analyst recommendation trends for a company.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Symbol of the company: AAPL.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 767.91,\n        \"success_rate\": 0.487\n      }\n    }\n  ],\n  \"search_id\": \"328f08f2-0096-46ff-96bf-a8ae14755a61\",\n  \"elapsed_time_ms\": 516.19\n}","cwd":"/Users/lynch/.openclaw/workspace"},"isError":false,"timestamp":1772592125862}}
