   \"name\": \"Get Trends by WOEID\",\n      \"description\": \"Retrieves trending topics for a specific location identified by its WOEID.\",\n      \"params\": [\n        {\n          \"name\": \"woeid\",\n          \"type\": \"integer\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The WOEID of the place to lookup a trend for.\"\n          }\n        },\n        {\n          \"name\": \"max_trends\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The maximum number of results.\"\n          }\n        },\n        {\n          \"name\": \"trend.fields\",\n          \"type\": \"array\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"A comma separated list of Trend fields to display.\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"woeid\": 1\n        }\n      },\n      \"provider_description\": \"Use X API to fetch posts, users, trends, etc.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 731.12,\n        \"success_rate\": 0.223\n      }\n    },\n    {\n      \"tool_id\": \"qveris_social.x_account_hottest_post_v1\",\n      \"name\": \"X Account Hottest Post (7 Days)\",\n      \"description\": \"Return the single hottest post (by engagement) from a given X/Twitter account in the last 7 days.\",\n      \"params\": [\n        {\n          \"name\": \"username\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"X/Twitter username (without @)\",\n            \"zh\": \"X账号用户名（不含@）\"\n          }\n        },\n        {\n          \"name\": \"account\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Alias for username\",\n            \"zh\": \"同 username\"\n          }\n        }\n      ],\n      \"provider_description\": \"Social media monitoring and analysis skills\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 695.16,\n        \"success_rate\": 1\n      },\n      \"skill_package_url\": \"https://qveris.ai/api/v1/skills/qveris_social.x_account_hottest_post_v1/package\",\n      \"skill_type\": \"package\"\n    },\n    {\n      \"tool_id\": \"qveris_social.x_domain_hot_topics_v1\",\n      \"name\": \"X Domain Hot Topics Tracker\",\n      \"description\": \"Track and aggregate hot topics from domain experts (KOLs) on X/Twitter platform. Supports multiple domains: AI, Finance, Crypto, Tech, etc.\",\n      \"params\": [\n        {\n          \"name\": \"domains\",\n          \"type\": \"array\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"List of domains to query. Available: AI, Finance, Crypto, Tech, Science. If not specified, queries all domains.\",\n            \"zh\": \"要查询的领域列表。可选：AI、Finance、Crypto、Tech、Science。如不指定则查询所有领域。\"\n          },\n          \"enum\": [\n            \"AI\",\n            \"Finance\",\n            \"Crypto\",\n            \"Tech\",\n            \"Science\"\n          ]\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Maximum number of results to return per domain\",\n            \"zh\": \"每个领域返回结果的最大数量\"\n          }\n        },\n        {\n          \"name\": \"min_engagement\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Minimum engagement (likes + retweets + replies) for filtering posts\",\n            \"zh\": \"用于过滤的最小互动量（点赞+转发+回复）\"\n          }\n        }\n      ],\n      \"provider_description\": \"Social media monitoring and analysis skills\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 11206.49,\n        \"success_rate\": 1\n      },\n      \"skill_package_url\": \"https://qveris.ai/api/v1/skills/qveris_social.x_domain_hot_topics_v1/package\",\n      \"skill_type\": \"package\"\n    },\n    {\n      \"tool_id\": \"alphavantage.news_sentiment.query.v1.7aca3c4a\",\n      \"name\": \"Market News & Sentiment\",\n      \"description\": \"Returns live and historical market news & sentiment data from global news outlets covering stocks, crypto, forex, and economic topics.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The function to call. In this case, NEWS_SENTIMENT\"\n          },\n          \"enum\": [\n            \"NEWS_SENTIMENT\"\n          ]\n        },\n        {\n          \"name\": \"tickers\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of stock/crypto/forex symbols to filter articles by (e.g., AAPL,CRYPTO:BTC).\"\n          }\n        },\n        {\n          \"name\": \"topics\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of topics to filter by.\"\n          },\n          \"enum\": [\n            \"blockchain\",\n            \"earnings\",\n            \"ipo\",\n            \"mergers_and_acquisitions\",\n            \"financial_markets\",\n            \"economy_fiscal\",\n            \"economy_monetary\",\n            \"economy_macro\",\n            \"energy_transportation\",\n            \"finance\",\n            \"life_sciences\",\n            \"manufacturing\",\n            \"real_estate\",\n            \"retail_wholesale\",\n            \"technology\"\n          ]\n        },\n        {\n          \"name\": \"time_from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start time in YYYYMMDDTHHMM format (e.g., 20220410T0130).\"\n          }\n        },\n        {\n          \"name\": \"time_to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End time in YYYYMMDDTHHMM format.\"\n          }\n        },\n        {\n          \"name\": \"sort\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Sorting method for results.\"\n          },\n          \"enum\": [\n            \"LATEST\",\n            \"EARLIEST\",\n            \"RELEVANCE\"\n          ]\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Maximum number of results (up to 1000).\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"function\": \"NEWS_SENTIMENT\"\n        }\n      },\n      \"provider_description\": \"Alpha Vantage provides realtime and historical financial market data through a set of powerful and developer-friendly data APIs and spreadsheets. From traditional asset classes (e.g., stocks, ETFs, mutual funds) to economic indicators, from foreign exchange rates to commodities, from fundamental data to technical indicators, Alpha Vantage is your one-stop-shop for enterprise-grade global market data delivered through cloud-based APIs, MCP servers, spreadsheets, and more.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 538.66,\n        \"success_rate\": 0.734\n      }\n    },\n    {\n      \"tool_id\": \"qveris_social.x_domain_hot_events_v1\",\n      \"name\": \"X Domain Hot Events Today\",\n      \"description\": \"Summarize today's hot events on X/Twitter for a domain: fetch new posts then use LLM to summarize events and return event list with post ids.\",\n      \"params\": [\n        {\n          \"name\": \"domains\",\n          \"type\": \"array\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Domain(s) to summarize\",\n            \"zh\": \"要总结的领域\"\n          },\n          \"enum\": [\n            \"AI\",\n            \"Finance\",\n            \"Crypto\",\n            \"Tech\",\n            \"Science\"\n          ]\n        }\n      ],\n      \"provider_description\": \"Social media monitoring and analysis skills\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 22032.14,\n        \"success_rate\": 1\n      },\n      \"skill_package_url\": \"https://qveris.ai/api/v1/skills/qveris_social.x_domain_hot_events_v1/package\",\n      \"skill_type\": \"package\"\n    },\n    {\n      \"tool_id\": \"qveris_social.x_domain_new_posts_v1\",\n      \"name\": \"X Domain New Posts Today\",\n      \"description\": \"Search today's new posts from domain experts (KOLs) on X/Twitter with full fields: text, images, media, metrics. Supports AI, Finance, Crypto, Tech, Science.\",\n      \"params\": [\n        {\n          \"name\": \"domains\",\n          \"type\": \"array\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Domains to query\",\n            \"zh\": \"要查询的领域\"\n          },\n          \"enum\": [\n            \"AI\",\n            \"Finance\",\n            \"Crypto\",\n            \"Tech\",\n            \"Science\"\n          ]\n        },\n        {\n          \"name\": \"limit\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": null\n        }\n      ],\n      \"provider_description\": \"Social media monitoring and analysis skills\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 7737.01,\n        \"success_rate\": 1\n      },\n      \"skill_package_url\": \"https://qveris.ai/api/v1/skills/qveris_social.x_domain_new_posts_v1/package\",\n      \"skill_type\": \"package\"\n    },\n    {\n      \"tool_id\": \"gdelt-data.doc.tonechart.retrieve.v2.a7b24341\",\n      \"name\": \"Retrieve Tone Chart\",\n      \"description\": \"Generates a histogram showing the distribution of article tones (from extremely negative to extremely positive) for articles mentioning a specific query over the last 3 months.\",\n      \"params\": [\n        {\n          \"name\": \"query\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Search query phrase\"\n          }\n        },\n        {\n          \"name\": \"mode\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"API operation mode\"\n          },\n          \"enum\": [\n            \"tonechart\"\n          ]\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"mode\": \"tonechart\",\n          \"query\": \"climate change\"\n        }\n      },\n      \"provider_description\": \"The Global Database of Events, Language, and Tone (GDELT) monitors the world's broadcast, print, and web news from nearly every corner of every country in over 100 languages and identifies the people, locations, organizations, counts, themes, sources, emotions, quotes, images and events driving our global society every second of every day. GDELT 2.0 updates every 15 minutes with new features including realtime translation of 65 languages and measurement of over 2,300 emotions and themes.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 19242.44,\n        \"success_rate\": 0.077\n      }\n    },\n    {\n      \"tool_id\": \"alphavantage.news_sentiment.retrieve.v1.7aca3c4a\",\n      \"name\": \"Retrieve Market News & Sentiment\",\n      \"description\": \"Returns live and historical market news & sentiment data from premier news outlets around the world, covering stocks, cryptocurrencies, forex, and various financial topics.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The function name.\"\n          },\n          \"enum\": [\n            \"NEWS_SENTIMENT\"\n          ]\n        },\n        {\n          \"name\": \"tickers\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of stock/crypto/forex symbols (e.g., COIN,CRYPTO:BTC,FOREX:USD). Filters articles that mention all listed tickers.\"\n          }\n        },\n        {\n          \"name\": \"topics\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Comma-separated list of topics. Articles must cover all listed topics.\"\n          },\n          \"enum\": [\n            \"blockchain\",\n            \"earnings\",\n            \"ipo\",\n            \"mergers_and_acquisitions\",\n            \"financial_markets\",\n            \"economy_fiscal\",\n            \"economy_monetary\",\n            \"economy_macro\",\n            \"energy_transportation\",\n            \"finance\",\n            \"life_sciences\",\n            \"manufacturing\",\n            \"real_estate\",\n            \"retail_wholesale\",\n            \"technology\"\n          ]\n        },\n        {\n          \"name\": \"time_from\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Start time in YYYYMMDDTHHMM format (e.g., 20220410T0130).\"\n          }\n        },\n        {\n          \"name\": \"time_to\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"End time in YYYYMMDDTHHMM format.\"\n          }\n        },\n        {\n          \"name\": \"sort\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Sorting method.\"\n          },\n          \"enum\": [\n            \"LATEST\",\n            \"EARLIEST\",\n            \"RELEVANCE\"\n          ]\n        },\n 