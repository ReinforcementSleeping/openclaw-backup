{"type":"message","id":"354194ec","parentId":"f7844088","timestamp":"2026-03-04T03:32:54.728Z","message":{"role":"toolResult","toolCallId":"call_function_3nukxt8ti27u_1","toolName":"exec","content":[{"type":"text","text":"{\n  \"query\": \"ths_ifind real time quotation\",\n  \"total\": 10,\n  \"results\": [\n    {\n      \"tool_id\": \"ths_ifind.real_time_quotation.v1\",\n      \"name\": \"iFinD 同花顺实时行情 (THS Real-time Quotation)\",\n      \"description\": \"Query real-time quotation data for securities in the 同花顺 (THS) iFinD database, providing real-time market data for financial products including stocks, funds, bonds, and futures, such as real-time prices, trading volumes, price changes, bid/ask quotes, etc. Supports querying various real-time indicators including latest price, price change, trading volume, turnover ratio, market value, and five-level bid/ask quotes.\",\n      \"params\": [\n        {\n          \"name\": \"codes\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Security codes, multiple codes separated by commas (max 50), e.g., '300033.SZ,600030.SH'\"\n        },\n        {\n          \"name\": \"indicators\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Indicator list, multiple indicators separated by commas. Options: 'common' (common indicators), 'all' (all indicators), or custom indicator list. Default is 'all'\"\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"codes\": \"300033.SZ,600030.SH\"\n        }\n      },\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1667.64,\n        \"success_rate\": 0.887\n      }\n    },\n    {\n      \"tool_id\": \"ths_ifind.quotation.v1\",\n      \"name\": \"iFinD 同花顺行情 (历史+实时) (THS Quotation)\",\n      \"description\": \"Query historical and real-time quotation data for securities in the 同花顺 (THS) iFinD database, supporting price, trading volume, turnover ratio, and other indicators for various financial products including stocks, funds, bonds, and futures.\",\n      \"params\": [\n        {\n          \"name\": \"codes\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Security codes, multiple codes separated by commas (max 50), e.g., '300033.SZ,600030.SH'\"\n        },\n        {\n          \"name\": \"indicators\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Indicator list, comma-separated. Options: 'common' (common indicators), 'all' (all indicators), or custom list. Default is 'all'. Applies to both history and real-time calls.\"\n        },\n        {\n          \"name\": \"startdate\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Start date, formats: 'YYYY-MM-DD', 'YYYY/MM/DD', 'YYYYMMDD'\"\n        },\n        {\n          \"name\": \"enddate\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"End date, formats: 'YYYY-MM-DD', 'YYYY/MM/DD', 'YYYYMMDD'\"\n        },\n        {\n          \"name\": \"interval\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Time period: 'D' (daily), 'W' (weekly), 'M' (monthly), 'Q' (quarterly), 'S' (semi-annual), 'Y' (yearly), default 'D'\"\n        },\n        {\n          \"name\": \"cps\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Adjustment method: '1' (no adjustment), '2' (forward), '3' (backward), '6' (forward cash dividend), '7' (backward cash dividend), default '1'\"\n        },\n        {\n          \"name\": \"fill\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Non-trading day handling: 'Previous' (use previous data), 'Blank' (empty), default 'Previous'\"\n        }\n      ],\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 2750.14,\n        \"success_rate\": 0.9\n      }\n    },\n    {\n      \"tool_id\": \"twelvedata.quote.retrieve.v1.affbefe3\",\n      \"name\": \"Quote\",\n      \"description\": \"The quote endpoint provides real-time data for a selected financial instrument, returning essential information such as the latest price, open, high, low, close, volume, and price change. This endpoint is ideal for users needing up-to-date market data to track price movements and trading activity for specific stocks, ETFs, or other securities.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Symbol ticker of the instrument\"\n          }\n        },\n        {\n          \"name\": \"figi\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Filter by financial instrument global identifier (FIGI). This request parameter is available starting with the <a href=\\\"https://twelvedata.com/pricing\\\">Ultra<a> plan\"\n          }\n        },\n        {\n          \"name\": \"isin\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Filter by international securities identification number (ISIN). ISIN access is activating in the <a href=\\\"https://twelvedata.com/account/add-ons\\\">Data add-ons</a> section\"\n          }\n        },\n        {\n          \"name\": \"cusip\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The CUSIP of an instrument for which data is requested. CUSIP access is activating in the <a href=\\\"https://twelvedata.com/account/add-ons\\\">Data add-ons</a> section\"\n          }\n        },\n        {\n          \"name\": \"interval\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Interval of the quote\"\n          },\n          \"enum\": [\n            \"1min\",\n            \"5min\",\n            \"15min\",\n            \"30min\",\n            \"45min\",\n            \"1h\",\n            \"2h\",\n            \"4h\",\n            \"1day\",\n            \"1week\",\n            \"1month\"\n          ]\n        },\n        {\n          \"name\": \"exchange\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Exchange where instrument is traded\"\n          }\n        },\n        {\n          \"name\": \"mic_code\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Market Identifier Code (MIC) under ISO 10383 standard\"\n          }\n        },\n        {\n          \"name\": \"country\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Country where instrument is traded, e.g., `United States` or `US`\"\n          }\n        },\n        {\n          \"name\": \"volume_time_period\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Number of periods for Average Volume\"\n          }\n        },\n        {\n          \"name\": \"type\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The asset class to which the instrument belongs\"\n          },\n          \"enum\": [\n            \"American Depositary Receipt\",\n            \"Bond\",\n            \"Bond Fund\",\n            \"Closed-end Fund\",\n            \"Common Stock\",\n            \"Depositary Receipt\",\n            \"Digital Currency\",\n            \"ETF\",\n            \"Exchange-Traded Note\",\n            \"Global Depositary Receipt\",\n            \"Limited Partnership\",\n            \"Mutual Fund\",\n            \"Physical Currency\",\n            \"Preferred Stock\",\n            \"REIT\",\n            \"Right\",\n            \"Structured Product\",\n            \"Trust\",\n            \"Unit\",\n            \"Warrant\"\n          ]\n        },\n        {\n          \"name\": \"format\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Value can be JSON or CSV\\nDefault JSON\"\n          },\n          \"enum\": [\n            \"JSON\",\n            \"CSV\"\n          ]\n        },\n        {\n          \"name\": \"delimiter\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Specify the delimiter used when downloading the CSV file\"\n          }\n        },\n        {\n          \"name\": \"prepost\",\n          \"type\": \"boolean\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Parameter is optional. Only for `Pro` and above plans.\\nAvailable at the `1min`, `5min`, `15min`, and `30min` intervals for US equities.\\nOpen, high, low, close values are supplied without volume.\"\n          }\n        },\n        {\n          \"name\": \"eod\",\n          \"type\": \"boolean\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"If true, then return data for closed day\"\n          }\n        },\n        {\n          \"name\": \"rolling_period\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Number of hours for calculate rolling change at period. By default set to 24, it can be in range [1, 168].\"\n          }\n        },\n        {\n          \"name\": \"dp\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Specifies the number of decimal places for floating values\\nShould be in range [0,11] inclusive\"\n          }\n        },\n        {\n          \"name\": \"timezone\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Timezone at which output datetime will be displayed. Supports:\\n<ul>\\n<li>1. <code>Exchange</code> for local exchange time</li>\\n<li>2. <code>UTC</code> for datetime at universal UTC standard</li>\\n<li>3. Timezone name according to the IANA Time Zone Database. E.g. <code>America/New_York</code>, <code>Asia/Singapore</code>. Full list of timezones can be found <a href=\\\"https://en.wikipedia.org/wiki/List_of_tz_database_time_zones\\\" target=\\\"blank\\\">here</a>.</li>\\n</ul>\\n<i>Take note that the IANA Timezone name is case-sensitive</i>\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Financial APIs providing real-time, historical, and EOD data for stocks, forex, cryptocurrency, ETFs, commodities, and fundamental market data. If the parameters of the tool include symbol, figi, isin, and cusip, one of these four parameters must be selected as a required parameter.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 0.596,\n        \"success_rate\": 1\n      }\n    },\n    {\n      \"tool_id\": \"finnhub_io_api.stock.quote\",\n      \"name\": \"Quote\",\n      \"description\": \"Get real-time quote data for US stocks.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Stock symbol\"\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 853.46,\n        \"success_rate\": 0.951\n      }\n    },\n    {\n      \"tool_id\": \"alphavantage.realtime_bulk_quotes.retrieve.v1\",\n      \"name\": \"Realtime Bulk Quotes\",\n      \"description\": \"This is a premium endpoint. ***THE SAMPLE DATA SCHEMA BELOW IS ARTIFICIAL AND FOR ILLUSTRATION PURPOSES ONLY***. To access the actual data, please subscribe to any premium plan that mentions 'Realtime US Market Data' in its description at https://www.alphavantage.co/premium/ for your personal non-professional use. For professional/commercial use, please contact support at support@alphavantage.co.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The API function to call, set to REALTIME_BULK_QUOTES for this endpoint.\"\n          }\n        },\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Comma-separated list of stock symbols (e.g., MSFT,AAPL,IBM).\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"MSFT,AAPL,IBM\",\n          \"function\": \"REALTIME_BULK_QUOTES\"\n        }\n      },\n      \"provider_description\": \"Alpha Vantage provides realtime and historical financial market data through a set of powerful and developer-friendly data APIs and spreadsheets. From traditional asset classes (e.g., stocks, ETFs, mutual funds) to economic indicators, from foreign exchange rates to commodities, from fundamental data to technical indicators, Alpha Vantage is your one-stop-shop for enterprise-grade global market data delivered through cloud-based APIs, MCP servers, spreadsheets, and more.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 565.13,\n        \"success_rate\": 0.258\n      }\n    },\n    {\n      \"tool_id\": \"alphavantage.realtime_bulk_quotes.retrieve.v1.7aca3c4a\",\n      \"name\": \"Realtime Bulk Quotes\",\n      \"description\": \"Returns realtime quotes for US-traded symbols in bulk, accepting up to 100 symbols per API request and covering both regular and extended trading hours.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The time series of your choice.\"\n          },\n          \"enum\": [\n            \"REALTIME_BULK_QUOTES\"\n          ]\n        },\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Up to 100 symbols separated by comma.\"\n          }\n        },\n        {\n          \"name\": \"datatype\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Data format: json or csv.\"\n          },\n          \"enum\": [\n            \"json\",\n            \"csv\"\n          ]\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"AAPL,MSFT,GOOGL\",\n          \"function\": \"REALTIME_BULK_QUOTES\"\n        }\n      },\n      \"provider_description\": \"Alpha Vantage provides realtime and historical financial market data through a set of powerful and developer-friendly data APIs and spreadsheets. From traditional asset classes (e.g., stocks, ETFs, mutual funds) to economic indicators, from foreign exchange rates to commodities, from fundamental data to technical indicators, Alpha Vantage is your one-stop-shop for enterprise-grade global market data delivered through cloud-based APIs, MCP servers, spreadsheets, and more.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 534.28,\n        \"success_rate\": 0.996\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.quote.retrieve.v1.f72cf5ef\",\n      \"name\": \"Quote\",\n      \"description\": \"<p>Get real-time quote data for US stocks. Constant polling is not recommended. Use websocket if you need real-time updates.</p><p>Real-time stock prices for international markets are supported for Enterprise clients via our partner's feed. <a href=\\\"mailto:support@finnhub.io\\\">Contact Us</a> to learn more.</p>\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Symbol\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 695.14,\n        \"success_rate\": 0.971\n      }\n    },\n    {\n      \"tool_id\": \"eodhd.real_time.retrieve.v1.3b8a5cf8\",\n      \"name\": \"Retrieve Real-Time (Delayed) Stock Prices\",\n      \"description\": \"Fetch real-time price data for a specified cryptocurrency pair.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Stock ticker symbol with exchange suffix (e.g., AAPL.US)\"\n          }\n        },\n        {\n          \"name\": \"fmt\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Response format\"\n          },\n          \"enum\": [\n            \"json\",\n            \"csv\"\n          ]\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"EUR.FOREX\"\n        }\n      },\n      \"provider_description\": \"Access historical end-of-day stock prices, intraday data, US stock options, and real-time prices with free and advanced plans. EODHD provides financial data for 150,000+ tickers, including stocks, ETFs, funds, and currencies worldwide.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1093.58,\n        \"success_rate\": 0.948\n      }\n    },\n    {\n      \"tool_id\": \"nbp_pl.cenyzlota.retrieve.v1\",\n      \"name\": \"Retrieve gold price quotations\",\n      \"description\": \"Retrieves gold price quotations (default or recent).\",\n      \"params\": [\n        {\n          \"name\": \"format\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Response format\"\n          },\n          \"enum\": [\n            \"json\",\n            \"xml\"\n          ]\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"format\": \"json\"\n        }\n      },\n      \"provider_description\": \"Narodowy Bank Polski API services providing currency exchange rates, financial data and central banking information\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 657.66,\n        \"success_rate\": 1\n      }\n    },\n    {\n      \"tool_id\": \"twelvedata.price.retrieve.v1.0b36f0a6\",\n      \"name\": \"Latest price\",\n      \"description\": \"The latest price endpoint provides the latest market price for a specified financial instrument. It returns a single data point representing the current (or the most recently available) trading price.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Symbol ticker of the instrument\"\n          }\n        },\n        {\n          \"name\": \"figi\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Filter by financial instrument global identifier (FIGI). This request parameter is available starting with the <a href=\\\"https://twelvedata.com/pricing\\\">Ultra<a> plan\"\n          }\n        },\n        {\n          \"name\": \"isin\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Filter by international securities identification number (ISIN). ISIN access is activating in the <a href=\\\"https://twelvedata.com/account/add-ons\\\">Data add-ons</a> section\"\n          }\n        },\n        {\n          \"name\": \"cusip\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The CUSIP of an instrument for which data is requested. CUSIP access is activating in the <a href=\\\"https://twelvedata.com/account/add-ons\\\">Data add-ons</a> section\"\n          }\n        },\n        {\n          \"name\": \"exchange\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Exchange where instrument is traded\"\n          }\n        },\n        {\n          \"name\": \"mic_code\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Market Identifier Code (MIC) under ISO 10383 standard\"\n          }\n        },\n        {\n          \"name\": \"country\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Country where instrument is traded, e.g., `United States` or `US`\"\n          }\n        },\n        {\n          \"name\": \"type\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The asset class to which the instrument belongs\"\n          },\n          \"enum\": [\n            \"American Depositary Receipt\",\n            \"Bond\",\n            \"Bond Fund\",\n            \"Closed-end Fund\",\n            \"Common Stock\",\n            \"Depositary Receipt\",\n            \"Digital Currency\",\n            \"ETF\",\n            \"Exchange-Traded Note\",\n            \"Global Depositary Receipt\",\n            \"Limited Partnership\",\n            \"Mutual Fund\",\n            \"Physical Currency\",\n            \"Preferred Stock\",\n            \"REIT\",\n            \"Right\",\n            \"Structured Product\",\n            \"Trust\",\n            \"Unit\",\n            \"Warrant\"\n          ]\n        },\n        {\n          \"name\": \"format\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Value can be JSON or CSV\"\n          },\n          \"enum\": [\n            \"JSON\",\n            \"CSV\"\n          ]\n        },\n        {\n          \"name\": \"delimiter\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Specify the delimiter used when downloading the CSV file\"\n          }\n        },\n        {\n          \"name\": \"prepost\",\n          \"type\": \"boolean\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Parameter is optional. Only for Pro and above plans.\\nAvailable at the `1min`, `5min`, `15min`, and `30min` intervals for US equities.\\nOpen, high, low, close values are supplied without volume.\"\n          }\n        },\n        {\n          \"name\": \"dp\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Specifies the number of decimal places for floating values.\\nShould be in range [0,11] inclusive\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Financial APIs providing real-time, historical, and EOD data for stocks, forex, cryptocurrency, ETFs, commodities, and fundamental market data. If the parameters of the tool include symbol, figi, isin, and cusip, one of these four parameters must be selected as a required parameter.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 0.575,\n        \"success_rate\": 1\n      }\n    }\n  ],\n  \"search_id\": \"16cd743b-0456-47b4-9841-241d405b9aca\",\n  \"elapsed_time_ms\": 530.62\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":1465,"aggregated":"{\n  \"query\": \"ths_ifind real time quotation\",\n  \"total\": 10,\n  \"results\": [\n    {\n      \"tool_id\": \"ths_ifind.real_time_quotation.v1\",\n      \"name\": \"iFinD 同花顺实时行情 (THS Real-time Quotation)\",\n      \"description\": \"Query real-time quotation data for securities in the 同花顺 (THS) iFinD database, providing real-time market data for financial products including stocks, funds, bonds, and futures, such as real-time prices, trading volumes, price changes, bid/ask quotes, etc. Supports querying various real-time indicators including latest price, price change, trading volume, turnover ratio, market value, and five-level bid/ask quotes.\",\n      \"params\": [\n        {\n          \"name\": \"codes\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Security codes, multiple codes separated by commas (max 50), e.g., '300033.SZ,600030.SH'\"\n        },\n        {\n          \"name\": \"indicators\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Indicator list, multiple indicators separated by commas. Options: 'common' (common indicators), 'all' (all indicators), or custom indicator list. Default is 'all'\"\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"codes\": \"300033.SZ,600030.SH\"\n        }\n      },\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1667.64,\n        \"success_rate\": 0.887\n      }\n    },\n    {\n      \"tool_id\": \"ths_ifind.quotation.v1\",\n      \"name\": \"iFinD 同花顺行情 (历史+实时) (THS Quotation)\",\n      \"description\": \"Query historical and real-time quotation data for securities in the 同花顺 (THS) iFinD database, supporting price, trading volume, turnover ratio, and other indicators for various financial products including stocks, funds, bonds, and futures.\",\n      \"params\": [\n        {\n          \"name\": \"codes\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Security codes, multiple codes separated by commas (max 50), e.g., '300033.SZ,600030.SH'\"\n        },\n        {\n          \"name\": \"indicators\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Indicator list, comma-separated. Options: 'common' (common indicators), 'all' (all indicators), or custom list. Default is 'all'. Applies to both history and real-time calls.\"\n        },\n        {\n          \"name\": \"startdate\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Start date, formats: 'YYYY-MM-DD', 'YYYY/MM/DD', 'YYYYMMDD'\"\n        },\n        {\n          \"name\": \"enddate\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"End date, formats: 'YYYY-MM-DD', 'YYYY/MM/DD', 'YYYYMMDD'\"\n        },\n        {\n          \"name\": \"interval\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Time period: 'D' (daily), 'W' (weekly), 'M' (monthly), 'Q' (quarterly), 'S' (semi-annual), 'Y' (yearly), default 'D'\"\n        },\n        {\n          \"name\": \"cps\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Adjustment method: '1' (no adjustment), '2' (forward), '3' (backward), '6' (forward cash dividend), '7' (backward cash dividend), default '1'\"\n        },\n        {\n          \"name\": \"fill\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": \"Non-trading day handling: 'Previous' (use previous data), 'Blank' (empty), default 'Previous'\"\n        }\n      ],\n      \"provider_description\": \"同花顺 (THS) iFinD data provider, offering financial data for Chinese and international markets including stocks, securities, funds, bonds, futures, etc. Supports company announcements, intelligent stock screening, industry analysis, market trend prediction, and more, helping users conduct comprehensive financial data analysis and investment decisions.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 2750.14,\n        \"success_rate\": 0.9\n      }\n    },\n    {\n      \"tool_id\": \"twelvedata.quote.retrieve.v1.affbefe3\",\n      \"name\": \"Quote\",\n      \"description\": \"The quote endpoint provides real-time data for a selected financial instrument, returning essential information such as the latest price, open, high, low, close, volume, and price change. This endpoint is ideal for users needing up-to-date market data to track price movements and trading activity for specific stocks, ETFs, or other securities.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Symbol ticker of the instrument\"\n          }\n        },\n        {\n          \"name\": \"figi\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Filter by financial instrument global identifier (FIGI). This request parameter is available starting with the <a href=\\\"https://twelvedata.com/pricing\\\">Ultra<a> plan\"\n          }\n        },\n        {\n          \"name\": \"isin\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Filter by international securities identification number (ISIN). ISIN access is activating in the <a href=\\\"https://twelvedata.com/account/add-ons\\\">Data add-ons</a> section\"\n          }\n        },\n        {\n          \"name\": \"cusip\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The CUSIP of an instrument for which data is requested. CUSIP access is activating in the <a href=\\\"https://twelvedata.com/account/add-ons\\\">Data add-ons</a> section\"\n          }\n        },\n        {\n          \"name\": \"interval\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Interval of the quote\"\n          },\n          \"enum\": [\n            \"1min\",\n            \"5min\",\n            \"15min\",\n            \"30min\",\n            \"45min\",\n            \"1h\",\n            \"2h\",\n            \"4h\",\n            \"1day\",\n            \"1week\",\n            \"1month\"\n          ]\n        },\n        {\n          \"name\": \"exchange\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Exchange where instrument is traded\"\n          }\n        },\n        {\n          \"name\": \"mic_code\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Market Identifier Code (MIC) under ISO 10383 standard\"\n          }\n        },\n        {\n          \"name\": \"country\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Country where instrument is traded, e.g., `United States` or `US`\"\n          }\n        },\n        {\n          \"name\": \"volume_time_period\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Number of periods for Average Volume\"\n          }\n        },\n        {\n          \"name\": \"type\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The asset class to which the instrument belongs\"\n          },\n          \"enum\": [\n            \"American Depositary Receipt\",\n            \"Bond\",\n            \"Bond Fund\",\n            \"Closed-end Fund\",\n            \"Common Stock\",\n            \"Depositary Receipt\",\n            \"Digital Currency\",\n            \"ETF\",\n            \"Exchange-Traded Note\",\n            \"Global Depositary Receipt\",\n            \"Limited Partnership\",\n            \"Mutual Fund\",\n            \"Physical Currency\",\n            \"Preferred Stock\",\n            \"REIT\",\n            \"Right\",\n            \"Structured Product\",\n            \"Trust\",\n            \"Unit\",\n            \"Warrant\"\n          ]\n        },\n        {\n          \"name\": \"format\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Value can be JSON or CSV\\nDefault JSON\"\n          },\n          \"enum\": [\n            \"JSON\",\n            \"CSV\"\n          ]\n        },\n        {\n          \"name\": \"delimiter\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Specify the delimiter used when downloading the CSV file\"\n          }\n        },\n        {\n          \"name\": \"prepost\",\n          \"type\": \"boolean\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Parameter is optional. Only for `Pro` and above plans.\\nAvailable at the `1min`, `5min`, `15min`, and `30min` intervals for US equities.\\nOpen, high, low, close values are supplied without volume.\"\n          }\n        },\n        {\n          \"name\": \"eod\",\n          \"type\": \"boolean\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"If true, then return data for closed day\"\n          }\n        },\n        {\n          \"name\": \"rolling_period\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Number of hours for calculate rolling change at period. By default set to 24, it can be in range [1, 168].\"\n          }\n        },\n        {\n          \"name\": \"dp\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Specifies the number of decimal places for floating values\\nShould be in range [0,11] inclusive\"\n          }\n        },\n        {\n          \"name\": \"timezone\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Timezone at which output datetime will be displayed. Supports:\\n<ul>\\n<li>1. <code>Exchange</code> for local exchange time</li>\\n<li>2. <code>UTC</code> for datetime at universal UTC standard</li>\\n<li>3. Timezone name according to the IANA Time Zone Database. E.g. <code>America/New_York</code>, <code>Asia/Singapore</code>. Full list of timezones can be found <a href=\\\"https://en.wikipedia.org/wiki/List_of_tz_database_time_zones\\\" target=\\\"blank\\\">here</a>.</li>\\n</ul>\\n<i>Take note that the IANA Timezone name is case-sensitive</i>\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Financial APIs providing real-time, historical, and EOD data for stocks, forex, cryptocurrency, ETFs, commodities, and fundamental market data. If the parameters of the tool include symbol, figi, isin, and cusip, one of these four parameters must be selected as a required parameter.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 0.596,\n        \"success_rate\": 1\n      }\n    },\n    {\n      \"tool_id\": \"finnhub_io_api.stock.quote\",\n      \"name\": \"Quote\",\n      \"description\": \"Get real-time quote data for US stocks.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": \"Stock symbol\"\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 853.46,\n        \"success_rate\": 0.951\n      }\n    },\n    {\n      \"tool_id\": \"alphavantage.realtime_bulk_quotes.retrieve.v1\",\n      \"name\": \"Realtime Bulk Quotes\",\n      \"description\": \"This is a premium endpoint. ***THE SAMPLE DATA SCHEMA BELOW IS ARTIFICIAL AND FOR ILLUSTRATION PURPOSES ONLY***. To access the actual data, please subscribe to any premium plan that mentions 'Realtime US Market Data' in its description at https://www.alphavantage.co/premium/ for your personal non-professional use. For professional/commercial use, please contact support at support@alphavantage.co.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The API function to call, set to REALTIME_BULK_QUOTES for this endpoint.\"\n          }\n        },\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Comma-separated list of stock symbols (e.g., MSFT,AAPL,IBM).\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"MSFT,AAPL,IBM\",\n          \"function\": \"REALTIME_BULK_QUOTES\"\n        }\n      },\n      \"provider_description\": \"Alpha Vantage provides realtime and historical financial market data through a set of powerful and developer-friendly data APIs and spreadsheets. From traditional asset classes (e.g., stocks, ETFs, mutual funds) to economic indicators, from foreign exchange rates to commodities, from fundamental data to technical indicators, Alpha Vantage is your one-stop-shop for enterprise-grade global market data delivered through cloud-based APIs, MCP servers, spreadsheets, and more.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 565.13,\n        \"success_rate\": 0.258\n      }\n    },\n    {\n      \"tool_id\": \"alphavantage.realtime_bulk_quotes.retrieve.v1.7aca3c4a\",\n      \"name\": \"Realtime Bulk Quotes\",\n      \"description\": \"Returns realtime quotes for US-traded symbols in bulk, accepting up to 100 symbols per API request and covering both regular and extended trading hours.\",\n      \"params\": [\n        {\n          \"name\": \"function\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"The time series of your choice.\"\n          },\n          \"enum\": [\n            \"REALTIME_BULK_QUOTES\"\n          ]\n        },\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Up to 100 symbols separated by comma.\"\n          }\n        },\n        {\n          \"name\": \"datatype\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Data format: json or csv.\"\n          },\n          \"enum\": [\n            \"json\",\n            \"csv\"\n          ]\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"AAPL,MSFT,GOOGL\",\n          \"function\": \"REALTIME_BULK_QUOTES\"\n        }\n      },\n      \"provider_description\": \"Alpha Vantage provides realtime and historical financial market data through a set of powerful and developer-friendly data APIs and spreadsheets. From traditional asset classes (e.g., stocks, ETFs, mutual funds) to economic indicators, from foreign exchange rates to commodities, from fundamental data to technical indicators, Alpha Vantage is your one-stop-shop for enterprise-grade global market data delivered through cloud-based APIs, MCP servers, spreadsheets, and more.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 534.28,\n        \"success_rate\": 0.996\n      }\n    },\n    {\n      \"tool_id\": \"finnhub.quote.retrieve.v1.f72cf5ef\",\n      \"name\": \"Quote\",\n      \"description\": \"<p>Get real-time quote data for US stocks. Constant polling is not recommended. Use websocket if you need real-time updates.</p><p>Real-time stock prices for international markets are supported for Enterprise clients via our partner's feed. <a href=\\\"mailto:support@finnhub.io\\\">Contact Us</a> to learn more.</p>\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Symbol\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Finnhub - Free APIs for realtime stock, forex, and cryptocurrency. Company fundamentals, Economic data, and Alternative data.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 695.14,\n        \"success_rate\": 0.971\n      }\n    },\n    {\n      \"tool_id\": \"eodhd.real_time.retrieve.v1.3b8a5cf8\",\n      \"name\": \"Retrieve Real-Time (Delayed) Stock Prices\",\n      \"description\": \"Fetch real-time price data for a specified cryptocurrency pair.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": true,\n          \"description\": {\n            \"en\": \"Stock ticker symbol with exchange suffix (e.g., AAPL.US)\"\n          }\n        },\n        {\n          \"name\": \"fmt\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Response format\"\n          },\n          \"enum\": [\n            \"json\",\n            \"csv\"\n          ]\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"EUR.FOREX\"\n        }\n      },\n      \"provider_description\": \"Access historical end-of-day stock prices, intraday data, US stock options, and real-time prices with free and advanced plans. EODHD provides financial data for 150,000+ tickers, including stocks, ETFs, funds, and currencies worldwide.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 1093.58,\n        \"success_rate\": 0.948\n      }\n    },\n    {\n      \"tool_id\": \"nbp_pl.cenyzlota.retrieve.v1\",\n      \"name\": \"Retrieve gold price quotations\",\n      \"description\": \"Retrieves gold price quotations (default or recent).\",\n      \"params\": [\n        {\n          \"name\": \"format\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Response format\"\n          },\n          \"enum\": [\n            \"json\",\n            \"xml\"\n          ]\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"format\": \"json\"\n        }\n      },\n      \"provider_description\": \"Narodowy Bank Polski API services providing currency exchange rates, financial data and central banking information\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 657.66,\n        \"success_rate\": 1\n      }\n    },\n    {\n      \"tool_id\": \"twelvedata.price.retrieve.v1.0b36f0a6\",\n      \"name\": \"Latest price\",\n      \"description\": \"The latest price endpoint provides the latest market price for a specified financial instrument. It returns a single data point representing the current (or the most recently available) trading price.\",\n      \"params\": [\n        {\n          \"name\": \"symbol\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Symbol ticker of the instrument\"\n          }\n        },\n        {\n          \"name\": \"figi\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Filter by financial instrument global identifier (FIGI). This request parameter is available starting with the <a href=\\\"https://twelvedata.com/pricing\\\">Ultra<a> plan\"\n          }\n        },\n        {\n          \"name\": \"isin\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Filter by international securities identification number (ISIN). ISIN access is activating in the <a href=\\\"https://twelvedata.com/account/add-ons\\\">Data add-ons</a> section\"\n          }\n        },\n        {\n          \"name\": \"cusip\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The CUSIP of an instrument for which data is requested. CUSIP access is activating in the <a href=\\\"https://twelvedata.com/account/add-ons\\\">Data add-ons</a> section\"\n          }\n        },\n        {\n          \"name\": \"exchange\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Exchange where instrument is traded\"\n          }\n        },\n        {\n          \"name\": \"mic_code\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Market Identifier Code (MIC) under ISO 10383 standard\"\n          }\n        },\n        {\n          \"name\": \"country\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Country where instrument is traded, e.g., `United States` or `US`\"\n          }\n        },\n        {\n          \"name\": \"type\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"The asset class to which the instrument belongs\"\n          },\n          \"enum\": [\n            \"American Depositary Receipt\",\n            \"Bond\",\n            \"Bond Fund\",\n            \"Closed-end Fund\",\n            \"Common Stock\",\n            \"Depositary Receipt\",\n            \"Digital Currency\",\n            \"ETF\",\n            \"Exchange-Traded Note\",\n            \"Global Depositary Receipt\",\n            \"Limited Partnership\",\n            \"Mutual Fund\",\n            \"Physical Currency\",\n            \"Preferred Stock\",\n            \"REIT\",\n            \"Right\",\n            \"Structured Product\",\n            \"Trust\",\n            \"Unit\",\n            \"Warrant\"\n          ]\n        },\n        {\n          \"name\": \"format\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Value can be JSON or CSV\"\n          },\n          \"enum\": [\n            \"JSON\",\n            \"CSV\"\n          ]\n        },\n        {\n          \"name\": \"delimiter\",\n          \"type\": \"string\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Specify the delimiter used when downloading the CSV file\"\n          }\n        },\n        {\n          \"name\": \"prepost\",\n          \"type\": \"boolean\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Parameter is optional. Only for Pro and above plans.\\nAvailable at the `1min`, `5min`, `15min`, and `30min` intervals for US equities.\\nOpen, high, low, close values are supplied without volume.\"\n          }\n        },\n        {\n          \"name\": \"dp\",\n          \"type\": \"integer\",\n          \"required\": false,\n          \"description\": {\n            \"en\": \"Specifies the number of decimal places for floating values.\\nShould be in range [0,11] inclusive\"\n          }\n        }\n      ],\n      \"examples\": {\n        \"sample_parameters\": {\n          \"symbol\": \"AAPL\"\n        }\n      },\n      \"provider_description\": \"Financial APIs providing real-time, historical, and EOD data for stocks, forex, cryptocurrency, ETFs, commodities, and fundamental market data. If the parameters of the tool include symbol, figi, isin, and cusip, one of these four parameters must be selected as a required parameter.\",\n      \"stats\": {\n        \"avg_execution_time_ms\": 0.575,\n        \"success_rate\": 1\n      }\n    }\n  ],\n  \"search_id\": \"16cd743b-0456-47b4-9841-241d405b9aca\",\n  \"elapsed_time_ms\": 530.62\n}","cwd":"/Users/lynch/.openclaw/workspace"},"isError":false,"timestamp":1772595174727}}
