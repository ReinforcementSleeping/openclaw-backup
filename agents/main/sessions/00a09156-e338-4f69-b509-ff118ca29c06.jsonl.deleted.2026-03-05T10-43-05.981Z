{"type":"message","id":"3c8bc712","parentId":"dc931fca","timestamp":"2026-03-04T03:33:58.697Z","message":{"role":"toolResult","toolCallId":"call_function_t3oa11wbt9u6_1","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env node\n\nconst API_BASE = 'https://qveris.ai/api/v1';\nconst API_KEY = process.env.QVERIS_API_KEY;\n\nasync function search(query, limit = 10) {\n  const res = await fetch(`${API_BASE}/search`, {\n    method: 'POST',\n    headers: {\n      'Content-Type': 'application/json',\n      'Authorization': `Bearer ${API_KEY}`\n    },\n    body: JSON.stringify({ query, limit })\n  });\n  const data = await res.json();\n  return data;\n}\n\nasync function execute(toolId, params, searchId = null) {\n  const res = await fetch(`${API_BASE}/tools/execute`, {\n    method: 'POST',\n    headers: {\n      'Content-Type': 'application/json',\n      'Authorization': `Bearer ${API_KEY}`\n    },\n    body: JSON.stringify({ tool_id: toolId, params, search_id: searchId })\n  });\n  const data = await res.json();\n  return data;\n}\n\nasync function getByIds(...ids) {\n  const res = await fetch(`${API_BASE}/tools/get-by-ids`, {\n    method: 'POST',\n    headers: {\n      'Content-Type': 'application/json',\n      'Authorization': `Bearer ${API_KEY}`\n    },\n    body: JSON.stringify({ ids })\n  });\n  const data = await res.json();\n  return data;\n}\n\nconst cmd = process.argv[2];\nconst args = process.argv.slice(3);\n\nasync function main() {\n  try {\n    if (cmd === 'search') {\n      const query = args[0];\n      const limit = args.includes('--limit') ? parseInt(args[args.indexOf('--limit') + 1]) : 10;\n      const result = await search(query, limit);\n      console.log(JSON.stringify(result, null, 2));\n    } else if (cmd === 'execute') {\n      const toolId = args[0];\n      const searchIdIdx = args.indexOf('--search-id');\n      const searchId = searchIdIdx > -1 ? args[searchIdIdx + 1] : null;\n      const paramsIdx = args.indexOf('--params');\n      const params = paramsIdx > -1 ? JSON.parse(args[paramsIdx + 1]) : {};\n      const result = await execute(toolId, params, searchId);\n      console.log(JSON.stringify(result, null, 2));\n    } else if (cmd === 'get-by-ids') {\n      const result = await getByIds(...args.filter(a => !a.startsWith('--')));\n      console.log(JSON.stringify(result, null, 2));\n    } else {\n      console.error('Unknown command:', cmd);\n      process.exit(1);\n    }\n  } catch (err) {\n    console.error('Error:', err.message);\n    process.exit(1);\n  }\n}\n\nmain();"}],"details":{"status":"completed","exitCode":0,"durationMs":10,"aggregated":"#!/usr/bin/env node\n\nconst API_BASE = 'https://qveris.ai/api/v1';\nconst API_KEY = process.env.QVERIS_API_KEY;\n\nasync function search(query, limit = 10) {\n  const res = await fetch(`${API_BASE}/search`, {\n    method: 'POST',\n    headers: {\n      'Content-Type': 'application/json',\n      'Authorization': `Bearer ${API_KEY}`\n    },\n    body: JSON.stringify({ query, limit })\n  });\n  const data = await res.json();\n  return data;\n}\n\nasync function execute(toolId, params, searchId = null) {\n  const res = await fetch(`${API_BASE}/tools/execute`, {\n    method: 'POST',\n    headers: {\n      'Content-Type': 'application/json',\n      'Authorization': `Bearer ${API_KEY}`\n    },\n    body: JSON.stringify({ tool_id: toolId, params, search_id: searchId })\n  });\n  const data = await res.json();\n  return data;\n}\n\nasync function getByIds(...ids) {\n  const res = await fetch(`${API_BASE}/tools/get-by-ids`, {\n    method: 'POST',\n    headers: {\n      'Content-Type': 'application/json',\n      'Authorization': `Bearer ${API_KEY}`\n    },\n    body: JSON.stringify({ ids })\n  });\n  const data = await res.json();\n  return data;\n}\n\nconst cmd = process.argv[2];\nconst args = process.argv.slice(3);\n\nasync function main() {\n  try {\n    if (cmd === 'search') {\n      const query = args[0];\n      const limit = args.includes('--limit') ? parseInt(args[args.indexOf('--limit') + 1]) : 10;\n      const result = await search(query, limit);\n      console.log(JSON.stringify(result, null, 2));\n    } else if (cmd === 'execute') {\n      const toolId = args[0];\n      const searchIdIdx = args.indexOf('--search-id');\n      const searchId = searchIdIdx > -1 ? args[searchIdIdx + 1] : null;\n      const paramsIdx = args.indexOf('--params');\n      const params = paramsIdx > -1 ? JSON.parse(args[paramsIdx + 1]) : {};\n      const result = await execute(toolId, params, searchId);\n      console.log(JSON.stringify(result, null, 2));\n    } else if (cmd === 'get-by-ids') {\n      const result = await getByIds(...args.filter(a => !a.startsWith('--')));\n      console.log(JSON.stringify(result, null, 2));\n    } else {\n      console.error('Unknown command:', cmd);\n      process.exit(1);\n    }\n  } catch (err) {\n    console.error('Error:', err.message);\n    process.exit(1);\n  }\n}\n\nmain();","cwd":"/Users/lynch/.openclaw/workspace"},"isError":false,"timestamp":1772595238695}}
