{
   "action": {
      "default_icon": {
         "128": "icon121.png",
         "16": "icon16.png",
         "32": "icon32.png",
         "48": "icon121.png"
      },
      "default_title": "OpenClaw Browser Relay (click to attach/detach)"
   },
   "background": {
      "service_worker": "background.js",
