      "128": "icon121.png",
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon121.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "OpenClaw Browser Relay for Chrome",
   "options_ui": {
      "open_in_tab": true,
      "page": "options.html"
   },
   "permissions": [ "debugger", "activeTab", "storage" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0"
}
